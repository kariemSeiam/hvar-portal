# tools/pending-sells-viewer/.env (optional; merged with repo root .env)

# Hub API — default local Flask (run.py :5050)
MCRM_API_BASE=http://127.0.0.1:5050
# MCRM_API_TOKEN=
# MCRM_ACTION_USER_ID=1
# Confirm uses this user_id when the page does not pass ?user_id= (must exist in DB).
# 400 من الـ API غالباً: تتبع مكرر، مخزون، حالة التذكرة ليست معلقة، أو user_id غير صالح.
# MCRM_API_INSECURE=1

# Standalone viewer only (python server.py); on hub use :5050 instead
# PENDING_SELLS_VIEWER_PORT=8765

# ERP (فحص ERP)
# ERP_BASE=https://erp.hvarstore.com
# ERP_SESSION_COOKIE=
# ERP_XSRF_COOKIE=
# ERP_XSRF_HEADER=

# With hub running: open http://127.0.0.1:5050/pending-sells/

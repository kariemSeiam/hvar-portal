{
    "mcpServers": {
        "hub-mcrm-api": {
            "command": "node",
            "args": ["/mnt/pigo-hub/Developer/Web/Hvar/Hvar-2025/HUB-MCRM/mcp-servers/hub-mcrm-api/dist/index.js"],
            "env": {
                "HUB_MCRM_API_URL": "http://127.0.0.1:5050",
                "HUB_MCRM_MANIFEST_PATH": "/mnt/pigo-hub/Developer/Web/Hvar/Hvar-2025/HUB-MCRM/docs/system/api-manifest.json"
            }
        },
        "github": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-github"
            ],
            "env": {
                "GITHUB_TOKEN": "${GITHUB_TOKEN}"
            }
        },
        "browser-tools": {
            "command": "npx",
            "args": [
                "-y",
                "@agentdeskai/browser-tools-mcp@latest"
            ]
        },
        "chrome-devtools": {
            "command": "npx",
            "args": [
                "-y",
                "chrome-devtools-mcp@latest",
                "--no-usage-statistics",
                "--no-performance-crux",
                "--browser-url=http://127.0.0.1:9222"
            ],
            "env": {
                "CHROME_DEVTOOLS_MCP_NO_UPDATE_CHECKS": "1"
            }
        }
    }
}

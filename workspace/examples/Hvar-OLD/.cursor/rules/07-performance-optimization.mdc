## Backend Performance Optimization

### Database Query Optimization
Follow established patterns for efficient database operations:

```python
# Optimize database queries
class OptimizedService:
    def __init__(self):
        self.db = get_db_connection()
    
    def get_customers_with_orders(self, limit=50):
        """Optimized query with JOIN and LIMIT"""
        with get_db_cursor() as cursor:
            cursor.execute("""
                SELECT 
                    c.id, c.name, c.phone, c.email,
                    COUNT(o.id) as order_count,
                    MAX(o.created_at) as last_order
                FROM customers c
                LEFT JOIN orders o ON c.id = o.customer_id
                GROUP BY c.id
                ORDER BY last_order DESC
                LIMIT ?
            """, (limit,))
            
            return cursor.fetchall()
    
    def get_customer_by_phone(self, phone):
        """Use indexed field for fast lookup"""
        with get_db_cursor() as cursor:
            cursor.execute("""
                SELECT * FROM customers 
                WHERE phone = ? 
                LIMIT 1
            """, (phone,))
            
            row = cursor.fetchone()
            return row if row else None
```

### API Response Optimization
Optimize API responses for better performance:

```python
# Optimize API responses
def create_optimized_response(success=True, data=None, error=None):
    """Create optimized API response with minimal overhead"""
    response = {
        'success': success,
        'timestamp': datetime.utcnow().isoformat()
    }
    
    if success and data is not None:
        response['data'] = data
    elif not success and error:
        response['error'] = error
    
    return jsonify(response)

# Use pagination for large datasets
def get_paginated_data(page=1, per_page=20, **filters):
    """Get paginated data with efficient querying"""
    offset = (page - 1) * per_page
    
    with get_db_cursor() as cursor:
        # Get total count
        cursor.execute("SELECT COUNT(*) FROM table_name")
        total = cursor.fetchone()[0]
        
        # Get paginated data
        cursor.execute("""
            SELECT * FROM table_name
            ORDER BY created_at DESC
            LIMIT ? OFFSET ?
        """, (per_page, offset))
        
        data = cursor.fetchall()
        
        return {
            'data': data,
            'pagination': {
                'page': page,
                'per_page': per_page,
                'total': total,
                'pages': (total + per_page - 1) // per_page
            }
        }
```

### Background Task Optimization
Optimize background tasks for better performance:

```python
# Optimize background task processing
class OptimizedTaskProcessor:
    def __init__(self):
        self.scheduler = BackgroundScheduler()
        self.batch_size = 100
        self.max_workers = 4
    
    def process_orders_batch(self, orders):
        """Process orders in optimized batches"""
        if not orders:
            return
        
        # Process in batches to avoid memory issues
        for i in range(0, len(orders), self.batch_size):
            batch = orders[i:i + self.batch_size]
            self._process_batch(batch)
    
    def _process_batch(self, batch):
        """Process a single batch of orders"""
        with ThreadPoolExecutor(max_workers=self.max_workers) as executor:
            futures = [
                executor.submit(self._process_single_order, order)
                for order in batch
            ]
            
            # Wait for all to complete
            for future in as_completed(futures):
                try:
                    result = future.result()
                    # Handle result
                except Exception as e:
                    logger.error(f"Order processing failed: {e}")
    
    def _process_single_order(self, order):
        """Process a single order"""
        try:
            # Process order logic
            return {'success': True, 'order_id': order['id']}
        except Exception as e:
            logger.error(f"Failed to process order {order['id']}: {e}")
            return {'success': False, 'order_id': order['id'], 'error': str(e)}
```


# Security Practices & Best Practices

## Frontend Security

### Input Validation & Sanitization
Implement comprehensive input validation on the frontend:

```jsx
// Input validation utilities
const validationRules = {
  phone: {
    pattern: /^(\+20|0)?1[0125][0-9]{8}$/,
    message: 'يرجى إدخال رقم هاتف مصري صحيح'
  },
  email: {
    pattern: /^[^\s@]+@[^\s@]+\.[^\s@]+$/,
    message: 'يرجى إدخال بريد إلكتروني صحيح'
  },
  name: {
    minLength: 2,
    maxLength: 50,
    pattern: /^[\u0600-\u06FF\s\w]+$/,
    message: 'يرجى إدخال اسم صحيح'
  }
};

const validateInput = (value, rule) => {
  if (!value) return { isValid: false, message: 'هذا الحقل مطلوب' };
  
  if (rule.minLength && value.length < rule.minLength) {
    return { isValid: false, message: `يجب أن يكون الطول على الأقل ${rule.minLength} أحرف` };
  }
  
  if (rule.maxLength && value.length > rule.maxLength) {
    return { isValid: false, message: `يجب أن يكون الطول على الأكثر ${rule.maxLength} أحرف` };
  }
  
  if (rule.pattern && !rule.pattern.test(value)) {
    return { isValid: false, message: rule.message };
  }
  
  return { isValid: true, message: '' };
};

// Use in components
const InputField = ({ name, type, value, onChange, validationRule }) => {
  const [error, setError] = useState('');
  
  const handleChange = (e) => {
    const newValue = e.target.value;
    onChange(newValue);
    
    if (validationRule) {
      const validation = validateInput(newValue, validationRule);
      setError(validation.message);
    }
  };
  
  return (
    <div>
      <input
        type={type}
        name={name}
        value={value}
        onChange={handleChange}
        className={cn(
          'border rounded-md px-3 py-2 w-full',
          error ? 'border-red-500' : 'border-gray-300'
        )}
      />
      {error && <p className="text-red-500 text-sm mt-1">{error}</p>}
    </div>
  );
};
```

### XSS Prevention
Implement XSS prevention measures:

```jsx
// Safe HTML rendering utility
import DOMPurify from 'dompurify';

const SafeHTML = ({ html, className = '' }) => {
  const sanitizedHTML = DOMPurify.sanitize(html, {
    ALLOWED_TAGS: ['b', 'i', 'em', 'strong', 'a', 'br'],
    ALLOWED_ATTR: ['href', 'target']
  });
  
  return (
    <div 
      className={className}
      dangerouslySetInnerHTML={{ __html: sanitizedHTML }}
    />
  );
};

// Safe content display
const ContentDisplay = ({ content }) => {
  // Always escape user content
  const escapedContent = content
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#x27;');
  
  return <div>{escapedContent}</div>;
};
```

### CSRF Protection
Implement CSRF protection for forms:

```jsx
// CSRF token management
const useCSRFToken = () => {
  const [csrfToken, setCsrfToken] = useState('');
  
  useEffect(() => {
    // Get CSRF token from meta tag or API
    const token = document.querySelector('meta[name="csrf-token"]')?.content;
    if (token) {
      setCsrfToken(token);
    }
  }, []);
  
  return csrfToken;
};

// Secure form submission
const SecureForm = ({ onSubmit, children }) => {
  const csrfToken = useCSRFToken();
  
  const handleSubmit = async (e) => {
    e.preventDefault();
    
    const formData = new FormData(e.target);
    formData.append('_csrf', csrfToken);
    
    try {
      await onSubmit(formData);
    } catch (error) {
      console.error('Form submission failed:', error);
    }
  };
  
  return (
    <form onSubmit={handleSubmit}>
      <input type="hidden" name="_csrf" value={csrfToken} />
      {children}
    </form>
  );
};
```

## Backend Security

### Input Validation & Sanitization
Implement server-side input validation:

```python
# Input validation utilities
import re
from typing import Dict, Any, Optional
from dataclasses import dataclass

@dataclass
class ValidationRule:
    required: bool = True
    min_length: Optional[int] = None
    max_length: Optional[int] = None
    pattern: Optional[str] = None
    custom_validator: Optional[callable] = None

class InputValidator:
    def __init__(self):
        self.rules = {
            'phone': ValidationRule(
                required=True,
                pattern=r'^(\+20|0)?1[0125][0-9]{8}$',
                min_length=10,
                max_length=15
            ),
            'email': ValidationRule(
                required=True,
                pattern=r'^[^\s@]+@[^\s@]+\.[^\s@]+$',
                max_length=255
            ),
            'name': ValidationRule(
                required=True,
                min_length=2,
                max_length=50,
                pattern=r'^[\u0600-\u06FF\s\w]+$'
            )
        }
    
    def validate(self, data: Dict[str, Any]) -> Dict[str, list]:
        """Validate input data against rules"""
        errors = {}
        
        for field, rule in self.rules.items():
            value = data.get(field, '')
            
            # Check required
            if rule.required and not value:
                errors[field] = ['هذا الحقل مطلوب']
                continue
            
            if not value:  # Skip validation for empty optional fields
                continue
            
            # Check length
            if rule.min_length and len(value) < rule.min_length:
                errors[field] = [f'يجب أن يكون الطول على الأقل {rule.min_length} أحرف']
            
            if rule.max_length and len(value) > rule.max_length:
                errors[field] = [f'يجب أن يكون الطول على الأكثر {rule.max_length} أحرف']
            
            # Check pattern
            if rule.pattern and not re.match(rule.pattern, value):
                errors[field] = ['القيمة غير صحيحة']
            
            # Custom validation
            if rule.custom_validator:
                try:
                    custom_error = rule.custom_validator(value)
                    if custom_error:
                        errors[field] = [custom_error]
                except Exception as e:
                    errors[field] = ['خطأ في التحقق من القيمة']
        
        return errors

# Use in API endpoints
validator = InputValidator()

@app.route('/api/customers', methods=['POST'])
def create_customer():
    try:
        data = request.get_json()
        
        # Validate input
        errors = validator.validate(data)
        if errors:
            return create_response(
                success=False, 
                error="Validation failed",
                validation_errors=errors
            ), 400
        
        # Sanitize data
        sanitized_data = {
            'name': data['name'].strip(),
            'email': data['email'].lower().strip(),
            'phone': re.sub(r'\D', '', data['phone'])  # Remove non-digits
        }
        
        # Process request
        result = customer_service.create_customer(sanitized_data)
        return create_response(success=True, data=result)
        
    except Exception as e:
        logger.error(f"Customer creation failed: {e}")
        return create_response(
            success=False, 
            error="Internal server error"
        ), 500
```

### SQL Injection Prevention
Use parameterized queries to prevent SQL injection:

```python
# Safe database operations
class SecureDatabaseService:
    def __init__(self):
        self.db = get_db_connection()
    
    def get_customer_by_phone(self, phone: str):
        """Safe query with parameterized input"""
        with get_db_cursor() as cursor:
            cursor.execute("""
                SELECT * FROM customers 
                WHERE phone = ? 
                LIMIT 1
            """, (phone,))
            
            return cursor.fetchone()
    
    def search_customers(self, search_term: str, limit: int = 50):
        """Safe search with LIKE and parameterized input"""
        with get_db_cursor() as cursor:
            cursor.execute("""
                SELECT * FROM customers 
                WHERE name LIKE ? OR phone LIKE ?
                ORDER BY created_at DESC
                LIMIT ?
            """, (f'%{search_term}%', f'%{search_term}%', limit))
            
            return cursor.fetchall()
    
    def update_customer(self, customer_id: int, data: dict):
        """Safe update with parameterized input"""
        allowed_fields = ['name', 'email', 'phone']
        update_fields = []
        update_values = []
        
        for field, value in data.items():
            if field in allowed_fields:
                update_fields.append(f"{field} = ?")
                update_values.append(value)
        
        if not update_fields:
            raise ValueError("No valid fields to update")
        
        update_values.append(customer_id)
        
        with get_db_cursor() as cursor:
            cursor.execute(f"""
                UPDATE customers 
                SET {', '.join(update_fields)}
                WHERE id = ?
            """, update_values)
            
            return cursor.rowcount > 0
```

### Authentication & Authorization
Implement secure authentication and authorization:

```python
# Secure authentication system
import jwt
import hashlib
import secrets
from functools import wraps
from flask import request, g, current_app

class AuthService:
    def __init__(self):
        self.secret_key = current_app.config['SECRET_KEY']
        self.algorithm = 'HS256'
        self.token_expiry = 3600  # 1 hour
    
    def hash_password(self, password: str) -> str:
        """Hash password with salt"""
        salt = secrets.token_hex(16)
        hash_obj = hashlib.pbkdf2_hmac(
            'sha256', 
            password.encode('utf-8'), 
            salt.encode('utf-8'), 
            100000  # 100k iterations
        )
        return f"{salt}${hash_obj.hex()}"
    
    def verify_password(self, password: str, hashed: str) -> bool:
        """Verify password against hash"""
        try:
            salt, hash_hex = hashed.split('$')
            hash_obj = hashlib.pbkdf2_hmac(
                'sha256', 
                password.encode('utf-8'), 
                salt.encode('utf-8'), 
                100000
            )
            return hash_obj.hex() == hash_hex
        except Exception:
            return False
    
    def create_token(self, user_id: int, role: str) -> str:
        """Create JWT token"""
        payload = {
            'user_id': user_id,
            'role': role,
            'exp': datetime.utcnow() + timedelta(seconds=self.token_expiry)
        }
        return jwt.encode(payload, self.secret_key, algorithm=self.algorithm)
    
    def verify_token(self, token: str) -> Optional[dict]:
        """Verify JWT token"""
        try:
            payload = jwt.decode(token, self.secret_key, algorithms=[self.algorithm])
            return payload
        except jwt.ExpiredSignatureError:
            return None
        except jwt.InvalidTokenError:
            return None

# Authentication decorator
def require_auth(f):
    """Decorator to require authentication"""
    @wraps(f)
    def decorated_function(*args, **kwargs):
        token = request.headers.get('Authorization')
        
        if not token:
            return create_response(
                success=False, 
                error="Authentication required"
            ), 401
        
        # Remove 'Bearer ' prefix if present
        if token.startswith('Bearer '):
            token = token[7:]
        
        auth_service = AuthService()
        payload = auth_service.verify_token(token)
        
        if not payload:
            return create_response(
                success=False, 
                error="Invalid or expired token"
            ), 401
        
        # Set user context
        g.current_user = payload
        return f(*args, **kwargs)
    
    return decorated_function

# Role-based authorization
def require_role(required_role: str):
    """Decorator to require specific role"""
    def decorator(f):
        @wraps(f)
        def decorated_function(*args, **kwargs):
            if not hasattr(g, 'current_user'):
                return create_response(
                    success=False, 
                    error="Authentication required"
                ), 401
            
            if g.current_user.get('role') != required_role:
                return create_response(
                    success=False, 
                    error="Insufficient permissions"
                ), 403
            
            return f(*args, **kwargs)
        return decorated_function
    return decorator

# Use in protected endpoints
@app.route('/api/admin/users', methods=['GET'])
@require_auth
@require_role('admin')
def get_users():
    """Admin-only endpoint"""
    users = user_service.get_all_users()
    return create_response(success=True, data=users)
```


## Data Security

### Sensitive Data Handling
Handle sensitive data securely:

```python
# Sensitive data handling
import base64
from cryptography.fernet import Fernet

class DataEncryption:
    def __init__(self, key: str):
        self.cipher = Fernet(key)
    
    def encrypt(self, data: str) -> str:
        """Encrypt sensitive data"""
        return self.cipher.encrypt(data.encode()).decode()
    
    def decrypt(self, encrypted_data: str) -> str:
        """Decrypt sensitive data"""
        return self.cipher.decrypt(encrypted_data.encode()).decode()

# Use for sensitive fields
class CustomerService:
    def __init__(self):
        self.encryption = DataEncryption(config.secret_key)
    
    def create_customer(self, data: dict):
        """Create customer with encrypted sensitive data"""
        # Encrypt sensitive fields
        if 'ssn' in data:
            data['ssn_encrypted'] = self.encryption.encrypt(data['ssn'])
            del data['ssn']
        
        if 'credit_card' in data:
            data['credit_card_encrypted'] = self.encryption.encrypt(data['credit_card'])
            del data['credit_card']
        
        # Store in database
        return self._store_customer(data)
    
    def get_customer(self, customer_id: int):
        """Get customer with decrypted sensitive data"""
        customer = self._fetch_customer(customer_id)
        
        # Decrypt sensitive fields
        if customer.get('ssn_encrypted'):
            customer['ssn'] = self.encryption.decrypt(customer['ssn_encrypted'])
            del customer['ssn_encrypted']
        
        if customer.get('credit_card_encrypted'):
            customer['credit_card'] = self.encryption.decrypt(customer['credit_card_encrypted'])
            del customer['credit_card_encrypted']
        
        return customer
```

### Logging Security
Secure logging practices:

```python
# Secure logging configuration
import logging
from logging.handlers import RotatingFileHandler

class SecureLogger:
    def __init__(self, name: str, log_file: str):
        self.logger = logging.getLogger(name)
        self.logger.setLevel(logging.INFO)
        
        # File handler with rotation
        file_handler = RotatingFileHandler(
            log_file, 
            maxBytes=10*1024*1024,  # 10MB
            backupCount=5
        )
        
        # Secure formatter - exclude sensitive data
        formatter = logging.Formatter(
            '%(asctime)s - %(name)s - %(levelname)s - %(message)s'
        )
        file_handler.setFormatter(formatter)
        
        self.logger.addHandler(file_handler)
    
    def log_customer_action(self, action: str, customer_id: int, user_id: int):
        """Log customer actions securely"""
        self.logger.info(
            f"Customer action: {action} | "
            f"Customer ID: {customer_id} | "
            f"User ID: {user_id} | "
            f"IP: {request.remote_addr}"
        )
    
    def log_security_event(self, event: str, details: dict):
        """Log security events"""
        # Sanitize sensitive details
        sanitized_details = self._sanitize_details(details)
        
        self.logger.warning(
            f"Security event: {event} | "
            f"Details: {sanitized_details} | "
            f"IP: {request.remote_addr}"
        )
    
    def _sanitize_details(self, details: dict) -> dict:
        """Remove sensitive information from log details"""
        sensitive_keys = ['password', 'token', 'api_key', 'secret']
        sanitized = details.copy()
        
        for key in sensitive_keys:
            if key in sanitized:
                sanitized[key] = '***REDACTED***'
        
        return sanitized

# Use secure logger
security_logger = SecureLogger('security', 'logs/security.log')
```

## Security Headers

### HTTP Security Headers
Implement security headers:

```python
# Security headers middleware
from flask import make_response

@app.after_request
def add_security_headers(response):
    """Add security headers to all responses"""
    response.headers['X-Content-Type-Options'] = 'nosniff'
    response.headers['X-Frame-Options'] = 'DENY'
    response.headers['X-XSS-Protection'] = '1; mode=block'
    response.headers['Strict-Transport-Security'] = 'max-age=31536000; includeSubDomains'
    response.headers['Content-Security-Policy'] = "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    response.headers['Referrer-Policy'] = 'strict-origin-when-cross-origin'
    response.headers['Permissions-Policy'] = 'geolocation=(), microphone=(), camera=()'
    
    return response
```


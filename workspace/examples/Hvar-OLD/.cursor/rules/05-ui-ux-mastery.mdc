### Optimized CSS Selectors
Use efficient CSS selectors for performance:

```css
/* Performance-optimized selectors */
.component {
  /* Use CSS custom properties for consistent values */
  color: var(--brand-red-600);
  background-color: var(--bg-primary);
  padding: var(--spacing-4);
  font-size: var(--text-base);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-md);
}

/* Avoid deep nesting - keep selectors shallow */
.card {
  background: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-lg);
  padding: var(--spacing-6);
  transition: all 0.2s ease-in-out;
}

.card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

/* Use attribute selectors for dynamic states */
[data-state="active"] {
  background-color: var(--brand-red-100);
  border-color: var(--brand-red-300);
}

[data-state="inactive"] {
  background-color: var(--bg-secondary);
  border-color: var(--border-color);
}
```

## Component Enhancement Patterns

### Button Component Enhancement
Enhance the existing Button component with modern CSS:

```jsx
// Enhanced Button with CSS custom properties
const Button = ({ 
  variant = 'primary', 
  size = 'md', 
  className = '', 
  ...props 
}) => {
  const getVariantClasses = () => {
    switch (variant) {
      case 'primary':
        return 'bg-[var(--brand-red-600)] hover:bg-[var(--brand-red-700)] focus:ring-[var(--brand-red-500)]';
      case 'secondary':
        return 'bg-[var(--brand-blue-500)] hover:bg-[var(--brand-blue-600)] focus:ring-[var(--brand-blue-400)]';
      case 'outline':
        return 'bg-transparent border border-[var(--border-color)] hover:bg-[var(--bg-secondary)]';
      case 'ghost':
        return 'bg-transparent hover:bg-[var(--bg-secondary)]';
      default:
        return 'bg-[var(--brand-red-600)] hover:bg-[var(--brand-red-700)]';
    }
  };
  
  const getSizeClasses = () => {
    switch (size) {
      case 'xs': return 'px-[var(--spacing-2)] py-[var(--spacing-1)] text-[var(--text-xs)]';
      case 'sm': return 'px-[var(--spacing-3)] py-[var(--spacing-1.5)] text-[var(--text-sm)]';
      case 'md': return 'px-[var(--spacing-4)] py-[var(--spacing-2)] text-[var(--text-sm)]';
      case 'lg': return 'px-[var(--spacing-5)] py-[var(--spacing-2.5)] text-[var(--text-base)]';
      case 'xl': return 'px-[var(--spacing-6)] py-[var(--spacing-3)] text-[var(--text-base)]';
      default: return 'px-[var(--spacing-4)] py-[var(--spacing-2)] text-[var(--text-sm)]';
    }
  };
  
  return (
    <button
      className={cn(
        'inline-flex items-center justify-center font-medium rounded-md transition-all duration-200',
        'focus:outline-none focus:ring-2 focus:ring-offset-2',
        'disabled:opacity-50 disabled:pointer-events-none',
        'text-white border',
        getVariantClasses(),
        getSizeClasses(),
        className
      )}
      {...props}
    />
  );
};
```

### Card Component Enhancement
Enhance with modern CSS techniques:

```jsx
const Card = ({ 
  variant = 'default', 
  className = '', 
  children, 
  ...props 
}) => {
  const getVariantClasses = () => {
    switch (variant) {
      case 'default':
        return 'bg-[var(--bg-primary)] border border-[var(--border-color)] shadow-[var(--shadow-sm)]';
      case 'elevated':
        return 'bg-[var(--bg-primary)] border border-[var(--border-color)] shadow-[var(--shadow-md)]';
      case 'flat':
        return 'bg-[var(--bg-primary)] border border-[var(--border-color)]';
      case 'transparent':
        return 'bg-transparent';
      default:
        return 'bg-[var(--bg-primary)] border border-[var(--border-color)] shadow-[var(--shadow-sm)]';
    }
  };
  
  return (
    <div
      className={cn(
        'rounded-[var(--radius-lg)] overflow-hidden transition-all duration-300',
        'hover:shadow-[var(--shadow-md)] hover:scale-[1.01]',
        getVariantClasses(),
        className
      )}
      {...props}
    >
      {children}
    </div>
  );
};
```


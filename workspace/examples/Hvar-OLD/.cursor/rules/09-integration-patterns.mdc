# Integration Patterns & Feature Development

## New Feature Integration

### Frontend Feature Integration
Follow established patterns when adding new features:

```jsx
// 1. Create page component in appropriate directory
// src/pages/new-feature/NewFeaturePage.jsx
import React, { useState, useEffect } from 'react';
import { Card, Button, Loading } from '../../components/ui';
import { useAuth } from '../../context/AuthContext';
import api from '../../services/api';

const NewFeaturePage = () => {
  const { user } = useAuth();
  const [loading, setLoading] = useState(true);
  const [data, setData] = useState(null);
  const [error, setError] = useState(null);
  
  useEffect(() => {
    const fetchData = async () => {
      setLoading(true);
      setError(null);
      
      try {
        const result = await api.newFeature.getData();
        setData(result);
      } catch (err) {
        console.error('Error fetching data:', err);
        setError('Failed to load data');
      } finally {
        setLoading(false);
      }
    };
    
    fetchData();
  }, []);
  
  if (loading) return <Loading text="جاري التحميل..." />;
  if (error) return <div className="text-red-500">{error}</div>;
  
  return (
    <div className="space-y-6">
      <div className="flex justify-between items-center">
        <h1 className="text-2xl font-bold">الميزة الجديدة</h1>
        <Button variant="primary">إضافة جديد</Button>
      </div>
      
      <Card>
        {/* Feature content */}
      </Card>
    </div>
  );
};

export default NewFeaturePage;


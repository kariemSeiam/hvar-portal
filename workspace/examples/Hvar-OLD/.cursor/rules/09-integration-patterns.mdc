## Context Integration

### React Context Integration
Integrate new features with existing context system:

```jsx
// src/context/NewFeatureContext.jsx
import React, { createContext, useContext, useState, useEffect } from 'react';
import api from '../services/api';

const NewFeatureContext = createContext({
  data: null,
  loading: false,
  error: null,
  refreshData: () => {},
  createItem: () => {},
  updateItem: () => {},
  deleteItem: () => {},
});

export const useNewFeature = () => {
  const context = useContext(NewFeatureContext);
  if (!context) {
    throw new Error('useNewFeature must be used within a NewFeatureProvider');
  }
  return context;
};

const NewFeatureProvider = ({ children }) => {
  const [data, setData] = useState(null);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState(null);
  
  const fetchData = async () => {
    setLoading(true);
    setError(null);
    
    try {
      const result = await api.newFeature.getData();
      setData(result);
    } catch (err) {
      console.error('Error fetching new feature data:', err);
      setError('Failed to load data');
    } finally {
      setLoading(false);
    }
  };
  
  const createItem = async (itemData) => {
    try {
      const result = await api.newFeature.createItem(itemData);
      await fetchData(); // Refresh data
      return result;
    } catch (err) {
      console.error('Error creating item:', err);
      throw err;
    }
  };
  
  const updateItem = async (id, itemData) => {
    try {
      const result = await api.newFeature.updateItem(id, itemData);
      await fetchData(); // Refresh data
      return result;
    } catch (err) {
      console.error('Error updating item:', err);
      throw err;
    }
  };
  
  const deleteItem = async (id) => {
    try {
      await api.newFeature.deleteItem(id);
      await fetchData(); // Refresh data
    } catch (err) {
      console.error('Error deleting item:', err);
      throw err;
    }
  };
  
  useEffect(() => {
    fetchData();
  }, []);
  
  const contextValue = {
    data,
    loading,
    error,
    refreshData: fetchData,
    createItem,
    updateItem,
    deleteItem,
  };
  
  return (
    <NewFeatureContext.Provider value={contextValue}>
      {children}
    </NewFeatureContext.Provider>
  );
};

export default NewFeatureProvider;

// Add to App.jsx
import NewFeatureProvider from './context/NewFeatureContext';

function App() {
  return (
    <ThemeProvider defaultDirection="rtl" defaultTheme="light">
      <LoadingProvider>
        <OrdersProvider>
          <NewFeatureProvider>  {/* Add new context provider */}
            <AuthProvider>
              <Router>
                {/* ... existing routes */}
              </Router>
            </AuthProvider>
          </NewFeatureProvider>
        </OrdersProvider>
      </LoadingProvider>
    </ThemeProvider>
  );
}
```


### Data Model Integration
Create data models following established patterns:

```python
# Hvar-Bosta-v2/app/models/new_feature.py
class NewFeatureModel:
    def __init__(self, **kwargs):
        """Initialize model with data"""
        for key, value in kwargs.items():
            setattr(self, key, value)
    
    @classmethod
    def create(cls, data):
        """Create new record"""
        with get_db_cursor() as cursor:
            cursor.execute("""
                INSERT INTO new_feature_table (name, description, status)
                VALUES (?, ?, ?)
            """, (data['name'], data.get('description'), data.get('status', 'active')))
            
            return cls.get_by_id(cursor.lastrowid)
    
    @classmethod
    def get_by_id(cls, item_id):
        """Get record by ID"""
        with get_db_cursor() as cursor:
            cursor.execute("""
                SELECT * FROM new_feature_table WHERE id = ?
            """, (item_id,))
            
            row = cursor.fetchone()
            if row:
                return cls(**dict(zip([col[0] for col in cursor.description], row)))
            return None
    
    @classmethod
    def get_all(cls, filters=None):
        """Get all records with optional filters"""
        query = "SELECT * FROM new_feature_table"
        params = []
        
        if filters:
            conditions = []
            for key, value in filters.items():
                if key in ['status', 'name']:
                    conditions.append(f"{key} = ?")
                    params.append(value)
            
            if conditions:
                query += " WHERE " + " AND ".join(conditions)
        
        query += " ORDER BY created_at DESC"
        
        with get_db_cursor() as cursor:
            cursor.execute(query, params)
            rows = cursor.fetchall()
            
            return [cls(**dict(zip([col[0] for col in cursor.description], row))) 
                   for row in rows]

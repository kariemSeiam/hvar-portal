### Database Schema Integration
Add new tables following established patterns:

```python
# Hvar-Bosta-v2/app/models/new_feature.py
"""
New Feature Database Model
Handles database operations for new feature
"""
from app.models.database import get_db_cursor

def init_new_feature_table():
    """Initialize new feature table"""
    with get_db_cursor() as cursor:
        cursor.execute("""
            CREATE TABLE IF NOT EXISTS new_feature_table (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                name TEXT NOT NULL,
                description TEXT,
                status TEXT DEFAULT 'active',
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        """)
        
        # Create indexes for performance
        cursor.execute("""
            CREATE INDEX IF NOT EXISTS idx_new_feature_status 
            ON new_feature_table(status)
        """)
        
        cursor.execute("""
            CREATE INDEX IF NOT EXISTS idx_new_feature_created 
            ON new_feature_table(created_at)
        """)


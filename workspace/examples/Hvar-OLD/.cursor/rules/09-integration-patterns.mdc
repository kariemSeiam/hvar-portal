### Backend Feature Integration
Follow established patterns for backend features:

```python
# 1. Create route blueprint
# Hvar-Bosta-v2/app/routes/new_feature.py
from flask import Blueprint, request
from app.services.new_feature_service import NewFeatureService
from app.utils.api_response import create_response

bp = Blueprint('new_feature', __name__, url_prefix='/api/new-feature')

@bp.route('/', methods=['GET'])
def get_data():
    """Get new feature data"""
    try:
        service = NewFeatureService()
        result = service.get_data()
        return create_response(success=True, data=result)
    except Exception as e:
        return create_response(success=False, error=str(e))

@bp.route('/', methods=['POST'])
def create_item():
    """Create new feature item"""
    try:
        data = request.get_json()
        service = NewFeatureService()
        result = service.create_item(data)
        return create_response(success=True, data=result)
    except Exception as e:
        return create_response(success=False, error=str(e))

# 2. Create service class
# Hvar-Bosta-v2/app/services/new_feature_service.py
"""
New Feature Service
Handles business logic for new feature functionality
"""
from app.models.database import get_db_connection
from app.utils.api_response import create_response

class NewFeatureService:
    def __init__(self):
        self.db = get_db_connection()
    
    def get_data(self):
        """Get new feature data"""
        with get_db_cursor() as cursor:
            cursor.execute("""
                SELECT * FROM new_feature_table
                ORDER BY created_at DESC
            """)
            rows = cursor.fetchall()
            return [dict(zip([col[0] for col in cursor.description], row)) for row in rows]
    
    def create_item(self, data):
        """Create new feature item"""
        with get_db_cursor() as cursor:
            cursor.execute("""
                INSERT INTO new_feature_table (name, description, created_at)
                VALUES (?, ?, CURRENT_TIMESTAMP)
            """, (data['name'], data['description']))
            
            return {'id': cursor.lastrowid, 'name': data['name']}

# 3. Register blueprint in app factory
# Hvar-Bosta-v2/app/__init__.py
from app.routes.new_feature import bp as new_feature_bp

def create_app():
    app = Flask(__name__)
    # ... existing configuration
    
    # Register blueprints
    app.register_blueprint(new_feature_bp)
    
    return app

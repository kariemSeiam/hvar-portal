# React Patterns & Best Practices

## Component Architecture

### Component Structure Pattern
Follow the established pattern in `src/components/ui/Button.jsx`:

```jsx
import React from 'react';
import { cn } from '../../utils/tailwind';

/**
 * Component description using JSDoc format
 * @param {Object} props - Component props
 * @param {string} [props.variant='default'] - Variant description
 * @param {string} [props.className] - Additional CSS classes
 */
const ComponentName = ({ 
  variant = 'default', 
  size = 'md',
  className = '', 
  children,
  ...props 
}) => {
  // Component logic here
  
  return (
    <div 
      className={cn(
        'base-classes',
        variant === 'default' && 'default-variant-classes',
        variant === 'alternative' && 'alternative-variant-classes',
        className
      )}
      {...props}
    >
      {children}
    </div>
  );
};

export default ComponentName;
```

### Component Organization
- **UI Components**: Place in `src/components/ui/` for cross-feature use
- **Layout Components**: Place in `src/components/layout/` for structural components
- **Feature Components**: Place in feature-specific directories (e.g., `src/pages/orders/components/`)
- **Page Components**: Place in `src/pages/` with appropriate subdirectory structure

## State Management Patterns

### Context Usage Pattern
Follow the established pattern in `src/context/AuthContext.jsx`:

```jsx
import React, { createContext, useContext, useState, useEffect } from 'react';

const ContextName = createContext({
  // Default context values
  value: null,
  setValue: () => {},
});

export const useContextName = () => {
  const context = useContext(ContextName);
  if (!context) {
    throw new Error('useContextName must be used within a ContextNameProvider');
  }
  return context;
};

const ContextNameProvider = ({ children }) => {
  const [value, setValue] = useState(null);
  
  // Context logic here
  
  const contextValue = {
    value,
    setValue,
  };
  
  return (
    <ContextName.Provider value={contextValue}>
      {children}
    </ContextName.Provider>
  );
};

export default ContextNameProvider;
```

### Local State Management
Follow the pattern in `src/pages/DashboardPage.jsx`:

```jsx
const ComponentName = () => {
  const [loading, setLoading] = useState(true);
  const [data, setData] = useState(null);
  const [error, setError] = useState(null);
  
  useEffect(() => {
    const fetchData = async () => {
      setLoading(true);
      setError(null);
      
      try {
        const result = await api.getData();
        setData(result);
      } catch (err) {
        console.error('Error fetching data:', err);
        setError('Failed to load data');
      } finally {
        setLoading(false);
      }
    };
    
    fetchData();
  }, []);
  
  // Component render logic
};
```

## Custom Hooks Pattern

### Hook Structure
Follow the pattern in `src/hooks/useApi.js`:

```jsx
import { useState, useEffect, useCallback } from 'react';

/**
 * Custom hook description
 * @param {string} endpoint - API endpoint
 * @param {Object} options - Hook options
 * @returns {Object} Hook return values
 */
export const useCustomHook = (endpoint, options = {}) => {
  const [data, setData] = useState(null);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState(null);
  
  const fetchData = useCallback(async () => {
    setLoading(true);
    setError(null);
    
    try {
      const result = await api.get(endpoint);
      setData(result);
    } catch (err) {
      setError(err.message);
    } finally {
      setLoading(false);
    }
  }, [endpoint]);
  
  useEffect(() => {
    if (options.autoFetch !== false) {
      fetchData();
    }
  }, [fetchData, options.autoFetch]);
  
  return {
    data,
    loading,
    error,
    refetch: fetchData,
  };
};
```

## Routing & Navigation

### Route Definition Pattern
Follow the pattern in `src/App.jsx`:

```jsx
// Lazy load page components
const PageComponent = React.lazy(() => import('./pages/PageComponent'));

// Route definition
<Route 
  path="/route-path" 
  element={
    <ProtectedRoute>
      <PageComponent />
    </ProtectedRoute>
  } 
/>
```

### Protected Routes
Follow the established pattern:

```jsx
const ProtectedRoute = ({ children }) => {
  const isAuthenticated = localStorage.getItem('token');
  
  if (!isAuthenticated) {
    return <Navigate to="/login" replace />;
  }
  
  return children;
};
```

## Form Handling Patterns

### Form State Management
Follow the established pattern:

```jsx
const FormComponent = () => {
  const [formData, setFormData] = useState({
    field1: '',
    field2: '',
  });
  const [errors, setErrors] = useState({});
  const [loading, setLoading] = useState(false);
  
  const handleChange = (e) => {
    const { name, value } = e.target;
    setFormData(prev => ({
      ...prev,
      [name]: value
    }));
    
    // Clear error when user starts typing
    if (errors[name]) {
      setErrors(prev => ({
        ...prev,
        [name]: ''
      }));
    }
  };
  
  const handleSubmit = async (e) => {
    e.preventDefault();
    setLoading(true);
    
    try {
      await api.submitForm(formData);
      // Handle success
    } catch (error) {
      setErrors(error.validationErrors || {});
    } finally {
      setLoading(false);
    }
  };
  
  return (
    <form onSubmit={handleSubmit}>
      {/* Form fields */}
    </form>
  );
};
```

## Performance Optimization

### React.memo Usage
Use React.memo for components that receive stable props:

```jsx
const ExpensiveComponent = React.memo(({ data, onAction }) => {
  // Component logic
  return <div>{/* Component JSX */}</div>;
});
```

### useMemo & useCallback Usage
Use when beneficial for performance:

```jsx
const ComponentName = ({ items, onItemClick }) => {
  const sortedItems = useMemo(() => {
    return items.sort((a, b) => a.name.localeCompare(b.name));
  }, [items]);
  
  const handleItemClick = useCallback((item) => {
    onItemClick(item);
  }, [onItemClick]);
  
  return (
    <div>
      {sortedItems.map(item => (
        <Item 
          key={item.id} 
          item={item} 
          onClick={handleItemClick}
        />
      ))}
    </div>
  );
};
```

## Error Boundaries

### Error Boundary Implementation
```jsx
class ErrorBoundary extends React.Component {
  constructor(props) {
    super(props);
    this.state = { hasError: false, error: null };
  }
  
  static getDerivedStateFromError(error) {
    return { hasError: true, error };
  }
  
  componentDidCatch(error, errorInfo) {
    console.error('Error caught by boundary:', error, errorInfo);
  }
  
  render() {
    if (this.state.hasError) {
      return (
        <div className="error-boundary">
          <h2>Something went wrong</h2>
          <button onClick={() => window.location.reload()}>
            Reload Page
          </button>
        </div>
      );
    }
    
    return this.props.children;
  }
}
```

## Accessibility Patterns

### ARIA Attributes
```jsx
const AccessibleComponent = ({ label, description }) => {
  return (
    <div
      role="region"
      aria-label={label}
      aria-describedby="description"
    >
      <h2>{label}</h2>
      <p id="description">{description}</p>
    </div>
  );
};
```

### Keyboard Navigation
```jsx
const KeyboardComponent = ({ onAction }) => {
  const handleKeyDown = (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      onAction();
    }
  };
  
  return (
    <div
      tabIndex={0}
      role="button"
      onKeyDown={handleKeyDown}
      onClick={onAction}
    >
      Clickable content
    </div>
  );
};
```

## Testing Patterns

### Component Testing
```jsx
// Component test structure
import { render, screen, fireEvent } from '@testing-library/react';
import ComponentName from './ComponentName';

describe('ComponentName', () => {
  it('renders correctly', () => {
    render(<ComponentName />);
    expect(screen.getByText('Expected Text')).toBeInTheDocument();
  });
  
  it('handles user interactions', () => {
    const mockHandler = jest.fn();
    render(<ComponentName onAction={mockHandler} />);
    
    fireEvent.click(screen.getByRole('button'));
    expect(mockHandler).toHaveBeenCalled();
  });
});
```

## Code Splitting

### Lazy Loading Pattern
Follow the established pattern in `src/App.jsx`:

```jsx
// Lazy load page components
const PageComponent = React.lazy(() => import('./pages/PageComponent'));

// Use with Suspense
<React.Suspense fallback={<LoadingFallback />}>
  <PageComponent />
</React.Suspense>
```

### Dynamic Imports
```jsx
const loadComponent = async (componentName) => {
  const module = await import(`./components/${componentName}`);
  return module.default;
};
```

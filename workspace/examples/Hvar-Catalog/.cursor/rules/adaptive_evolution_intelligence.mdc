## INTELLIGENT ADAPTATION RULES

### 1. Pattern Recognition
```jsx
// Rule automatically recognizes and applies new patterns
// When a new pattern emerges in 3+ components, it becomes standard

// Example: New error boundary pattern
export const AdaptiveErrorBoundary = ({ children, fallback }) => {
  const [hasError, setHasError] = useState(false);
  const [error, setError] = useState(null);
  
  // Rule learns this pattern and applies it to error handling
  if (hasError) {
    return fallback ? fallback(error) : (
      <div className="text-center py-8">
        <h2 className="text-lg font-heading text-red-600 mb-2">
          حدث خطأ غير متوقع
        </h2>
        <button 
          onClick={() => setHasError(false)}
          className="btn-modern bg-primary-500"
        >
          إعادة المحاولة
        </button>
      </div>
    );
  }
  
  return children;
};
```

### 2. Quality Standard Preservation
```jsx
// Rule maintains established quality standards during evolution
// New patterns must meet or exceed existing quality benchmarks

// Example: New component must follow established patterns
export const NewEvolvedComponent = ({ data, onAction }) => {
  const { darkMode, dir } = useDesignSystem();
  
  // ✅ Maintains established patterns
  const handleAction = useCallback(() => {

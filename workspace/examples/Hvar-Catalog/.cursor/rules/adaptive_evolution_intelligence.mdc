### 3. Performance Pattern Evolution
```jsx
// ✅ ADAPTIVE: Rule learns new performance optimization techniques
// When new optimization patterns emerge, they become standard practice

// Example: New lazy loading pattern
export const AdaptiveLazyLoader = ({ children, threshold = 0.1 }) => {
  const { darkMode, dir } = useDesignSystem();
  const [isVisible, setIsVisible] = useState(false);
  const ref = useRef();
  
  // Rule learns this intersection observer pattern
  useEffect(() => {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          setIsVisible(true);
          observer.disconnect();
        }
      },
      { threshold }
    );
    
    if (ref.current) {
      observer.observe(ref.current);
    }
    
    return () => observer.disconnect();
  }, [threshold]);
  
  return (
    <div ref={ref} dir={dir}>
      {isVisible ? children : <LoadingSpinner />}
    </div>
  );
};
```


};
```

### 3. Backward Compatibility
```jsx
// Rule ensures new patterns don't break existing functionality
// Evolution must maintain compatibility with established interfaces

// Example: Evolving existing component
export const EvolvedProductCard = ({ product, onQuickView, onContact }) => {
  const { darkMode, dir } = useDesignSystem();
  
  // ✅ Maintains existing interface
  const handleQuickView = useCallback(() => {
    onQuickView?.(product);
  }, [product, onQuickView]);
  
  // ✅ Adds new features while preserving existing functionality
  const [isFavorite, setIsFavorite] = useState(false);
  
  return (
    <article className="bg-white dark:bg-gray-800 rounded-lg shadow-md" dir={dir}>
      {/* Existing functionality preserved */}
      {/* New features added */}
      <button 
        onClick={() => setIsFavorite(!isFavorite)}
        className="absolute top-2 left-2 rtl:right-2 p-2 rounded-full bg-white/80"
      >
        <HeartIcon className={`w-5 h-5 ${isFavorite ? 'text-red-500 fill-current' : 'text-gray-600'}`} />
      </button>
    </article>
  );
};
```


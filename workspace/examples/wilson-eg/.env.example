# Wilson Egypt — backend environment
# Copy to .env at the repository root (same folder as README.md). Do not commit .env.

# Required when FLASK_ENV=production (or ENV=production). Use a long random string.
SECRET_KEY=your-secret-key-change-in-production

# Optional. Default: SQLite file at repo root (see backend/app.py BASE_DIR).
# SQLALCHEMY_DATABASE_URI=sqlite:///F:/path/to/wilson.db

# development | production — production refuses to boot with default SECRET_KEY
# FLASK_ENV=development

# Public base URL for uploaded slide/image URLs (trailing slash optional; normalized at runtime).
# Dev default: http://127.0.0.1:5004/uploads/
# UPLOAD_URL_PREFIX=https://api.yourdomain.com/uploads/

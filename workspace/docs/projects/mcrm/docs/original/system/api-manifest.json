      "id": "call_center_leader_request_info",
      "method": "POST",
      "path": "/api/call-center/orders/{order_id}/request-info",
      "path_params": [{ "name": "order_id", "type": "integer" }],
      "query_params": [],
      "body": { "message": { "type": "string" } },
      "description": "Leader requests more info; status → new (order returns to agent queue; message in snapshot).",
      "responses": { "200": "order_status=new", "404": "not found" },
      "errors": ["ORDER_NOT_FOUND", "ORDER_ALREADY_CONVERTED"]

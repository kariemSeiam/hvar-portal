      "method": "GET",
      "path": "/api/call-center/orders/{order_id}",
      "path_params": [{ "name": "order_id", "type": "integer" }],
      "query_params": [],
      "body": null,
      "description": "Get single order by id. Used by call session modal (FAB). Returns order + calls + ticket.",
      "responses": { "200": "order, calls, ticket", "404": "not found" },
      "response_schema": {
        "200": {
          "order": "object (id, erp_order_id, customer_phone, customer_name, delivery_address, governorate, city, order_description, cod_amount, status, source, service_type, attempt_count, next_action_at, scheduled_callback_at, last_attempt_at, cancellation_reason, bosta_tracking, bosta_order_id, customer_id, converted_to_ticket_id, created_at, updated_at; dates ISO, cod_amount float)",
          "calls": "array of call objects (id, order_id, customer_phone, status, notes, created_at, attempt_number, agent_id; dates ISO)",
          "ticket": "object | null (if converted)"
        }
      },
      "errors": ["ORDER_NOT_FOUND"]

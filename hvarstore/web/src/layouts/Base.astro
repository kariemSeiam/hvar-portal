---
import "../styles/global.css"
import "@fontsource/cairo/400.css"
import "@fontsource/cairo/600.css"
import "@fontsource/cairo/700.css"
import "@fontsource/cairo/900.css"
import "@fontsource/inter/400.css"
import "@fontsource/inter/500.css"
import "@fontsource/inter/600.css"
import "@fontsource/jetbrains-mono/500.css"
import Navbar from "../components/Navbar.astro"
import Footer from "../components/Footer.astro"
import CartFab from "../components/cart/CartFab"
import CartDrawer from "../components/cart/CartDrawer"


interface Props {
  title?: string
  description?: string
  image?: string
  noFooter?: boolean
  /** JSON-LD structured data snippets (injected before </head>) */
  jsonld?: string[]
}

const {
  title = 'هفار — أجهزة منزلية بضمان حقيقي وشحن مجاني',
  description = 'تسوق أجهزة المطبخ من هفار: خلاطات، قلايات هوائية، مكاوي، عجانات. ضمان سنتين، شحن مجاني لجميع المحافظات، افحص قبل الدفع.',
  image,
  noFooter = false,
  jsonld = [],
} = Astro.props

const defaultOgImage = 'https://hvarstore.com/og-image.png'
const ogImage = image ?? defaultOgImage

const canonicalURL = new URL(Astro.url.pathname, Astro.site)

/* ── Global JSON-LD: Organization + WebSite ─────────────────────────── */
function ld(obj: Record<string, unknown>) {
  return JSON.stringify({ "@context": "https://schema.org", ...obj })
}

const orgJsonld = ld({
  ['@type']: 'Organization',
  name: 'هفار',
  alternateName: 'HVAR',
  url: 'https://hvarstore.com',
  logo: defaultOgImage,
  description: 'أجهزة منزلية موثوقة لكل مطبخ مصري. ضمان سنتين، شحن مجاني، افحص قبل الدفع.',
  telephone: '17566',
  contactPoint: {
    ['@type']: 'ContactPoint',
    telephone: '17566',
    contactType: 'customer service',
    areaServed: 'EG',
    availableLanguage: 'ar',
  },
  sameAs: [
    'https://www.facebook.com/hvar22',
    'https://www.instagram.com/hvar222',
    'https://www.tiktok.com/@hvarstore1',
  ],
})

const websiteJsonld = ld({
  ['@type']: 'WebSite',
  name: 'هفار',
  alternateName: 'HVAR',
  url: 'https://hvarstore.com',
  inLanguage: 'ar',
  potentialAction: {
    ['@type']: 'SearchAction',
    target: 'https://hvarstore.com/products?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
})
---

<!doctype html>
<html dir="rtl" lang="ar">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#d43533" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="author" content="هفار — HVAR" />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OG -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ar_EG" />
    <meta property="og:site_name" content="هفار" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={orgJsonld}></script>
    <script type="application/ld+json" set:html={websiteJsonld}></script>
    {jsonld.map((snippet) => (
      <script type="application/ld+json" set:html={snippet}></script>
    ))}

    <link rel="preconnect" href="https://hvarstore.com" crossorigin="anonymous" />

    <!-- Dark mode: run before render to prevent flash -->
    <script is:inline>
      ;(function () {
        var stored = localStorage.getItem('hvar-theme')
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark')
        }
      })()
    </script>

    <slot name="head" />
  </head>

  <body class="min-h-screen antialiased" style="background-color:var(--c-bg);color:var(--c-ink)">
    <Navbar />

    <main>
      <slot />
    </main>

    <CartFab client:load />
    <CartDrawer client:load />

    {!noFooter && <Footer />}

    <!-- Wilson P7: Scroll reveal observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('visible')
              observer.unobserve(e.target)
            }
          })
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' },
      )
      document
        .querySelectorAll('.reveal-section, .reveal-child, .reveal-scale')
        .forEach((el) => observer.observe(el))
    </script>
  </body>
</html>

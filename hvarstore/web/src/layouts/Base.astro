---
import "../styles/global.css"
import "@fontsource/cairo/400.css"
import "@fontsource/cairo/600.css"
import "@fontsource/cairo/700.css"
import "@fontsource/cairo/900.css"
import "@fontsource/inter/400.css"
import "@fontsource/inter/500.css"
import "@fontsource/inter/600.css"
import "@fontsource/jetbrains-mono/500.css"
import Navbar from "../components/Navbar.astro"
import Footer from "../components/Footer.astro"
import BottomNav from "../components/BottomNav.astro"
import CartFab from "../components/cart/CartFab"
import CartDrawer from "../components/cart/CartDrawer"


interface Props {
  title?: string
  description?: string
  image?: string
  noFooter?: boolean
  /** PDP passes this — StickyMobileCta owns the mobile bottom edge there. */
  noBottomNav?: boolean
  /** JSON-LD structured data snippets (injected before </head>) */
  jsonld?: string[]
}

const {
  title = 'هفار | أجهزة مطبخ مصرية، شحن مجاني لكل مصر',
  description = 'تسوق أجهزة المطبخ من هفار: خلاطات، قلايات هوائية، مكاوي، عجانات. صناعة مصرية، شحن مجاني لجميع المحافظات، افحص قبل الدفع.',
  image,
  noFooter = false,
  noBottomNav = false,
  jsonld = [],
} = Astro.props

const defaultOgImage = 'https://hvarstore.com/og-image.png'
const ogImage = image ?? defaultOgImage

const canonicalURL = new URL(Astro.url.pathname, Astro.site)

/* ── Global JSON-LD: Organization + WebSite ─────────────────────────── */
function ld(obj: Record<string, unknown>) {
  return JSON.stringify({ "@context": "https://schema.org", ...obj })
}

const orgJsonld = ld({
  ['@type']: 'Organization',
  name: 'هفار',
  alternateName: 'HVAR',
  url: 'https://hvarstore.com',
  logo: defaultOgImage,
  description: 'أجهزة منزلية لكل مطبخ مصري. صناعة مصرية، شحن مجاني، افحص قبل الدفع.',
  telephone: '17566',
  contactPoint: {
    ['@type']: 'ContactPoint',
    telephone: '17566',
    contactType: 'customer service',
    areaServed: 'EG',
    availableLanguage: 'ar',
  },
  sameAs: [
    'https://www.facebook.com/hvar22',
    'https://www.instagram.com/hvar222',
    'https://www.tiktok.com/@hvarstore1',
  ],
})

const websiteJsonld = ld({
  ['@type']: 'WebSite',
  name: 'هفار',
  alternateName: 'HVAR',
  url: 'https://hvarstore.com',
  inLanguage: 'ar',
  potentialAction: {
    ['@type']: 'SearchAction',
    target: 'https://hvarstore.com/products?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
})
---

<!doctype html>
<html dir="rtl" lang="ar">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#d43533" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="author" content="هفار — HVAR" />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OG -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ar_EG" />
    <meta property="og:site_name" content="هفار" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={orgJsonld}></script>
    <script type="application/ld+json" set:html={websiteJsonld}></script>
    {jsonld.map((snippet) => (
      <script type="application/ld+json" set:html={snippet}></script>
    ))}

    <link rel="preconnect" href="https://hvarstore.com" crossorigin="anonymous" />

    <!-- Dark mode: run before render to prevent flash -->
    <script is:inline>
      ;(function () {
        var stored = localStorage.getItem('hvar-theme')
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
        if (stored === 'dark' || !stored) {
          document.documentElement.classList.add('dark')
        }
      })()
    </script>

    <slot name="head" />
  </head>

  <body class:list={['min-h-screen antialiased', !noBottomNav && 'has-bnav']} style="background-color:var(--c-bg);color:var(--c-ink)">
    <Navbar />

    <main>
      <slot />
    </main>

    <CartFab client:idle />
    <CartDrawer client:idle />
    {!noBottomNav && <BottomNav />}

    {!noBottomNav && (
      <div id="cart-toast" role="status" aria-live="polite" aria-atomic="true">
        <span class="ct-icon" aria-hidden="true">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </span>
        <span id="ct-text" class="ct-text font-cairo"></span>
      </div>
    )}

    {!noFooter && <Footer />}

    <style is:global>
      /* Reserve the thumb-zone: keep page content clear of the bottom nav */
      @media (max-width: 767px) {
        body.has-bnav {
          padding-bottom: calc(3.5rem + env(safe-area-inset-bottom, 0px));
        }
        /* Cart already reachable via bottom nav — hide the floating pill */
        body.has-bnav .cart-fab-pill {
          display: none;
        }
      }

      /* Cart toast — mobile only, floats above bottom nav */
      #cart-toast {
        position: fixed;
        inset-inline: 0;
        bottom: calc(3.5rem + env(safe-area-inset-bottom, 0px) + 0.625rem);
        margin-inline: auto;
        width: fit-content;
        max-width: calc(100vw - 2.5rem);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1rem 0.6rem 0.75rem;
        border-radius: 9999px;
        background: var(--c-ink);
        color: var(--c-bg);
        font-size: 0.8125rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        z-index: 58;
        pointer-events: none;
        transform: translateY(calc(100% + 1rem));
        opacity: 0;
        transition:
          transform 0.38s cubic-bezier(0.22, 1, 0.36, 1),
          opacity 0.22s ease;
      }
      #cart-toast.toast--show {
        transform: translateY(0);
        opacity: 1;
      }
      .ct-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: var(--c-brand);
        color: #fff;
        flex-shrink: 0;
      }
      .ct-text {
        font-weight: 600;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      @media (min-width: 768px) {
        #cart-toast { display: none; }
      }
    </style>

    <!-- Cart toast — fires on hvar:cartadd from any add-to-cart button -->
    <script>
      {
        let toastTimer: ReturnType<typeof setTimeout>
        const toast = document.getElementById('cart-toast')
        const textEl = document.getElementById('ct-text')
        if (toast && textEl) {
          document.addEventListener('hvar:cartadd', (e) => {
            const name: string = (e as CustomEvent).detail?.name ?? ''
            textEl.textContent = name.length > 22 ? name.slice(0, 22) + '…' : name
            toast.classList.add('toast--show')
            clearTimeout(toastTimer)
            toastTimer = setTimeout(() => toast.classList.remove('toast--show'), 2400)
          })
        }
      }
    </script>

    <!-- Wilson P7: Scroll reveal observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('visible')
              observer.unobserve(e.target)
            }
          })
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' },
      )
      document
        .querySelectorAll('.reveal-section, .reveal-child, .reveal-scale')
        .forEach((el) => observer.observe(el))
    </script>
  </body>
</html>

---
const WA_NUMBER = '201204444196'
const year = new Date().getFullYear()
---

<footer class="relative overflow-hidden" style="background-color:#1c1917;margin-top:5rem">

  <!-- Doodle layer: flame-stroke appliance row on dark canvas -->
  <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true" style="opacity:0.085">
    <svg width="100%" height="100%" viewBox="0 0 1200 340" fill="none" preserveAspectRatio="xMidYMid meet"
         style="color:var(--c-flame-bright)">

      <!-- Flowing baseline connecting all appliances -->
      <path d="M80 240 Q220 222 340 238 Q460 254 600 232 Q740 212 860 238 Q980 264 1100 240 Q1160 228 1200 236"
            stroke="currentColor" stroke-width="0.8" fill="none" stroke-dasharray="5 8"/>

      <!-- Kettle — left -->
      <g transform="translate(130,192)">
        <ellipse cx="0" cy="0" rx="30" ry="32" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <path d="M28 -11 Q44 -17 46 -28 Q48 -39 38 -43" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round"/>
        <path d="M-28 -16 Q-50 -16 -50 4 Q-50 20 -28 20" stroke="currentColor" stroke-width="1.2" fill="none"/>
        <ellipse cx="0" cy="-32" rx="17" ry="4" stroke="currentColor" stroke-width="1.2" fill="none"/>
        <circle cx="0" cy="-37" r="3.5" stroke="currentColor" stroke-width="0.9" fill="none"/>
        <ellipse cx="0" cy="32" rx="36" ry="6" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <!-- Steam wisps -->
        <path d="M-5 -37 Q-2 -50 0 -60 Q2 -70 0 -80" stroke="currentColor" stroke-width="0.9" fill="none" stroke-linecap="round"/>
        <path d="M7 -36 Q10 -48 7 -60 Q4 -72 7 -82" stroke="currentColor" stroke-width="0.7" fill="none" stroke-linecap="round"/>
      </g>

      <!-- Blender — left-center -->
      <g transform="translate(340,186)">
        <path d="M-18 -46 L16 -46 L11 22 L-13 22 Z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
        <path d="M-16 -46 L14 -46 L10 -58 L-12 -58 Z" stroke="currentColor" stroke-width="1" fill="none"/>
        <rect x="-3" y="-66" width="6" height="9" rx="3" stroke="currentColor" stroke-width="1" fill="none"/>
        <path d="M16 -18 Q32 -18 32 2 Q32 18 16 18" stroke="currentColor" stroke-width="1.2" fill="none"/>
        <rect x="-20" y="22" width="40" height="22" rx="6" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <circle cx="0" cy="33" r="6" stroke="currentColor" stroke-width="1" fill="none"/>
        <line x1="-12" y1="44" x2="-12" y2="52" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        <line x1="12" y1="44" x2="12" y2="52" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        <line x1="-6" y1="-20" x2="6" y2="-20" stroke="currentColor" stroke-width="0.6" stroke-dasharray="2 3"/>
        <line x1="-6" y1="-10" x2="6" y2="-10" stroke="currentColor" stroke-width="0.6" stroke-dasharray="2 3"/>
      </g>

      <!-- Kibbeh Maker — center (hero product) -->
      <g transform="translate(600,194)">
        <rect x="-56" y="-20" width="112" height="40" rx="20" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <path d="M-12 -20 L-24 -56 L24 -56 L12 -20" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
        <line x1="-24" y1="-56" x2="24" y2="-56" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
        <path d="M-36 -10 Q-24 0 -36 10" stroke="currentColor" stroke-width="0.9" fill="none"/>
        <path d="M-12 -10 Q0 0 -12 10" stroke="currentColor" stroke-width="0.9" fill="none"/>
        <path d="M12 -10 Q24 0 12 10" stroke="currentColor" stroke-width="0.9" fill="none"/>
        <circle cx="56" cy="0" r="19" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <circle cx="50" cy="-6" r="2.2" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <circle cx="56" cy="-9" r="2.2" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <circle cx="62" cy="-6" r="2.2" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <circle cx="50" cy="6" r="2.2" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <circle cx="56" cy="9" r="2.2" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <circle cx="62" cy="6" r="2.2" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <circle cx="56" cy="0" r="2.2" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <line x1="-56" y1="0" x2="-78" y2="0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <circle cx="-78" cy="0" r="7" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <line x1="-78" y1="-7" x2="-78" y2="-28" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <circle cx="-78" cy="-34" r="6" stroke="currentColor" stroke-width="1.2" fill="none"/>
        <rect x="-40" y="20" width="14" height="12" rx="3" stroke="currentColor" stroke-width="1" fill="none"/>
        <rect x="26" y="20" width="14" height="12" rx="3" stroke="currentColor" stroke-width="1" fill="none"/>
      </g>

      <!-- Air Fryer — right-center -->
      <g transform="translate(870,188)">
        <path d="M-26 -20 Q-28 -46 0 -48 Q28 -46 26 -20 Z" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <rect x="-13" y="-42" width="26" height="11" rx="2" stroke="currentColor" stroke-width="1" fill="none"/>
        <rect x="-24" y="-20" width="48" height="48" rx="8" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <circle cx="14" cy="-6" r="7" stroke="currentColor" stroke-width="1" fill="none"/>
        <line x1="14" y1="-13" x2="14" y2="-10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="-18" y1="-12" x2="-18" y2="-1" stroke="currentColor" stroke-width="0.8" stroke-linecap="round"/>
        <line x1="-12" y1="-12" x2="-12" y2="-1" stroke="currentColor" stroke-width="0.8" stroke-linecap="round"/>
        <circle cx="-17" cy="30" r="4" stroke="currentColor" stroke-width="1" fill="none"/>
        <circle cx="17" cy="30" r="4" stroke="currentColor" stroke-width="1" fill="none"/>
      </g>

      <!-- Iron — right -->
      <g transform="translate(1088,192) rotate(-6)">
        <path d="M-44 -11 Q-54 -11 -54 0 Q-54 11 -44 14 L34 14 Q46 14 48 5 L48 -11 Q48 -21 34 -21 L-34 -21 Q-44 -21 -44 -11 Z" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <path d="M-19 -21 Q-19 -48 0 -52 Q17 -55 34 -49 L34 -21" stroke="currentColor" stroke-width="1.2" fill="none"/>
        <circle cx="-29" cy="2" r="1.8" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <circle cx="-15" cy="2" r="1.8" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <circle cx="0" cy="2" r="1.8" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <circle cx="14" cy="2" r="1.8" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <circle cx="-22" cy="8" r="1.8" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <circle cx="-8" cy="8" r="1.8" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <circle cx="7" cy="8" r="1.8" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <path d="M34 -49 Q40 -57 42 -68 Q44 -78 38 -84" stroke="currentColor" stroke-width="0.8" fill="none" stroke-dasharray="3 3" stroke-linecap="round"/>
      </g>

      <!-- Wheat stalks — decorative food motif between appliances -->
      <g transform="translate(234,152)">
        <line x1="0" y1="0" x2="0" y2="62" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
        <path d="M0 16 Q9 8 13 13 Q9 18 0 16" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <path d="M0 16 Q-9 8 -13 13 Q-9 18 0 16" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <path d="M0 30 Q9 22 13 27 Q9 32 0 30" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <path d="M0 30 Q-9 22 -13 27 Q-9 32 0 30" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <path d="M0 44 Q7 37 10 41 Q7 45 0 44" stroke="currentColor" stroke-width="0.7" fill="none"/>
        <path d="M0 44 Q-7 37 -10 41 Q-7 45 0 44" stroke="currentColor" stroke-width="0.7" fill="none"/>
        <path d="M0 0 Q2 -7 0 -13" stroke="currentColor" stroke-width="0.9" fill="none" stroke-linecap="round"/>
      </g>
      <g transform="translate(976,158)">
        <line x1="0" y1="0" x2="0" y2="58" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
        <path d="M0 14 Q8 7 12 12 Q8 17 0 14" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <path d="M0 14 Q-8 7 -12 12 Q-8 17 0 14" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <path d="M0 28 Q8 21 12 26 Q8 31 0 28" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <path d="M0 28 Q-8 21 -12 26 Q-8 31 0 28" stroke="currentColor" stroke-width="0.8" fill="none"/>
        <path d="M0 42 Q6 36 9 40 Q6 44 0 42" stroke="currentColor" stroke-width="0.7" fill="none"/>
        <path d="M0 42 Q-6 36 -9 40 Q-6 44 0 42" stroke="currentColor" stroke-width="0.7" fill="none"/>
        <path d="M0 0 Q2 -6 0 -12" stroke="currentColor" stroke-width="0.9" fill="none" stroke-linecap="round"/>
      </g>

    </svg>
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Brand -->
      <div>
        <a href="/" class="inline-flex items-center gap-0.5 mb-4">
          <span class="font-cairo font-black text-2xl" style="color:var(--c-brand)">هفار</span>
          <span class="font-cairo text-sm mt-1" style="color:#78716c">ستور</span>
        </a>
        <p class="text-sm font-cairo leading-relaxed" style="color:#78716c">
          أجهزة مصرية للمطبخ. شحن مجاني، وافحص قبل ما تدفع.
        </p>
        <!-- WhatsApp -->
        <a
          href={`https://wa.me/${WA_NUMBER}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-4 px-4 py-2 rounded-xl font-semibold font-cairo text-sm transition-colors"
          style="background:rgba(37,211,102,0.10);color:#25d366"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          تواصل على واتساب
        </a>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-cairo font-bold text-sm mb-4" style="color:#f5f5f4">روابط سريعة</h3>
        <ul class="space-y-2 text-sm font-cairo">
          {[
            { href: '/products', label: 'تصفح المنتجات' },
            { href: '/cart',     label: 'السلة' },
            { href: '/orders',   label: 'طلباتي' },
            { href: '/service',  label: 'الصيانة والاستبدال' },
            { href: '/contact',  label: 'تواصل معنا' },
          ].map(({ href, label }) => (
            <li>
              <a href={href} class="transition-colors" style="color:#78716c" onmouseover="this.style.color='#d4cfc9'" onmouseout="this.style.color='#78716c'">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Trust -->
      <div>
        <h3 class="font-cairo font-bold text-sm mb-4" style="color:#f5f5f4">لماذا هفار؟</h3>
        <ul class="space-y-3 text-sm font-cairo">
          {[
            'ضمان على جميع المنتجات',
            'افحص قبل الدفع — الدفع عند الاستلام',
            'شحن مجاني لجميع أنحاء مصر',
            'صيانة واستبدال ومرتجع في خطوات',
          ].map((text) => (
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="var(--c-trust)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
              <span style="color:#78716c">{text}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <div class="mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3" style="border-top:1px solid #292524">
      <p class="font-cairo text-xs" style="color:#57534e">
        © {year} هفار ستور. جميع الحقوق محفوظة.
      </p>
      <div class="flex items-center gap-4 text-xs font-cairo" style="color:#57534e">
        <a href="/privacy" class="transition-colors hover:text-stone-400">سياسة الخصوصية</a>
        <span>·</span>
        <a href="/terms" class="transition-colors hover:text-stone-400">الشروط والأحكام</a>
      </div>
    </div>
  </div>
</footer>

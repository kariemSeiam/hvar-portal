---
// TODO: replace WA_NUMBER with real Hvar WhatsApp number
const WA_NUMBER = '201XXXXXXXXX'
const year = new Date().getFullYear()
---

<footer style="background-color:#1c1917;margin-top:5rem">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Brand -->
      <div>
        <a href="/" class="inline-flex items-center gap-0.5 mb-4">
          <span class="font-cairo font-black text-2xl" style="color:var(--c-brand)">هفار</span>
          <span class="font-cairo text-sm mt-1" style="color:#78716c">ستور</span>
        </a>
        <p class="text-sm font-cairo leading-relaxed" style="color:#78716c">
          هفار اختيارك الأول في المطبخ. أجهزة موثوقة بضمان حقيقي، شحن مجاني، وخدمة بعد البيع متكاملة.
        </p>
        <!-- WhatsApp -->
        <a
          href={`https://wa.me/${WA_NUMBER}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-4 px-4 py-2 rounded-xl font-semibold font-cairo text-sm transition-colors"
          style="background:rgba(37,211,102,0.10);color:#25d366"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          تواصل على واتساب
        </a>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-cairo font-bold text-sm mb-4" style="color:#f5f5f4">روابط سريعة</h3>
        <ul class="space-y-2 text-sm font-cairo">
          {[
            { href: '/products', label: 'تصفح المنتجات' },
            { href: '/cart',     label: 'السلة' },
            { href: '/orders',   label: 'طلباتي' },
            { href: '/service',  label: 'الصيانة والاستبدال' },
            { href: '/contact',  label: 'تواصل معنا' },
          ].map(({ href, label }) => (
            <li>
              <a href={href} class="transition-colors" style="color:#78716c" onmouseover="this.style.color='#d4cfc9'" onmouseout="this.style.color='#78716c'">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Trust -->
      <div>
        <h3 class="font-cairo font-bold text-sm mb-4" style="color:#f5f5f4">لماذا هفار؟</h3>
        <ul class="space-y-3 text-sm font-cairo">
          {[
            'ضمان من ٢-٣ سنوات على كل منتج',
            'افحص قبل الدفع — الدفع عند الاستلام',
            'شحن مجاني لجميع أنحاء مصر',
            'صيانة واستبدال ومرتجع في خطوات',
          ].map((text) => (
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
              <span style="color:#78716c">{text}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <div class="mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3" style="border-top:1px solid #292524">
      <p class="font-cairo text-xs" style="color:#57534e">
        © {year} هفار ستور. جميع الحقوق محفوظة.
      </p>
      <div class="flex items-center gap-4 text-xs font-cairo" style="color:#57534e">
        <a href="/privacy" class="transition-colors hover:text-stone-400">سياسة الخصوصية</a>
        <span>·</span>
        <a href="/terms" class="transition-colors hover:text-stone-400">الشروط والأحكام</a>
      </div>
    </div>
  </div>
</footer>

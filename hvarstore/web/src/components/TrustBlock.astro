---
import Doodles from './Doodles.astro'

/*
  Accent palette:
  red   → hardest promises (warranty, social proof) — brand fire
  brass → service qualities (shipping, inspection, installments, maintenance) — premium warmth
*/
const pillars = [
  {
    label: 'ضمان حقيقي',
    svg: `<path d="M12 2L4 6v6c0 5 3.5 9.5 8 11 4.5-1.5 8-6 8-11V6L12 2Z"/><polyline points="9 12 11 14 15 10"/>`,
    accent: 'red-start' as const,
    iconShape: 'xl'   as const,
    featured: true,
  },
  {
    label: 'شحن مجاني',
    svg: `<rect x="3" y="9" width="11" height="8" rx="1"/><path d="M14 11h4l3 5H14"/><circle cx="7.5" cy="18.5" r="1.5"/><circle cx="17.5" cy="18.5" r="1.5"/>`,
    accent: 'brass-top' as const,
    iconShape: 'full' as const,
    featured: false,
  },
  {
    label: 'افحص قبل الدفع',
    svg: `<circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="21" y2="21"/><path d="M9.5 11a1.5 1.5 0 1 0 3 0 1.5 1.5 0 0 0-3 0"/>`,
    accent: 'brass-tint' as const,
    iconShape: 'xl'   as const,
    featured: false,
  },
  {
    label: 'تقسيط بدون فوائد',
    svg: `<line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/>`,
    accent: 'brass-bottom' as const,
    iconShape: 'full' as const,
    featured: false,
  },
  {
    label: 'صيانة متكاملة',
    svg: `<path d="M14.5 4.5A4.5 4.5 0 0 0 6 8c0 .9.3 1.8.7 2.5L3 14.1A2 2 0 1 0 5.9 17l3.6-3.7A4.5 4.5 0 1 0 14.5 4.5Z"/>`,
    accent: 'brass-end' as const,
    iconShape: 'xl'   as const,
    featured: false,
  },
  {
    label: '١٤٧+ ألف عميل',
    svg: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
    accent: 'red-ring' as const,
    iconShape: 'full' as const,
    featured: true,
  },
]

type Accent = typeof pillars[number]['accent']

/*
  cardStyle: uses CSS custom properties so colors shift with the design system.
  --c-brass-rgb / --c-brand-rgb are the RGB component tokens for alpha variants.
  #130F0C stays hardcoded — it is the brand forced-dark canvas.
  #F5EFE6 stays hardcoded for text — forced-dark sections need light text regardless of theme.
*/
function cardStyle(accent: Accent): string {
  const dim = 'rgba(var(--c-brass-rgb),0.20)'
  const base = `background:rgba(255,255,255,0.04);border:1.5px solid ${dim}`

  if (accent === 'red-start')    return `${base};border-inline-start:3px solid var(--c-brand)`
  if (accent === 'brass-top')    return `${base};border-top:3px solid var(--c-brass)`
  if (accent === 'brass-tint')   return `background:rgba(var(--c-brass-rgb),0.07);border:1.5px solid rgba(var(--c-brass-rgb),0.30)`
  if (accent === 'brass-bottom') return `${base};border-bottom:3px solid var(--c-brass)`
  if (accent === 'brass-end')    return `${base};border-inline-end:3px solid var(--c-brass)`
  if (accent === 'red-ring')     return `${base};box-shadow:0 0 0 2px rgba(var(--c-brand-rgb),0.28),inset 0 0 0 1px rgba(var(--c-brand-rgb),0.07);border-end-end-radius:1.5rem`
  return base
}
---

<section class="tb-section reveal-section relative overflow-hidden">

  <!-- Red → brass → red accent line at top (Wilson cta-elevated, Hvar palette) -->
  <div class="tb-top-bar" aria-hidden></div>

  <!-- P2 grain — surface texture so dark reads as material -->
  <div class="tb-grain" aria-hidden></div>

  <!-- P1 Doodles — kitchen silhouettes, faint on forced dark -->
  <Doodles variant="band" opacity={0.20} />

  <!-- Ambient: brand red ember from top, brass warmth from bottom -->
  <div class="tb-glow-top"    aria-hidden></div>
  <div class="tb-glow-bottom" aria-hidden></div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">

    <!-- Header -->
    <header class="text-center mb-10 sm:mb-12 reveal-child">
      <p class="tb-overline">هفار بتضمن</p>
      <h2 class="tb-title">
        مزايا <span class="tb-accent-word">نضمنها</span> لكِ
      </h2>
      <p class="tb-subtitle">
        ضمان وشحن وتقسيط وصيانة — كل ما تحتاجيه مع هفار
      </p>
    </header>

    <!--
      Grid layout:  2-col mobile → 3-col small → 6-col large
      Source: Wilson HomePage.tsx line 306
    -->
    <ul
      class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 sm:gap-4 list-none p-0 m-0"
      role="list"
    >
      {pillars.map(({ label, svg, accent, iconShape, featured }, idx) => (
        <li>
          <div
            class={`tb-card reveal-child relative overflow-hidden rounded-2xl flex flex-col items-center text-center p-3.5 sm:p-5 min-h-[7rem] sm:min-h-[8rem] ${idx % 2 === 0 ? 'pill-tilt' : 'pill-tilt-alt'}`}
            style={cardStyle(accent)}
          >

            <!-- P6 card shine sweep on hover -->
            <div class="tb-shine" aria-hidden></div>

            <!-- Icon with ember -->
            <div class={`tb-icon ${iconShape === 'full' ? 'rounded-full' : 'rounded-xl'} ${accent.startsWith('red') ? 'tb-icon--red' : ''}`}>
              <div class={`tb-ember ${featured ? 'tb-ember--on' : ''}`} aria-hidden></div>
              <svg
                width="20" height="20" viewBox="0 0 24 24"
                fill="none" stroke="currentColor"
                stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"
                class="tb-icon-svg"
                aria-hidden="true"
                set:html={svg}
              />
            </div>

            <span class="tb-label">{label}</span>

          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  /* ── Canvas ──────────────────────────────────────────────────────────── */
  .tb-section {
    /* Forced dark brand canvas — hardcoded by design, not theme-aware */
    background-color: #130F0C;
  }

  /* Red → brass → red accent line at top */
  .tb-top-bar {
    position: absolute;
    top: 0;
    left: 8%;
    right: 8%;
    height: 2px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(var(--c-brand-rgb), 0.55),
      rgba(var(--c-brass-rgb), 0.88),
      rgba(var(--c-brand-rgb), 0.55),
      transparent
    );
    border-radius: 1px;
    z-index: 2;
  }

  /* P2 grain */
  .tb-grain {
    position: absolute;
    inset: 0;
    opacity: 0.045;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    mix-blend-mode: overlay;
    pointer-events: none;
    z-index: 1;
  }

  /* Ambient glows */
  .tb-glow-top {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 55% at 50% -5%,
      rgba(var(--c-brand-rgb), 0.09) 0%, transparent 65%);
    pointer-events: none;
    z-index: 1;
  }
  .tb-glow-bottom {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 40% at 50% 108%,
      rgba(var(--c-brass-rgb), 0.08) 0%, transparent 65%);
    pointer-events: none;
    z-index: 1;
  }

  /* ── Header ──────────────────────────────────────────────────────────── */
  .tb-overline {
    font-family: "Cairo", system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.625rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    /* var(--c-brass) on forced dark — correct token usage */
    color: var(--c-brass);
    margin-bottom: 0.75rem;
  }
  .tb-title {
    font-family: "Cairo", system-ui, sans-serif;
    font-weight: 800;
    font-size: clamp(1.75rem, 4.5vw, 2.5rem);
    line-height: 1.2;
    /* Forced-dark text — hardcoded cream since section forces #130F0C bg */
    color: #F5EFE6;
    margin-bottom: 0.75rem;
  }
  .tb-accent-word {
    /* The key verb "نضمنها" (we guarantee) in brass — design system token */
    color: var(--c-brass);
  }
  .tb-subtitle {
    font-family: "Cairo", system-ui, sans-serif;
    font-size: 0.875rem;
    color: rgba(245, 239, 230, 0.36);
    max-width: 28rem;
    margin: 0 auto;
    line-height: 1.75;
  }

  /* ── Card ────────────────────────────────────────────────────────────── */
  .tb-card {
    transition:
      border-color 0.32s cubic-bezier(0.22,1,0.36,1),
      box-shadow   0.32s cubic-bezier(0.22,1,0.36,1),
      transform    0.32s cubic-bezier(0.22,1,0.36,1);
  }
  .tb-card:hover {
    border-color: rgba(var(--c-brass-rgb), 0.88) !important;
    box-shadow:
      0 0 0 1px rgba(var(--c-brass-rgb), 0.32),
      0 0 28px rgba(var(--c-brass-rgb), 0.14),
      inset 0 0 24px rgba(var(--c-brass-rgb), 0.05) !important;
    transform: translateY(-4px) rotate(0deg) !important;
  }
  /* P6 card shine sweep */
  .tb-shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 30%,
      rgba(255,255,255,0.055) 50%,
      transparent 70%
    );
    transform: translateX(-160%);
    transition: transform 0.55s cubic-bezier(0.22,1,0.36,1);
    pointer-events: none;
    z-index: 0;
  }
  .tb-card:hover .tb-shine {
    transform: translateX(160%);
  }

  /* ── Icon ────────────────────────────────────────────────────────────── */
  .tb-icon {
    position: relative;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-bottom: 0.625rem;
    /* Brass icon bg by default */
    background: rgba(var(--c-brass-rgb), 0.12);
    color: var(--c-brass);
    transition: transform 0.3s cubic-bezier(0.22,1,0.36,1);
    z-index: 2;
  }
  /* Red-accented cards: icon fires in brand red */
  .tb-icon--red {
    background: rgba(var(--c-brand-rgb), 0.12);
    color: var(--c-brand);
  }
  @media (min-width: 640px) {
    .tb-icon { width: 2.75rem; height: 2.75rem; }
  }
  .tb-card:hover .tb-icon {
    transform: scale(1.1);
  }

  /* Ember — radial glow behind icon, reveals on hover */
  .tb-ember {
    position: absolute;
    inset: -6px;
    border-radius: inherit;
    background: radial-gradient(
      circle at 50% 50%,
      rgba(var(--c-brass-rgb), 0.30) 0%,
      transparent 72%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 0;
  }
  .tb-icon--red .tb-ember {
    background: radial-gradient(
      circle at 50% 50%,
      rgba(var(--c-brand-rgb), 0.30) 0%,
      transparent 72%
    );
  }
  .tb-ember--on {
    opacity: 0.55;
  }
  .tb-card:hover .tb-ember {
    opacity: 1;
  }

  .tb-icon-svg {
    position: relative;
    z-index: 1;
  }

  /* ── Label ───────────────────────────────────────────────────────────── */
  .tb-label {
    font-family: "Cairo", system-ui, sans-serif;
    font-weight: 700;
    font-size: 0.8125rem;
    line-height: 1.4;
    /* Forced-dark section text — hardcoded cream */
    color: #F5EFE6;
    position: relative;
    z-index: 2;
  }
  @media (min-width: 640px) {
    .tb-label { font-size: 0.875rem; }
  }

  /* ── Reduced motion ──────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .tb-card,
    .tb-shine,
    .tb-ember,
    .tb-icon { transition: none; }
    .tb-card:hover { transform: none !important; }
    .tb-shine { display: none; }
  }
</style>

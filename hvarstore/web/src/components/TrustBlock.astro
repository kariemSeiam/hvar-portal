---
const pillars = [
  {
    label: 'ضمان حقيقي',
    desc: 'من ٢ لـ٣ سنوات على كل منتج',
    svg: `<path d="M12 2L4 6v6c0 5 3.5 9.5 8 11 4.5-1.5 8-6 8-11V6L12 2Z"/><path d="M9 12l2 2 4-4"/>`,
  },
  {
    label: 'شحن مجاني',
    desc: 'توصيل لجميع أنحاء مصر',
    svg: `<path d="M3 9h11v8H3zM14 9l3 4h4v4h-4"/><circle cx="7" cy="18" r="1.5"/><circle cx="17" cy="18" r="1.5"/><line x1="3" y1="6" x2="14" y2="6"/>`,
  },
  {
    label: 'افحص قبل الدفع',
    desc: 'دفع عند الاستلام — بدون مخاطرة',
    svg: `<circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="21" y2="21"/><path d="M9 11a2 2 0 1 0 4 0 2 2 0 0 0-4 0"/>`,
  },
  {
    label: 'صيانة متكاملة',
    desc: 'طلب صيانة واستبدال في خطوات',
    svg: `<path d="M14.5 4.5A4.5 4.5 0 0 0 6 8c0 .9.3 1.8.7 2.5L3 14.1A2 2 0 1 0 5.9 17l3.6-3.7A4.5 4.5 0 1 0 14.5 4.5Z"/>`,
  },
]
---

<section class="py-12 reveal-section" style="background-color:var(--c-surface);border-top:1px solid var(--c-border);border-bottom:1px solid var(--c-border)">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {pillars.map(({ svg, label, desc }) => (
        <div class="flex flex-col items-center text-center gap-3 reveal-child">
          <div class="w-12 h-12 flex items-center justify-center rounded-2xl" style="background-color:var(--c-brand-tint);color:var(--c-brand)">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={svg} />
          </div>
          <div>
            <p class="font-cairo font-bold text-sm" style="color:var(--c-ink)">{label}</p>
            <p class="font-cairo text-xs mt-0.5 leading-snug" style="color:var(--c-ink-muted)">{desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

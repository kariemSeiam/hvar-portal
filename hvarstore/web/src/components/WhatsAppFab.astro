---
// WhatsApp FAB — floating action button, fixed bottom-left
// Inspired by vision HTML: pulse ring, scale animation, permanent
---

<button
  id="wa-fab"
  class="fixed bottom-5 left-5 z-40 w-[60px] h-[60px] rounded-full bg-[#25d366] text-white border-none shadow-[0_14px_30px_-8px_rgba(37,211,102,0.6)] cursor-pointer flex items-center justify-center transition-transform duration-250 hover:scale-110 hover:rotate-6"
  aria-label="تواصل على واتساب"
  title="تواصل على واتساب"
>
  <svg width="30" height="30" viewBox="0 0 24 24" fill="currentColor">
    <path d="M12 2a10 10 0 00-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1012 2zm0 18a8 8 0 01-4-1l-3 .8.8-2.8A8 8 0 1112 20zm4.5-5.6c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1-.6.8-.8 1-.3.2-.5 0a6.5 6.5 0 01-3.2-2.8c-.2-.4.2-.4.6-1.3.1-.2 0-.3 0-.5l-.7-1.7c-.2-.5-.4-.4-.5-.4h-.5a1 1 0 00-.7.3 3 3 0 00-1 2.2 5.3 5.3 0 001.1 2.8 12 12 0 004.6 4c2.2.8 2.2.5 2.6.5a2.7 2.7 0 001.8-1.2 2.2 2.2 0 00.1-1.2c0-.1-.2-.2-.5-.3z"/>
  </svg>
</button>

<script>
  (function () {
    const btn = document.getElementById('wa-fab')
    if (!btn) return

    // Add pulse ring via pseudo-element (CSS ::before won't work on fixed position consistently)
    const ring = document.createElement('div')
    ring.style.cssText =
      'position:absolute;inset:0;border-radius:50%;border:2px solid #25d366;animation:waRing 1.8s infinite;pointer-events:none'
    btn.prepend(ring)

    // Inject keyframes
    const style = document.createElement('style')
    style.textContent = `
      @keyframes waRing {
        0% { transform: scale(0.85); opacity: 0.5; }
        100% { transform: scale(1.35); opacity: 0; }
      }
    `
    document.head.appendChild(style)

    // Open WhatsApp on click
    btn.addEventListener('click', function () {
      window.open(
        'https://wa.me/201000000000?text=' + encodeURIComponent('مرحباً، أريد الاستفسار'),
        '_blank',
      )
    })
  })()
</script>

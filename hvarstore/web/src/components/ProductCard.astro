---
import type { ProductCard as ProductCardType } from '../lib/api'

interface Props {
  product: ProductCardType
}

const { product } = Astro.props
const hasDiscount = product.comparePrice !== null && product.comparePrice > product.price
const discountPct = hasDiscount
  ? Math.round(((product.comparePrice! - product.price) / product.comparePrice!) * 100)
  : 0
const isLowStock = product.stock > 0 && product.stock <= 3
const outOfStock = product.stock === 0
---

<article class="card-shine group relative rounded-2xl overflow-hidden transition-all" style="background-color:var(--c-surface);border:1px solid var(--c-border);box-shadow:var(--c-shadow-card);transition:transform 0.3s cubic-bezier(0.22,1,0.36,1),box-shadow 0.3s cubic-bezier(0.22,1,0.36,1),border-color 0.2s;will-change:transform" onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='var(--c-shadow-hover)';this.style.borderColor='var(--c-border-strong)'" onmouseleave="this.style.transform='translateY(0)';this.style.boxShadow='var(--c-shadow-card)';this.style.borderColor='var(--c-border)'">

  <!-- Image -->
  <a href={`/products/${product.slug}`} class="block relative overflow-hidden" style="aspect-ratio:1/1">
    {product.image ? (
      <img
        src={product.image}
        alt={product.name}
        width="400"
        height="400"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <!-- Branded placeholder -->
      <div class="product-placeholder w-full h-full flex items-center justify-center">
        <!-- Subtle appliance doodle rings -->
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none" aria-hidden="true">
          <svg width="100%" height="100%" viewBox="0 0 200 200" fill="none" opacity="0.06">
            <circle cx="100" cy="100" r="70" stroke="var(--c-brand)" stroke-width="1" stroke-dasharray="4 6"/>
            <circle cx="100" cy="100" r="50" stroke="var(--c-brand)" stroke-width="0.8"/>
            <circle cx="100" cy="100" r="30" stroke="var(--c-brand)" stroke-width="0.6" stroke-dasharray="2 4"/>
          </svg>
        </div>
        <!-- هـ brand monogram -->
        <span class="relative z-10 font-cairo font-black select-none" style="font-size:3.5rem;line-height:1;color:var(--c-brand);opacity:0.18">هـ</span>
      </div>
    )}

    <!-- Discount badge -->
    {hasDiscount && (
      <span class="absolute top-3 end-3 px-2 py-0.5 rounded-lg font-inter font-bold text-[11px] leading-tight text-white" style="background-color:var(--c-brand)">
        -{discountPct}%
      </span>
    )}

    <!-- Out of stock overlay -->
    {outOfStock && (
      <div class="absolute inset-0 flex items-center justify-center" style="background:rgba(var(--c-bg-rgb,251,247,241),0.75)">
        <span class="font-cairo font-bold text-sm px-3 py-1.5 rounded-xl shadow-sm" style="background-color:var(--c-surface);color:var(--c-ink-muted);border:1px solid var(--c-border)">
          نفذت الكمية
        </span>
      </div>
    )}
  </a>

  <!-- Info -->
  <div class="p-4">
    <!-- Category -->
    {product.categoryName && (
      <span class="font-cairo font-semibold text-[10px] uppercase tracking-wide mb-1.5 block" style="color:var(--c-ink-faint)">
        {product.categoryName}
      </span>
    )}

    <a href={`/products/${product.slug}`} class="block mb-3">
      <h3 class="font-cairo font-semibold text-sm leading-snug line-clamp-2 transition-colors" style="color:var(--c-ink)" onmouseenter="this.style.color='var(--c-brand)'" onmouseleave="this.style.color='var(--c-ink)'">
        {product.name}
      </h3>
    </a>

    <!-- Price row -->
    <div class="flex items-baseline gap-2 mb-1.5">
      <span class="font-inter font-bold text-base tabular-nums" style="color:var(--c-brand)">
        {product.price.toLocaleString('ar-EG')} ج.م
      </span>
      {hasDiscount && (
        <span class="font-inter text-xs line-through tabular-nums" style="color:var(--c-ink-faint)">
          {product.comparePrice!.toLocaleString('ar-EG')}
        </span>
      )}
    </div>

    <!-- Low stock -->
    {isLowStock && (
      <p class="flex items-center gap-1 text-[11px] font-cairo mb-2 text-amber-600 dark:text-amber-400">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10.3 3.3L2 20h20L13.7 3.3a2 2 0 0 0-3.4 0Z"/>
          <line x1="12" y1="9" x2="12" y2="13"/>
          <line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        {product.stock} قطع متبقية
      </p>
    )}

    <!-- Add to cart -->
    <button
      class:list={[
        'add-to-cart w-full py-2.5 rounded-xl text-sm font-cairo font-bold transition-all duration-300',
        outOfStock ? 'cursor-not-allowed' : '',
      ]}
      style={outOfStock
        ? 'background-color:var(--c-border);color:var(--c-ink-muted)'
        : 'background-color:var(--c-brand);color:#ffffff'
      }
      disabled={outOfStock}
      data-product={JSON.stringify({
        productId: product.id,
        variationId: product.variationId,
        slug: product.slug,
        name: product.name,
        image: product.image,
        price: product.price,
      })}
      onmouseenter={!outOfStock ? "this.style.backgroundColor='var(--c-brand-hover)'" : undefined}
      onmouseleave={!outOfStock ? "this.style.backgroundColor='var(--c-brand)'" : undefined}
    >
      {outOfStock ? 'نفذت الكمية' : 'أضف للسلة'}
    </button>
  </div>
</article>

<script>
  if (!(window as Window & { __cartBtnsInit?: boolean }).__cartBtnsInit) {
    ;(window as Window & { __cartBtnsInit?: boolean }).__cartBtnsInit = true

    document.addEventListener('click', async (e) => {
      const btn = (e.target as Element).closest('.add-to-cart') as HTMLButtonElement | null
      if (!btn || btn.disabled) return

      const product = JSON.parse(btn.dataset.product ?? '{}')
      const { addToCart } = await import('../stores/cart')
      addToCart(product)

      const original = btn.textContent
      const originalBg = btn.style.backgroundColor
      btn.textContent = 'تمت الإضافة ✓'
      btn.style.backgroundColor = '#16a34a'

      setTimeout(() => {
        btn.textContent = original
        btn.style.backgroundColor = originalBg
      }, 1500)
    })
  }
</script>

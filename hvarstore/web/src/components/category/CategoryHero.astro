---
import Doodles from '../Doodles.astro'

interface Props {
  categoryName: string
  productCount: number
}
const { categoryName, productCount } = Astro.props

const HEROES: Record<string, { wattage: string; claim: string; tagline: string }> = {
  "كبة":           { wattage: "٢٠٠٠ وات", claim: "البلدوزر",        tagline: "أقوى كبة في مصر" },
  "خلاط":          { wattage: "٨٠٠٠ وات", claim: "٧ ملحقات",        tagline: "الأقوى في فئته" },
  "هاند بلندر":    { wattage: "١٥٠٠ وات", claim: "٤×١ نحاس",        tagline: "١٥ سرعة وتربو" },
  "عجان":          { wattage: "٢٢٠٠ وات", claim: "المدفع",           tagline: "أقوى عجان في مصر" },
  "مضرب":          { wattage: "٥٠٠ وات",  claim: "نحاس",             tagline: "مع حلة أو بدونها" },
  "قلاية هوائية":  { wattage: "٢٤٠٠ وات", claim: "دبل هيتر",        tagline: "٩ لتر جامبو" },
  "مكواه":         { wattage: "٢٨٠٠ وات", claim: "سيراميك",          tagline: "بخار فوري" },
  "مكنسة":         { wattage: "٢٠٠٠ وات", claim: "تربو",             tagline: "تنظيف شامل" },
  "فرن":           { wattage: "٢٢٠٠ وات", claim: "٤٦ لتر",           tagline: "حجم احترافي" },
  "مطحنة":         { wattage: "",          claim: "مطحنة هفار",       tagline: "توابل طازجة في ثواني" },
  "كاتيل":         { wattage: "",          claim: "كاتيل بيركس",      tagline: "٢ لتر من الزجاج المقاوم" },
}

const hero = HEROES[categoryName]
---

{hero && (
  <section
    class="relative overflow-hidden"
    style="background-color:#130F0C;min-height:148px"
  >

    <!-- Grain texture (Wilson P2) -->
    <div
      class="grain absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="opacity:0.06;mix-blend-mode:overlay"
    ></div>

    <!-- Ember glow left -->
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background:radial-gradient(ellipse 55% 90% at 20% 50%, rgba(var(--c-brand-rgb),0.14) 0%, transparent 70%)"
    ></div>

    <!-- Brass glow bottom-right -->
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background:radial-gradient(ellipse 40% 30% at 85% 85%, rgba(var(--c-brass-rgb),0.08) 0%, transparent 60%)"
    ></div>

    <!-- Ambient doodles (Wilson P1, band variant) -->
    <Doodles variant="band" opacity={0.55} />

    <!-- Content -->
    <div class="reveal-section relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex items-center justify-between gap-6">

      <!-- Left: text block (RTL: this is the right side visually) -->
      <div class="min-w-0">
        <!-- Product count -->
        <p class="reveal-child font-cairo text-xs mb-1" style="color:rgba(245,239,230,0.45)">
          {productCount} منتج
        </p>
        <!-- Claim (nickname/model) in brass -->
        <p class="reveal-child font-cairo font-bold text-lg mb-0.5" style="color:var(--c-brass)">
          {hero.claim}
        </p>
        <!-- Category name as main heading -->
        <h1
          class="reveal-child font-cairo font-black text-3xl sm:text-4xl leading-tight mb-1"
          style="color:#F5EFE6"
        >
          {categoryName}
        </h1>
        <!-- Tagline -->
        <p class="reveal-child font-cairo text-sm" style="color:rgba(245,239,230,0.50)">
          {hero.tagline}
        </p>
      </div>

      <!-- Right: wattage number — only rendered when wattage is set (hidden on smallest mobile) -->
      {hero.wattage && (
        <div class="reveal-child hidden xs:block flex-shrink-0 text-end" style="line-height:1">
          <p
            class="font-cairo font-black"
            style="font-size:clamp(2.8rem,7vw,4.5rem);color:var(--c-brand);opacity:0.88;line-height:1;letter-spacing:-0.02em"
          >
            {hero.wattage}
          </p>
        </div>
      )}

    </div>

    <!-- Trust line (Wilson P9) -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-4">
      <div class="trust-line" style="justify-content:flex-start;gap:1.5rem">
        <span style="color:rgba(245,239,230,0.35)" class="font-cairo text-xs">ضمان أصلي</span>
        <span style="color:rgba(245,239,230,0.35)" class="font-cairo text-xs">شحن مجاني</span>
        <span style="color:rgba(245,239,230,0.35)" class="font-cairo text-xs">ادفع لما يوصل</span>
      </div>
    </div>

  </section>
)}

<!--
  NOTE: #130F0C stays hardcoded — this section forces the brand dark canvas
  regardless of active theme. rgba(245,239,230,...) is ivory-on-dark, not a
  theme token. --c-brass and --c-brand replace the hardcoded #C8893B and
  #d43533 hex values and are identical across both Hvar themes.
  The .grain, .trust-line, .reveal-section, and .reveal-child classes come
  from the global stylesheet. The .trust-line separator dots are rendered by
  the global ::before pseudo-element rule, so no explicit · spans are needed.
-->

<style>
  /* Tailwind does not ship an xs: breakpoint — add it manually */
  @media (min-width: 400px) {
    .xs\:block { display: block; }
  }
</style>

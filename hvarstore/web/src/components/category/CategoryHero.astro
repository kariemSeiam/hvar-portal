---
interface Props {
  categoryName: string
  productCount: number
  categoryId?: number
  searchQuery?: string
}
const { categoryName, productCount, categoryId, searchQuery } = Astro.props

const HEROES: Record<string, { wattage: string; claim: string; tagline: string }> = {
  "كبة":           { wattage: "٢٠٠٠ وات", claim: "ماتور نحاس",      tagline: "أقوى كبة في مصر" },
  "خلاط":          { wattage: "٨٠٠٠ وات", claim: "٧ ملحقات",        tagline: "الأقوى في فئته" },
  "هاند بلندر":    { wattage: "١٥٠٠ وات", claim: "٤×١ نحاس",        tagline: "١٥ سرعة وتربو" },
  "عجان":          { wattage: "٢٢٠٠ وات", claim: "نحاس ١١ لتر",     tagline: "أقوى عجان في مصر" },
  "مضرب":          { wattage: "٥٠٠ وات",  claim: "نحاس",             tagline: "مع حلة أو بدونها" },
  "قلاية هوائية":  { wattage: "٢٤٠٠ وات", claim: "دبل هيتر",        tagline: "٩ لتر جامبو" },
  "مكواه":         { wattage: "٢٨٠٠ وات", claim: "سيراميك",          tagline: "بخار فوري" },
  "مكنسة":         { wattage: "٢٠٠٠ وات", claim: "تربو",             tagline: "تنظيف شامل" },
  "فرن":           { wattage: "٢٢٠٠ وات", claim: "٤٦ لتر",           tagline: "حجم احترافي" },
  "مطحنة":         { wattage: "",          claim: "مطحنة هفار",       tagline: "توابل طازجة في ثواني" },
  "كاتيل":         { wattage: "",          claim: "كاتيل بيركس",      tagline: "٢ لتر من الزجاج المقاوم" },
}

const hero = HEROES[categoryName]
---

{/* Known category — quiet utility band with claim, wattage chip, trust + search.
   Theme-aware: warm surface + ink on هفار الأحمر, charcoal + ivory on هفار الليل. */}
{hero && (
  <header class="page-hero">
    <div class="reveal-section max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-7 sm:py-9">

      {/* Spec highlight in flame + wattage chip */}
      <div class="reveal-child flex items-center gap-2.5 mb-1">
        <span class="font-cairo font-bold text-base" style="color:var(--c-flame)">{hero.claim}</span>
        {hero.wattage && (
          <span class="page-hero-chip">{hero.wattage}</span>
        )}
      </div>

      {/* Category name as main heading */}
      <h1 class="page-hero-title reveal-child">{categoryName}</h1>

      {/* Tagline + product count */}
      <p class="page-hero-sub reveal-child mt-1.5">
        {hero.tagline} · {productCount} منتج
      </p>

      {/* Trust line (Wilson P9) */}
      <div class="trust-line reveal-child mt-3" style="justify-content:flex-start;gap:1.5rem">
        <span class="font-cairo text-xs">ضمان أصلي</span>
        <span class="font-cairo text-xs">شحن مجاني</span>
        <span class="font-cairo text-xs">ادفع لما يوصل</span>
      </div>

      {/* Search bar — theme-aware light field */}
      {categoryId !== undefined && (
        <form method="GET" action="/products" class="reveal-child flex flex-wrap items-center gap-3 mt-5">
          <input type="hidden" name="category" value={String(categoryId)} />
          <div class="relative flex-1 min-w-[200px] max-w-sm">
            <input
              type="search"
              name="q"
              value={searchQuery ?? ''}
              placeholder={`ابحث في ${categoryName}...`}
              class="hvar-input w-full pr-10 pl-4 py-2.5 rounded-xl font-cairo text-sm transition-colors"
            />
            <svg class="absolute top-1/2 right-3 -translate-y-1/2" width="15" height="15" viewBox="0 0 20 20" fill="none"
                 style="color:var(--c-ink-muted)">
              <circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.5"/>
              <line x1="14" y1="14" x2="18" y2="18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          {searchQuery && (
            <a href={`/products?category=${categoryId}`}
               class="px-3 py-2.5 rounded-xl border font-cairo text-sm transition-colors"
               style="border-color:var(--c-border);color:var(--c-ink-muted)">
              مسح البحث
            </a>
          )}
        </form>
      )}

    </div>
  </header>
)}

{/* Fallback header for categories not in the HEROES map — same quiet band */}
{!hero && (
  <header class="page-hero">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-7 sm:py-9">
      <p class="page-hero-label mb-1.5">أجهزة هفار</p>
      <h1 class="page-hero-title mb-4">{categoryName}</h1>
      {categoryId !== undefined && (
        <form method="GET" action="/products" class="flex flex-wrap items-center gap-3">
          <input type="hidden" name="category" value={String(categoryId)} />
          <div class="relative flex-1 min-w-[200px] max-w-sm">
            <input
              type="search"
              name="q"
              value={searchQuery ?? ''}
              placeholder={`ابحث في ${categoryName}...`}
              class="hvar-input w-full pr-10 pl-4 py-2.5 rounded-xl font-cairo text-sm transition-colors"
            />
            <svg class="absolute top-1/2 right-3 -translate-y-1/2" width="15" height="15" viewBox="0 0 20 20" fill="none"
                 style="color:var(--c-ink-muted)">
              <circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.5"/>
              <line x1="14" y1="14" x2="18" y2="18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          {searchQuery && (
            <a href={`/products?category=${categoryId}`}
               class="px-3 py-2.5 rounded-xl border font-cairo text-sm transition-colors"
               style="border-color:var(--c-border);color:var(--c-ink-muted)">
              مسح البحث
            </a>
          )}
        </form>
      )}
    </div>
  </header>
)}

<style>
  input[type="search"]:focus {
    border-color: rgba(var(--c-brand-rgb), 0.6) !important;
    box-shadow: 0 0 0 1px rgba(var(--c-brand-rgb), 0.25);
  }
</style>

---
import type { FaqItem } from '../../lib/enrichment'

interface Props {
  faq: FaqItem[]
}

const { faq } = Astro.props
---

{faq.length > 0 && (
  <section class="fq-section">
    <h3 class="fq-heading">أسئلة شائعة</h3>

    <div class="fq-list" role="list">
      {faq.map((item, i) => (
        <details class="fq-item group" role="listitem">
          <summary class="fq-summary">
            <span class="fq-q-icon" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
                <path d="M6.5 6c0-1 .7-1.5 1.5-1.5s1.5.7 1.5 1.5c0 .7-.4 1.1-1 1.4C8 7.7 8 8 8 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <circle cx="8" cy="11" r="0.75" fill="currentColor"/>
              </svg>
            </span>
            <span class="fq-q-text">{item.q}</span>
            <span class="fq-chevron" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </summary>
          <div class="fq-answer">{item.a}</div>
        </details>
      ))}
    </div>
  </section>
)}

<style>
  .fq-section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .fq-heading {
    font-family: "Cairo", system-ui, sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: var(--c-ink);
  }

  .fq-list {
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .fq-item {
    border-block-end: 1px solid var(--c-hairline);
  }

  .fq-item:last-child {
    border-block-end: none;
  }

  .fq-summary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1.25rem;
    cursor: pointer;
    list-style: none;
    color: var(--c-ink);
    transition: background 150ms ease;
  }

  .fq-summary::-webkit-details-marker { display: none; }

  .fq-item[open] > .fq-summary,
  .fq-summary:hover {
    background: rgba(var(--c-brand-rgb), 0.035);
  }

  .fq-q-icon {
    flex-shrink: 0;
    color: var(--c-brand);
    opacity: 0.65;
    display: flex;
  }

  .fq-q-text {
    flex: 1;
    font-family: "Cairo", system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    line-height: 1.45;
  }

  .fq-chevron {
    flex-shrink: 0;
    color: var(--c-ink-muted);
    transition: transform 200ms var(--ease-spring);
    display: flex;
  }

  .fq-item[open] .fq-chevron {
    transform: rotate(180deg);
  }

  .fq-answer {
    padding-inline: 1.25rem;
    padding-inline-start: 3rem;
    padding-block-end: 1rem;
    font-family: "Cairo", system-ui, sans-serif;
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--c-ink-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .fq-chevron { transition: none; }
  }
</style>

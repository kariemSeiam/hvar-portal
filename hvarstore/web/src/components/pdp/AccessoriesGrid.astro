---
import type { AccessoryItem } from '../../lib/enrichment'

interface Props {
  accessories: AccessoryItem[]
}

const { accessories } = Astro.props
---

{accessories.length > 1 && (
  <section>
    <h3 class="font-cairo font-bold text-sm mb-3" style="color:var(--c-ink-secondary)">
      الملحقات المشمولة
    </h3>
    <div class="grid grid-cols-3 sm:grid-cols-4 gap-2">
      {accessories.map(acc => (
        <div
          class="rounded-xl p-3 text-center flex flex-col items-center gap-1.5"
          style="background-color:var(--c-surface-2);border:1px solid var(--c-border)"
        >
          <svg
            width="26"
            height="26"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            style="color:var(--c-ink-muted)"
          >
            <path d="M12 2l-1.5 3h-3l2.5 2-1 3.5L12 9l3 1.5-1-3.5 2.5-2h-3L12 2z"/>
            <line x1="12" y1="9" x2="12" y2="19"/>
            <line x1="9" y1="19" x2="15" y2="19"/>
          </svg>
          <p class="font-cairo font-semibold text-xs leading-tight" style="color:var(--c-ink)">
            {acc.nameAr}
          </p>
          {acc.spec && (
            <p class="font-cairo text-[10px]" style="color:var(--c-ink-muted)">
              {acc.spec}
            </p>
          )}
        </div>
      ))}
    </div>
  </section>
)}

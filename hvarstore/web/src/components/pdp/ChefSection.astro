---
import type { ChefEndorsement } from '../../lib/enrichment'

interface Props {
  chefs: ChefEndorsement[]
}

const { chefs } = Astro.props
const visible = chefs.filter((c) => c.name)

function initials(name: string): string {
  const parts = name.trim().split(' ')
  if (parts.length >= 2) return parts[0][0] + parts[1][0]
  return parts[0].slice(0, 2)
}
---

{visible.length > 0 && (
  <section class="ch-section">
    <h3 class="ch-heading">موصى به من شيفات مصر</h3>

    <div class="ch-list">
      {visible.map((chef) => (
        <div class="ch-card">
          <div class="ch-avatar" aria-hidden="true">{initials(chef.name)}</div>
          <div class="ch-body">
            <p class="ch-name">{chef.name}</p>
            {chef.quote && (
              <blockquote class="ch-quote">
                <span class="ch-qmark" aria-hidden="true">"</span>
                {chef.quote}
              </blockquote>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .ch-section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ch-heading {
    font-family: "Cairo", system-ui, sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--c-ink-secondary);
  }

  .ch-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ch-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--c-border);
    border-inline-start: 3px solid var(--c-brass);
    background: var(--c-surface-2);
  }

  .ch-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    background: rgba(var(--c-brass-rgb), 0.14);
    color: var(--c-brass);
    font-family: "Cairo", system-ui, sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    letter-spacing: -0.03em;
  }

  .ch-body {
    flex: 1;
    min-width: 0;
  }

  .ch-name {
    font-family: "Cairo", system-ui, sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--c-ink);
    margin-block-end: 0.25rem;
  }

  .ch-quote {
    font-family: "Cairo", system-ui, sans-serif;
    font-size: 0.875rem;
    color: var(--c-ink-muted);
    line-height: 1.7;
    margin: 0;
    padding: 0;
    border: none;
    position: relative;
  }

  .ch-qmark {
    font-size: 1.5rem;
    line-height: 0;
    vertical-align: -0.375rem;
    color: var(--c-brass);
    opacity: 0.45;
    margin-inline-end: 0.125rem;
    font-family: Georgia, serif;
  }
</style>

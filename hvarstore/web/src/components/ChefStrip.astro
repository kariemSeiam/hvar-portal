---
// Chef endorsement strip — Direction A's soul. No emojis.
---

<section class="py-16 sm:py-20 reveal-section">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="relative overflow-hidden rounded-2xl bg-[#1c1917] dark:bg-[#0f0e0d] p-8 sm:p-12">

      <!-- Grain overlay -->
      <div class="absolute inset-0 grain pointer-events-none opacity-60" aria-hidden="true"></div>

      <!-- Red glow -->
      <div class="absolute top-0 left-0 w-80 h-80 rounded-full bg-brand/6 -translate-x-1/3 -translate-y-1/3 blur-3xl pointer-events-none" aria-hidden="true"></div>

      <div class="relative z-10 flex flex-col sm:flex-row items-center gap-8">

        <!-- Chef avatar — styled monogram -->
        <div class="flex-shrink-0 w-20 h-20 rounded-full bg-gradient-to-br from-[var(--c-brand)]/30 to-[var(--c-brass)]/20 border border-[var(--c-brand)]/20 flex items-center justify-center">
          <span class="font-cairo font-black text-3xl text-brand select-none">س</span>
        </div>

        <!-- Quote -->
        <div class="flex-1 text-center sm:text-start">
          <svg class="w-8 h-5 text-[var(--c-brand)]/40 mb-3 mx-auto sm:mx-0" viewBox="0 0 32 20" fill="currentColor">
            <path d="M0 20V12C0 5.333 2.667 1.333 8 0l2 3C7.333 4.333 6 6.667 6 10h6v10H0Zm18 0V12C18 5.333 20.667 1.333 26 0l2 3c-2.667 1.333-4 3.667-4 7h6v10H18Z"/>
          </svg>
          <blockquote class="font-cairo text-xl sm:text-2xl font-bold text-white leading-relaxed mb-3">
            المطبخ الأحلى بيبدأ بالأدوات الصح
          </blockquote>
          <p class="font-cairo text-muted text-sm">
            شيف سارة عبد السلام — سفيرة هفار
          </p>
        </div>

        <!-- CTA -->
        <div class="flex-shrink-0">
          <a
            href="/products"
            class="inline-flex items-center gap-2 px-5 py-3 rounded-xl border border-white/10 hover:border-[var(--c-brand)]/60 text-white/70 hover:text-white font-cairo font-semibold text-sm transition-all hover:bg-white/5"
          >
            تسوق المجموعة
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 8h8M8 4l4 4-4 4"/>
            </svg>
          </a>
        </div>

      </div>
    </div>

  </div>
</section>

---
import Doodles from './Doodles.astro'

/*
 * Home hero — "the maker's hearth".
 *
 * The brand promise rendered as warmth, not a sales pitch. H1 is the confirmed
 * tagline «بيتك دايما جاهز مع هفار» (compass/brand/00). The hero never leads with
 * warranty or price — it leads with craft + the "always ready" feeling, and lets
 * quality whisper through the maker's seal.
 *
 * LOGO SLOT: the lockup above the H1 is a placeholder built from the brand device
 * (ember diamond + H-mark, the same mark used in the navbar) so the hero reads as
 * finished. Swap in the official SVG when ready — replace `.hero-logo-mark`'s inline
 * <svg> (keep the `.hero-logo` wrapper + sizing) or drop the asset and reference it.
 *
 * Mobile is copy-first by design: the promise + CTAs own the first screen over a
 * giant faint هـ maker's monogram, and the catalog peeks below the fold. The hotline
 * lives here as a quiet help line (the top utility strip hides its contact < 768px,
 * so this is the only above-the-fold hotline on mobile — keep it).
 *
 * Desktop (≥1024px) gets "the maker's seal": a warm, breathing scene — the logo on a
 * medallion over a living ember core, ringed once by a self-drawing circle, with the
 * real manufacturing range floating around it like embers around a hearth. Motion is
 * eased + asymmetric + breathing (never a constant linear spin — that reads as a tech
 * loader). Nothing depends on the product API, so it never degrades to a stale card.
 */

---

<section class="hero-section relative overflow-hidden" data-hero>

  <!-- Red mesh glow — .mesh-red carries its own dark-theme variant -->
  <div class="absolute inset-0 mesh-red pointer-events-none z-0" aria-hidden="true"></div>

  <!-- Giant maker's monogram — the brand stamp behind everything (anchors mobile) -->
  <span class="hero-watermark font-cairo" aria-hidden="true">هـ</span>

  <!-- Ambient doodle field (trimmed `hero` layout) -->
  <Doodles variant="hero" />

  <div class="hero-inner relative z-10 w-full max-w-7xl mx-auto">
    <div class="hero-grid">

      <!-- ── Copy column ─────────────────────────────────────── -->
      <div class="hero-col-copy">

        <!-- Logo lockup — placeholder built from the brand device; swap in official SVG -->
        <a href="/" class="hero-logo hv-reveal" style="--d:0s" aria-label="هفار — الصفحة الرئيسية">
          <span class="hero-logo-mark" aria-hidden="true">
            <svg viewBox="0 0 40 40" fill="none">
              <rect x="8" y="8" width="24" height="24" rx="6.5" transform="rotate(45 20 20)" fill="currentColor"/>
              <path d="M14 13v14M26 13v14M14 20h12" stroke="#fff" stroke-width="2.6" stroke-linecap="round"/>
            </svg>
          </span>
          <span class="hero-logo-word font-cairo">هفار</span>
        </a>

        <!-- H1 — the confirmed tagline, verbatim -->
        <h1 class="hero-h1 font-cairo font-black hv-reveal" style="--d:0.08s">
          <span class="block">بيتك دايما <span class="hero-key">جاهز</span></span>
          <span class="block hero-h1-with">مع <span class="hero-brand-word">هفار</span></span>
        </h1>

        <!-- Subline — craft + the "always ready" promise; quality whispers, never a warranty number -->
        <p class="hero-subline font-cairo leading-relaxed hv-reveal" style="--d:0.16s">
          أجهزة مصرية معمولة بإتقان وخامات تستحمل الشغل، تفضل معاكِ سنين —
          عشان بيتك يكون <span class="hero-stamp font-cairo">دايماً جاهز</span> لأي حاجة.
        </p>

        <!-- CTAs — shop + the track-order entry (→ /orders; returning buyers land on their orders) -->
        <div class="hero-ctas hv-reveal" style="--d:0.24s">
          <a href="/products" class="hero-cta-primary font-cairo font-bold">
            تسوقي دلوقتي
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M12 8H4M8 4L4 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/orders" class="hero-cta-secondary font-cairo font-semibold">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 7h11l3 4v5h-2"/><path d="M5 7v9h2"/>
              <circle cx="9" cy="17" r="1.8"/><circle cx="17" cy="17" r="1.8"/>
              <path d="M3 10h5"/>
            </svg>
            تتبّعي طلبك
          </a>
        </div>

        <!-- Help + trust — hotline's quiet home (mobile-safe) over whispered trust marks -->
        <div class="hero-meta hv-reveal" style="--d:0.32s">
          <a href="tel:17566" class="hero-hotline-link" aria-label="اتصلي بالخط الساخن ١٧٥٦٦">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2 4.2 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1 1 .4 2 .7 2.9a2 2 0 0 1-.4 2L8 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2-.5c.9.3 1.9.6 2.9.7A2 2 0 0 1 22 16.9Z"/>
            </svg>
            <span class="hero-hotline-text">محتاجة مساعدة؟ كلمينا</span>
            <span class="hero-hotline-num font-inter" dir="ltr">17566</span>
          </a>
          <ul class="hero-trust" aria-label="مزايا الشراء">
            <li>شحن مجاني</li>
            <li>افحصي قبل ما تدفعي</li>
            <li>دفع عند الاستلام</li>
          </ul>
        </div>

      </div>

    </div>
  </div>

</section>

<style>
  /* ── Section ── */
  .hero-section {
    display: flex;
    align-items: center;
    /* 3.5rem mobile navbar + ~3.5rem bottom nav; 88svh (not 100) so the
       catalog peeks above the fold — the scroll affordance IS the layout */
    min-height: calc(88svh - 7rem - env(safe-area-inset-bottom, 0px));
    padding-block: 1.5rem 2.5rem;
    background-color: var(--c-bg);
  }
  @media (min-width: 1024px) {
    .hero-section {
      /* 4rem desktop navbar; capped so ultra-tall monitors don't stretch it */
      min-height: min(calc(100svh - 4rem), 50rem);
      padding-block: 3.5rem 4rem;
    }
  }
  @media (max-height: 560px) {
    .hero-section { min-height: auto; }
  }

  .hero-inner { padding-inline: 1rem; }
  @media (min-width: 640px)  { .hero-inner { padding-inline: 1.5rem; } }
  @media (min-width: 1024px) { .hero-inner { padding-inline: 2rem; } }

  /* ── Maker's monogram watermark ──
     A giant faint هـ behind the copy. Carries the brand feel on mobile (where the
     seal is hidden); a quiet echo on desktop. Theme-aware, edge-anchored to the
     reading start so it never muddies the headline. */
  .hero-watermark {
    position: absolute;
    z-index: 0;
    inset-block-start: 50%;
    inset-inline-start: -0.18em;
    transform: translateY(-52%);
    font-weight: 900;
    line-height: 0.8;
    font-size: clamp(20rem, 64vw, 30rem);
    color: var(--c-brand);
    opacity: 0.04;
    pointer-events: none;
    user-select: none;
  }
  :global(html.dark) .hero-watermark { opacity: 0.06; }
  @media (min-width: 1024px) {
    .hero-watermark {
      inset-inline-start: -0.1em;
      font-size: 34rem;
      opacity: 0.035;
    }
    :global(html.dark) .hero-watermark { opacity: 0.05; }
  }

  /* ── Grid: single copy column ── */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .hero-grid { max-width: 52rem; }
  }

  /* ── Logo lockup ── */
  .hero-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.1rem;
  }
  .hero-logo-mark {
    display: inline-flex;
    width: 2.1rem;
    height: 2.1rem;
    color: var(--c-brand);
    filter: drop-shadow(0 4px 12px rgba(var(--c-brand-rgb), 0.30));
  }
  .hero-logo-mark svg { width: 100%; height: 100%; }
  .hero-logo-word {
    font-weight: 900;
    font-size: 1.6rem;
    line-height: 1;
    color: var(--c-ink);
    letter-spacing: -0.01em;
  }
  @media (min-width: 1024px) {
    .hero-logo { margin-bottom: 1.35rem; }
    .hero-logo-mark { width: 2.35rem; height: 2.35rem; }
    .hero-logo-word { font-size: 1.8rem; }
  }

  /* ── H1 — the tagline. Copy-first mobile earns bigger type ── */
  .hero-h1 {
    font-size: clamp(2.4rem, 10.8vw, 3rem);
    line-height: 1.16;
    color: var(--c-ink);
    margin-bottom: 0.875rem;
  }
  @media (min-width: 640px)  { .hero-h1 { font-size: clamp(3rem, 6vw, 3.6rem); } }
  @media (min-width: 1024px) { .hero-h1 { font-size: 3.9rem; margin-bottom: 1.125rem; } }

  /* مع stays in the dark hearth — no gray. The only color in the line is red. */
  .hero-h1-with { color: var(--c-ink); }
  /* The two heat-words — جاهز (the payoff) and هفار (the brand) — share one fire.
     The repeated red links promise to brand: «ready ⟷ with Hvar». */
  .hero-key { color: var(--c-brand); }
  .hero-brand-word { color: var(--c-brand); }

  /* ── Subline ── */
  .hero-subline {
    font-size: 1rem;
    max-width: 33rem;
    color: var(--c-ink-muted);
    margin-bottom: 1.5rem;
  }
  @media (min-width: 640px) { .hero-subline { font-size: 1.125rem; margin-bottom: 1.75rem; } }

  /* «دايماً جاهز» — the promise, stamped. Ember ink on red tint, the inline echo of
     the maker's seal: a promise is a thing you stamp, so the phrase IS one.
     Irregular radius + slight tilt = hand-pressed, not printed. */
  .hero-stamp {
    display: inline-block;
    padding: 0.04em 0.5em 0.14em;
    margin-inline: 0.1em;
    font-weight: 800;
    color: var(--c-brand-deep);
    background: var(--c-brand-tint);
    border: 1.5px solid var(--c-brand-line);
    border-radius: 0.55em 0.7em 0.5em 0.75em / 0.75em 0.5em 0.8em 0.55em;
    transform: rotate(-2deg);
    animation: stampThump 0.4s var(--ease-spring) 0.85s both;
  }
  :global(html.dark) .hero-stamp { color: var(--c-brand-warm); }
  @keyframes stampThump {
    0%   { opacity: 0; transform: rotate(-5deg) scale(1.5); }
    62%  { opacity: 1; transform: rotate(-2deg) scale(0.95); }
    100% { opacity: 1; transform: rotate(-2deg) scale(1); }
  }

  /* ── CTAs ── */
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 1.25rem;
  }
  .hero-cta-primary,
  .hero-cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 3rem;
    padding: 0.75rem 1.375rem;
    border-radius: 0.875rem;
    font-size: 0.9875rem;
    white-space: nowrap;
  }
  /* Narrow phones: both CTAs share one row, equal width */
  @media (max-width: 479px) {
    .hero-cta-primary,
    .hero-cta-secondary { flex: 1 1 0; padding-inline: 1rem; }
  }
  .hero-cta-primary {
    color: #fff;
    background: linear-gradient(135deg, var(--c-brand), var(--c-brand-deep));
    box-shadow: 0 12px 26px -12px var(--c-brand);
    transition: box-shadow 0.22s var(--ease-ember), transform 0.22s var(--ease-ember);
  }
  .hero-cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 34px -12px var(--c-brand);
  }
  .hero-cta-primary:active { transform: translateY(0); }
  .hero-cta-secondary {
    background-color: var(--c-surface);
    border: 1px solid var(--c-border);
    color: var(--c-ink);
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.22s var(--ease-ember);
  }
  .hero-cta-secondary:hover { border-color: var(--c-flame-bright); color: var(--c-brand); transform: translateY(-2px); }
  .hero-cta-secondary:active { transform: translateY(0); }

  /* ── Help + trust meta ── */
  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.625rem 1.1rem;
    margin-bottom: 0.5rem;
  }
  .hero-hotline-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: "Cairo", system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-ink-muted);
    transition: color 0.18s ease;
  }
  .hero-hotline-link svg { color: var(--c-flame); flex-shrink: 0; }
  .hero-hotline-link:hover { color: var(--c-brand); }
  .hero-hotline-num {
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--c-brand);
    letter-spacing: 0.04em;
  }
  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.7rem;
    list-style: none;
    margin: 0;
    padding: 0;
    font-family: "Cairo", system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--c-ink-faint);
  }
  .hero-trust li {
    display: inline-flex;
    align-items: center;
  }
  .hero-trust li:not(:first-child)::before {
    content: '';
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--c-flame-bright);
    opacity: 0.6;
    margin-inline-end: 0.7rem;
  }

  /* ── Entrance reveal — staggered via --d ── */
  .hv-reveal {
    opacity: 0;
    transform: translateY(16px);
    animation: hvFadeUp 0.65s var(--ease-spring) var(--d, 0s) forwards;
  }
  @keyframes hvFadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hv-reveal { animation: none; opacity: 1; transform: none; }
    .hero-stamp { animation: none; opacity: 1; }
    .hero-cta-primary, .hero-cta-secondary { transition: none; }
  }
</style>

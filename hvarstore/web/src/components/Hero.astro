                <line x1="30" y1="30" x2="30" y2="40" stroke="var(--c-brand)" stroke-width="1" stroke-linecap="round" stroke-dasharray="2 2"/>
                <circle cx="30" cy="50" r="2" fill="var(--c-brand)" opacity="0.3"/>
              </svg>
              <p class="font-cairo font-bold text-[11px]" style="color:var(--c-ink)">خلاط</p>
              <p class="font-cairo text-[9px]" style="color:var(--c-ink-muted)">من ٨٩٩ ج.م</p>
            </div>
            <div class="rounded-2xl bg-[#fbf7f1] dark:bg-[#12110f] border border-[#e7e0d6]/50 dark:border-[#2c2825]/50 p-3.5 text-center">

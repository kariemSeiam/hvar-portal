  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-12 gap-8 items-center">

      <!-- Left content (RTL: visual right side = content side) -->
      <div class="lg:col-span-7 max-w-xl relative">

        <!-- Premium badge — Direction A warmth cue: brass accent -->
        <div class="inline-flex items-center gap-2 mb-6 reveal-fade">
          <span class="w-6 h-px bg-[#C8893B]"></span>
          <span class="text-[#C8893B] text-[10px] font-semibold uppercase tracking-[0.15em] font-cairo">أجهزة منزلية موثوقة</span>
        </div>

        <!-- Headline — Direction A: editorial Arabic warmth, red like a ribbon -->
        <h1 class="font-cairo font-black text-[2.6rem] sm:text-[3.4rem] lg:text-[3.8rem] leading-[1.12] mb-5 reveal-fade" style="color:var(--c-ink);transition-delay: 0.1s;">
          <span class="block">في مطبخك</span>
          <span class="relative inline-block">
            يستاهل الأحسن
            <span class="absolute -bottom-2 right-0 left-0 h-[3px] rounded-full"
                  style="background: linear-gradient(90deg, #C8893B 0%, #daa545 50%, #C8893B 100%); opacity:0.6;"></span>
            <span class="absolute -bottom-[11px] right-0 w-[7px] h-[7px] rounded-full bg-[#d43533]"></span>
          </span>
        </h1>

        <!-- Subline — warm trust prose -->
        <p class="font-cairo text-base sm:text-lg leading-relaxed mb-6 max-w-lg reveal-fade" style="color:var(--c-ink-muted);transition-delay: 0.2s;">
          خلاطات، مكاوي، أجهزة مطبخ — كل اللي تحتاجه لمطبخك
          <span class="text-[#C8893B] font-semibold">بضمان سنتين</span>
          وشحن مجاني لباب البيت.
        </p>

        <!-- CTAs — Direction B: trust architecture, clear primary/secondary -->
        <div class="flex flex-wrap items-center gap-3 reveal-fade" style="transition-delay: 0.3s;">
          <a
            href="/products"
            class="inline-flex items-center gap-2 px-6 py-3.5 rounded-xl bg-[#d43533] hover:bg-[#b91c1c] text-white font-cairo font-bold text-base transition-all hover:shadow-[0_8px_24px_rgba(212,53,51,0.3)] hover:-translate-y-0.5"
            style="transition: all 0.3s cubic-bezier(0.22,1,0.36,1)"
          >
            تسوق الآن
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M4 8h8M8 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href="/orders"
            class="inline-flex items-center gap-2 px-6 py-3.5 rounded-xl bg-white dark:bg-[#1c1917] border border-[#e7e0d6] dark:border-[#2c2825] text-[#1c1917] dark:text-[#f5f5f4] font-cairo font-semibold text-base hover:border-[#d43533] dark:hover:border-[#d43533] transition-all"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
            تتبع طلبك
          </a>
        </div>

        <!-- Hero stats -->
        <div class="flex flex-wrap items-center gap-x-8 gap-y-2 mt-8 reveal-fade" style="transition-delay: 0.35s;">
          <div>
            <div class="font-inter font-black text-[1.4rem] sm:text-[1.7rem] tabular-nums" style="color:var(--c-ink)" dir="ltr">+50K</div>
            <div class="text-[11px] font-cairo" style="color:var(--c-ink-faint)">عميل واثق</div>
          </div>
          <div>
            <div class="font-inter font-black text-[1.4rem] sm:text-[1.7rem] tabular-nums" style="color:var(--c-ink)" dir="ltr">24h</div>
            <div class="text-[11px] font-cairo" style="color:var(--c-ink-faint)">خدمة عملاء</div>
          </div>
          <div>
            <div class="font-inter font-black text-[1.4rem] sm:text-[1.7rem] tabular-nums" style="color:var(--c-ink)" dir="ltr">2-5</div>
            <div class="text-[11px] font-cairo" style="color:var(--c-ink-faint)">أيام توصيل</div>
          </div>
        </div>

        <!-- Trust line -->
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mt-6 text-xs font-cairo reveal-fade" style="color:var(--c-ink-muted);transition-delay: 0.4s;">
          <span class="inline-flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            ضمان سنتين

---
import type { Category } from '../lib/api'
import { ALL_CATEGORIES_ICON as ALL_ICON, categoryIcon as icon } from '../lib/categoryIcons'

interface Props {
  categories: Category[]
  activeSlug?: string
}

const { categories, activeSlug = '' } = Astro.props
const visible = categories.filter((c) => c.productCount > 0)

// Arabic-Indic digits — matches the rest of the Arabic UI
const toAr = (n: number): string => String(n).replace(/[0-9]/g, (d) => '٠١٢٣٤٥٦٧٨٩'[+d])

// الكبة (البلدوزر) is the brand hero — a quiet brand-tinted icon, nothing louder
const heroSlug = 'chopper'
const totalCount = visible.reduce((s, c) => s + c.productCount, 0)
---

{visible.length > 0 && (
  <section class="cat-section reveal-section">
    <div class="cat-inner">

      <div class="cat-header reveal-child">
        <div>
          <p class="cat-eyebrow">تسوّق حسب القسم</p>
          <h2 class="cat-heading">كل اللي بيتك محتاجه</h2>
        </div>
        <a href="/products" class="cat-viewall">
          كل المنتجات
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M4 8h8M8 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <div class="cat-grid reveal-child" role="list" aria-label="أقسام المنتجات">

        <!-- الكل -->
        <a
          href="/products"
          role="listitem"
          class={`cat-tile${!activeSlug ? ' cat-tile--active' : ''}`}
          aria-current={!activeSlug ? 'page' : undefined}
        >
          <span class="cat-tile-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={ALL_ICON} />
          </span>
          <span class="cat-tile-name">كل المنتجات</span>
          <span class="cat-tile-count">{toAr(totalCount)} منتج</span>
        </a>

        {visible.map((cat) => {
          const isHero   = cat.slug === heroSlug
          const isActive = cat.slug === activeSlug
          return (
            <a
              href={`/products?category=${cat.id}`}
              role="listitem"
              class={`cat-tile${isHero ? ' cat-tile--hero' : ''}${isActive ? ' cat-tile--active' : ''}`}
              aria-current={isActive ? 'page' : undefined}
            >
              <span class="cat-tile-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icon(cat.slug)} />
              </span>
              <span class="cat-tile-name">{cat.name}</span>
              <span class="cat-tile-count">{toAr(cat.productCount)} منتج</span>
            </a>
          )
        })}

      </div>
    </div>
  </section>
)}

<style>
  /* ── Section ── */
  .cat-section {
    padding-block: 3rem 3.25rem;
  }
  @media (min-width: 1024px) {
    .cat-section { padding-block: 4rem; }
  }

  .cat-inner {
    max-width: 80rem;
    margin-inline: auto;
    padding-inline: 1rem;
  }
  @media (min-width: 640px)  { .cat-inner { padding-inline: 1.5rem; } }
  @media (min-width: 1024px) { .cat-inner { padding-inline: 2rem;   } }

  /* ── Header — flame eyebrow + heading + quiet view-all (matches home rhythm) ── */
  .cat-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-block-end: 1.25rem;
  }
  .cat-eyebrow {
    font-family: "Cairo", system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    color: var(--c-flame);
    margin-block-end: 0.35rem;
  }
  .cat-heading {
    font-family: "Cairo", system-ui, sans-serif;
    font-weight: 800;
    font-size: 1.25rem;
    line-height: 1.2;
    color: var(--c-ink);
  }
  @media (min-width: 1024px) { .cat-heading { font-size: 1.5rem; } }
  .cat-viewall {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
    font-family: "Cairo", system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--c-brand);
    text-decoration: none;
    transition: gap 0.2s ease;
  }
  .cat-viewall:hover { gap: 0.6rem; }

  /* ── Grid — every section visible at once, no horizontal scroll ── */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.625rem;
  }
  @media (min-width: 420px)  { .cat-grid { grid-template-columns: repeat(3, 1fr); gap: 0.75rem; } }
  @media (min-width: 768px)  { .cat-grid { grid-template-columns: repeat(4, 1fr); } }
  @media (min-width: 1100px) { .cat-grid { grid-template-columns: repeat(5, 1fr); gap: 0.875rem; } }

  /* ── Tile ── */
  .cat-tile {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.55rem;
    padding: 1.125rem 0.75rem 1rem;
    border-radius: var(--radius-lg, 1rem);
    border: 1px solid var(--c-border);
    background: var(--c-surface);
    text-decoration: none;
    min-height: 44px;
    transition:
      border-color 240ms var(--ease-spring),
      box-shadow   240ms var(--ease-spring),
      transform    240ms var(--ease-spring);
  }
  .cat-tile:hover {
    border-color: rgba(var(--c-brand-rgb), 0.35);
    transform: translateY(-2px);
    box-shadow: 0 6px 22px rgba(var(--c-brand-rgb), 0.10);
  }
  @media (prefers-reduced-motion: reduce) {
    .cat-tile { transition: none; }
    .cat-tile:hover { transform: none; }
  }

  /* Icon zone */
  .cat-tile-icon {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--c-ink-muted);
    background: rgba(var(--c-brand-rgb), 0.06);
    transition: background 200ms ease, color 200ms ease, transform 240ms var(--ease-spring);
  }
  .cat-tile-icon svg { width: 1.375rem; height: 1.375rem; }
  .cat-tile:hover .cat-tile-icon {
    background: rgba(var(--c-brand-rgb), 0.12);
    color: var(--c-brand);
    transform: scale(1.06);
  }

  /* Name — allowed to wrap to 2 lines so long Arabic names stay readable */
  .cat-tile-name {
    font-family: "Cairo", system-ui, sans-serif;
    font-weight: 700;
    font-size: 0.8125rem;
    line-height: 1.35;
    color: var(--c-ink);
    /* Reserve two lines so 1-line and 2-line names align row-to-row —
       no dead space under short names in a stretched grid cell. */
    min-height: calc(2 * 1.35em);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    align-items: center;
    overflow: hidden;
  }

  /* Count */
  .cat-tile-count {
    font-family: "Cairo", system-ui, sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--c-ink-faint);
    line-height: 1;
  }

  /* Hero (كبة) — a single quiet brand-tinted icon at rest, nothing louder */
  .cat-tile--hero:not(.cat-tile--active) .cat-tile-icon {
    color: var(--c-brand);
    background: rgba(var(--c-brand-rgb), 0.10);
  }

  /* Active (current filter) — full brand fill; vestigial on home, ready for reuse */
  .cat-tile--active {
    border-color: var(--c-brand);
    background: var(--c-brand);
    box-shadow: 0 6px 22px rgba(var(--c-brand-rgb), 0.28);
  }
  .cat-tile--active .cat-tile-name { color: #fff; }
  .cat-tile--active .cat-tile-count { color: rgba(255, 255, 255, 0.78); }
  .cat-tile--active .cat-tile-icon {
    background: rgba(255, 255, 255, 0.18);
    color: #fff;
  }
  .cat-tile--active:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(var(--c-brand-rgb), 0.36); }
</style>

/* ── Layouts ───────────────────────────────────────────────────────────────
 * Each placement: m=motif, x/y=position % (x is inline-start, RTL-aware),
 * s=size px, r=rotation deg, t=tone (ink|red|flame), d=depth 1-3
 * (foreground→far: brighter+faster → fainter+slower), sm=hide on mobile,
 * k='spark' twinkles. Edges/corners are populated; the optical center is left
 * clear so headlines and content read cleanly over the field. */
type Spot = { m: string; x: number; y: number; s: number; r: number; t: 'ink' | 'red' | 'flame'; d: 1 | 2 | 3; sm?: boolean; k?: 'spark' }

const LAYOUTS: Record<string, Spot[]> = {
  /* Edge-anchored + mostly far (d2/d3) so the field stays a quiet ambient layer
     under the headline, the هـ watermark and the seal — the optical center is left
     fully clear. The old field (17 motifs, two foreground d1, a central kibbeh)
     competed with the copy; this is the calmer support layer. */
  hero: [
    { m: 'kettle',    x: 4,  y: 12, s: 60, r: -8, t: 'ink',   d: 2 },
    { m: 'airfryer',  x: 88, y: 10, s: 56, r: 10, t: 'ink',   d: 2 },
    { m: 'mixer',     x: 7,  y: 60, s: 50, r: 6,  t: 'ink',   d: 3, sm: true },
    { m: 'iron',      x: 87, y: 66, s: 52, r: 14, t: 'ink',   d: 3, sm: true },
    { m: 'whisk',     x: 33, y: 7,  s: 36, r: -8, t: 'ink',   d: 3, sm: true },
    { m: 'kibbeh',    x: 82, y: 88, s: 46, r: 0,  t: 'red',   d: 2, sm: true },
    { m: 'flame',     x: 92, y: 40, s: 32, r: -5, t: 'red',   d: 3, sm: true },
    { m: 'spark',     x: 14, y: 34, s: 20, r: 14, t: 'flame', d: 3, k: 'spark' },
    { m: 'spark',     x: 50, y: 5,  s: 16, r: 0,  t: 'flame', d: 3, k: 'spark' },
    { m: 'droplet',   x: 12, y: 84, s: 26, r: -6, t: 'flame', d: 3, k: 'spark', sm: true },
    { m: 'star',      x: 70, y: 90, s: 22, r: 0,  t: 'flame', d: 3, k: 'spark', sm: true },
  ],
  band: [
    { m: 'kettle',    x: 4,  y: 22, s: 50, r: -8, t: 'ink',   d: 2 },
    { m: 'whisk',     x: 17, y: 62, s: 34, r: 8,  t: 'ink',   d: 3, sm: true },
    { m: 'mixer',     x: 39, y: 16, s: 40, r: 6,  t: 'ink',   d: 3, sm: true },
    { m: 'flame',     x: 60, y: 66, s: 32, r: -5, t: 'red',   d: 3, sm: true },
    { m: 'airfryer',  x: 83, y: 22, s: 46, r: 10, t: 'ink',   d: 2 },
    { m: 'wheat',     x: 92, y: 60, s: 32, r: 4,  t: 'flame', d: 3, sm: true },
    { m: 'spark',     x: 30, y: 82, s: 18, r: 0,  t: 'flame', d: 3, k: 'spark' },
    { m: 'star',      x: 71, y: 18, s: 22, r: 0,  t: 'flame', d: 3, k: 'spark', sm: true },
  ],
  drawer: [
    { m: 'dial',   x: 52,  y: 4,  s: 120, r: 0, t: 'red',  d: 2 },
    { m: 'dial',   x: -14, y: 60, s: 150, r: 0, t: 'red',  d: 3 },
    { m: 'kibbeh', x: 30,  y: 80, s: 96,  r: 0, t: 'red',  d: 1 },
    { m: 'whisk',  x: 60,  y: 40, s: 50,  r: 8, t: 'ink',  d: 3 },
    { m: 'kettle', x: 8,   y: 26, s: 56,  r: -8, t: 'ink', d: 3 },

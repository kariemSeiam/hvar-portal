---
/*
 * Wilson P1 — Appliance Doodle Field (reusable)
 * The single source of truth for Hvar's ambient doodle background.
 *
 * Drop into any `position:relative; overflow:hidden` section:
 *   <Doodles />                          → rich hero scatter
 *   <Doodles variant="band" />           → lighter strip (footers, CTA bands)
 *   <Doodles variant="drawer" opacity={0.6} />  → narrow vertical (nav drawer)
 *
 * WHY a component, not inline SVG: doodles live on nearly every page. Inlining
 * meant 5 divergent copies, hardcoded colors that ignored dark mode, and motifs
 * colliding in one cramped viewBox. Here each motif is its own positioned SVG —
 * theme-aware via tokens, individually animated, spaced with the center kept
 * clear for content. Motion + color follow compass/portal/design-system.md.
 */

interface Props {
  /** Layout preset. `hero` = full rich scatter, `band` = lighter strip, `drawer` = narrow vertical. */
  variant?: 'hero' | 'band' | 'drawer'
  /** Master opacity multiplier on the whole field (0–1). */
  opacity?: number
  class?: string
}

const { variant = 'hero', opacity = 1, class: className = '' } = Astro.props

/* ── Motif library ─────────────────────────────────────────────────────────
 * Every motif is authored in a normalized 0 0 48 48 viewBox.
 * Strokes inherit `currentColor` from the parent <svg> (set by tone class).
 * `.da` elements are flame accent dots regardless of tone. */

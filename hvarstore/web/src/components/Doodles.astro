const items = LAYOUTS[variant] ?? LAYOUTS.hero
---

<div class={`doodle-field ${className}`} style={`opacity:${opacity}`} aria-hidden="true">
  {items.map((it, i) => (
    <svg
      class:list={['dood', `dood--${it.t}`, `dood--d${it.d}`, { 'dood--sm-hide': it.sm, 'dood--spark': it.k === 'spark' }]}
      style={`--x:${it.x}%;--y:${it.y}%;--s:${it.s}px;--r:${it.r}deg;--i:${i}`}
      viewBox="0 0 48 48"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <Fragment set:html={MOTIFS[it.m]} />
    </svg>
  ))}
</div>

<style>
  /* ── Field ─────────────────────────────────────────────────────────────── */
  .doodle-field {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
    user-select: none;
    /* Warm brown ink in light; ivory in dark — the third tone alongside red + flame */
    --doodle-ink: #5a3a2c;
  }
  :global(html.dark) .doodle-field { --doodle-ink: #efe7db; }

  /* ── Motif ─────────────────────────────────────────────────────────────── */
  .dood {
    position: absolute;
    inset-block-start: var(--y);
    inset-inline-start: var(--x);
    width: var(--s);
    height: var(--s);
    transform: rotate(var(--r));
  }

  /* Tone — all theme-aware tokens, never hardcoded */
  .dood--ink   { color: var(--doodle-ink); }
  .dood--red   { color: var(--c-brand); }
  .dood--flame { color: var(--c-flame-bright); }

  /* Flame accent dots, regardless of motif tone */
  .dood :global(.da) { fill: var(--c-flame-bright); stroke: none; }

  /* Depth — spatial layering via opacity */
  .dood--d1 { opacity: 0.22; }
  .dood--d2 { opacity: 0.16; }
  .dood--d3 { opacity: 0.11; }
  :global(html.dark) .doodle-field .dood--d1 { opacity: 0.26; }
  :global(html.dark) .doodle-field .dood--d2 { opacity: 0.19; }
  :global(html.dark) .doodle-field .dood--d3 { opacity: 0.13; }
  .dood--spark { opacity: 0.20; }

  /* ── Motion — gentle native drift + sparkle twinkle ────────────────────── */
  @media (prefers-reduced-motion: no-preference) {
    .dood {
      will-change: transform;
      animation: dood-drift var(--dur, 30s) ease-in-out infinite alternate;
      animation-delay: calc(var(--i, 0) * -2.7s);
    }
    /* Depth drives speed + travel — far motifs drift slower and less */
    .dood--d1 { --dur: 26s; --dy: -16px; --dr: 3deg; }
    .dood--d2 { --dur: 32s; --dy: -12px; --dr: -4deg; }
    .dood--d3 { --dur: 38s; --dy: -9px;  --dr: 5deg; }

    .dood--spark {
      animation:
        dood-drift var(--dur, 38s) ease-in-out infinite alternate,
        dood-twinkle 6s ease-in-out infinite;
      animation-delay: calc(var(--i, 0) * -2.7s), calc(var(--i, 0) * -1.3s);
    }
  }

  @keyframes dood-drift {
    from { transform: translate3d(0, 0, 0) rotate(var(--r)); }
    to   { transform: translate3d(var(--dx, 0px), var(--dy, -12px), 0) rotate(calc(var(--r) + var(--dr, 4deg))); }
  }
  @keyframes dood-twinkle {
    0%, 100% { opacity: 0.10; }
    50%      { opacity: 0.28; }
  }

  /* ── Mobile declutter — drop the dense edge/far motifs ─────────────────── */
  @media (max-width: 640px) {
    .dood--sm-hide { display: none; }
  }
</style>

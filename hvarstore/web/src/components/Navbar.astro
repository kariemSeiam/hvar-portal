<script>
  const toggle   = document.getElementById('nav-toggle')!
  const closeBtn = document.getElementById('nav-close')!
  const drawer   = document.getElementById('nav-drawer')!
  const backdrop = document.getElementById('nav-backdrop')!
  const links    = document.querySelectorAll<HTMLElement>('.drawer-link')

  /* initial stagger state — enter from the left (drawer origin) */
  links.forEach((l) => {
    l.style.opacity   = '0'
    l.style.transform = 'translateX(-12px)'
    l.style.transition =
      `opacity 0.3s cubic-bezier(0.22,1,0.36,1) var(--dl,0ms),
       transform 0.3s cubic-bezier(0.22,1,0.36,1) var(--dl,0ms),
       background-color 0.2s, color 0.15s`
  })

  function open() {
    drawer.style.transform = 'perspective(1200px) rotateY(0deg) translateX(0)'
    drawer.setAttribute('aria-hidden', 'false')
    backdrop.style.opacity       = '1'
    backdrop.style.pointerEvents = 'auto'
    toggle.setAttribute('aria-expanded', 'true')
    document.body.style.overflow = 'hidden'
    links.forEach((l, i) => {
      setTimeout(() => {
        l.style.opacity   = '1'
        l.style.transform = 'translateX(0)'
      }, 50 + i * 38)
    })
  }

  function close() {
    drawer.style.transform = 'perspective(1200px) rotateY(-12deg) translateX(-110%)'
    drawer.setAttribute('aria-hidden', 'true')
    backdrop.style.opacity       = '0'
    backdrop.style.pointerEvents = 'none'
    toggle.setAttribute('aria-expanded', 'false')
    document.body.style.overflow = ''
    links.forEach((l) => {
      l.style.opacity   = '0'
      l.style.transform = 'translateX(-12px)'
    })
    collapseGroups()
  }

  toggle.addEventListener('click', open)
  closeBtn.addEventListener('click', close)
  backdrop.addEventListener('click', close)
  document.querySelectorAll('#nav-drawer a').forEach((a) => a.addEventListener('click', close))
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close() })

  // Drawer theme toggle — mirrors ThemeToggle.tsx behaviour
  const themeBtn  = document.getElementById('drawer-theme')!
  const iconMoon  = document.getElementById('drawer-icon-moon') as HTMLElement
  const iconSun   = document.getElementById('drawer-icon-sun')  as HTMLElement

  function syncThemeIcon() {
    const isDark = document.documentElement.classList.contains('dark')
    iconMoon.style.display = isDark ? 'none'  : 'block'
    iconSun.style.display  = isDark ? 'block' : 'none'
  }
  syncThemeIcon()

  themeBtn.addEventListener('click', () => {
    const isDark = document.documentElement.classList.contains('dark')
    document.documentElement.classList.toggle('dark', !isDark)
    localStorage.setItem('hvar-theme', isDark ? 'light' : 'dark')
    syncThemeIcon()
  })

  /* ── Mobile drawer: المنتجات category accordion (measured-height expand) ── */
  function collapseGroups() {
    document.querySelectorAll<HTMLElement>('.drawer-group.is-open').forEach((g) => {
      g.classList.remove('is-open')
      const sub = g.querySelector<HTMLElement>('[data-drawer-sub]')
      const tgl = g.querySelector<HTMLElement>('[data-drawer-toggle]')
      if (sub) sub.style.maxHeight = '0px'
      tgl?.setAttribute('aria-expanded', 'false')
    })
  }

  document.querySelectorAll<HTMLElement>('[data-drawer-toggle]').forEach((btn) => {
    const group = btn.closest('.drawer-group')
    const sub   = group?.querySelector<HTMLElement>('[data-drawer-sub]')
    if (!group || !sub) return
    btn.addEventListener('click', () => {
      const willOpen = !group.classList.contains('is-open')
      group.classList.toggle('is-open', willOpen)
      btn.setAttribute('aria-expanded', String(willOpen))
      sub.style.maxHeight = willOpen ? `${sub.scrollHeight}px` : '0px'
    })
  })

  /* ── Desktop المنتجات dropdown: reflect open state + Escape to dismiss.
     Open/close visuals are CSS (:hover / :focus-within); this only mirrors
     aria-expanded and gives keyboard users an exit. ── */
  document.querySelectorAll<HTMLElement>('[data-nav-dd]').forEach((dd) => {
    const trigger = dd.querySelector<HTMLElement>('[data-nav-dd-trigger]')
    if (!trigger) return
    const reflect = (open: boolean) => trigger.setAttribute('aria-expanded', String(open))
    dd.addEventListener('mouseenter', () => reflect(true))
    dd.addEventListener('mouseleave', () => reflect(false))
    dd.addEventListener('focusin',  () => reflect(true))
    dd.addEventListener('focusout', (e) => {
      if (!dd.contains(e.relatedTarget as Node)) reflect(false)
    })
    dd.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { reflect(false); trigger.blur() }
    })
  })
</script>


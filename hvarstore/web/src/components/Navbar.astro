---
import CartBadge from './cart/CartBadge'
import ThemeToggle from './ThemeToggle'

const path = Astro.url.pathname
const links = [
  { href: '/', label: 'البيت' },
  { href: '/products', label: 'المنتجات' },
  { href: '/contact', label: 'تواصل معنا' },
]
---

<header class="sticky top-0 z-50 backdrop-blur-md" style="background-color:color-mix(in srgb,var(--c-surface-2) 96%,transparent);border-bottom:1px solid var(--c-border)">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-0.5 select-none flex-shrink-0">
        <span class="text-[#d43533] font-cairo font-black text-[1.6rem] leading-none">هفار</span>
        <span class="text-stone-400 dark:text-stone-500 font-cairo text-[0.8rem] mt-1">ستور</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1">
        {links.map((l) => (
          <a
            href={l.href}
            class={`px-3 py-2 rounded-lg text-sm font-semibold font-cairo transition-colors ${
              path === l.href
                ? 'active-link'
                : 'nav-link'
            }`}
          >
            {l.label}
          </a>
        ))}
      </nav>

      <!-- Actions -->
      <div class="flex items-center gap-1">
        <CartBadge client:load />
        <a
          href="/login"
          class="hidden sm:flex items-center gap-1 px-3 py-1.5 rounded-lg text-sm font-semibold font-cairo transition-colors nav-link"
        >
          دخول
        </a>
        <ThemeToggle client:load />

        <!-- Mobile hamburger -->
        <button
          id="nav-toggle"
          class="md:hidden flex items-center justify-center w-9 h-9 rounded-full transition-colors nav-link"
          aria-label="القائمة"
          aria-expanded="false"
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <line x1="1" y1="4" x2="17" y2="4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="1" y1="9" x2="17" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="1" y1="14" x2="17" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

    </div>
  </div>
</header>

<!-- Mobile drawer overlay -->
<div id="nav-backdrop" class="fixed inset-0 z-40 bg-black/25 backdrop-blur-sm hidden"></div>

<!-- Mobile drawer panel (Wilson P5: 3D door-swing RTL) -->
<div
  id="nav-drawer"
  class="fixed top-0 right-0 z-50 h-full w-72 shadow-2xl"
  style="background-color:var(--c-surface-2)"
  style="transform: perspective(1200px) rotateY(12deg) translateX(100%); transition: transform 0.4s cubic-bezier(0.22,1,0.36,1);"
  aria-hidden="true"
>
  <!-- Doodle overlay (very subtle) -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none overflow-hidden">
    <svg width="100%" height="100%" viewBox="0 0 288 640" fill="none">
      <circle cx="240" cy="120" r="60" stroke="#d43533" stroke-width="1"/>
      <circle cx="240" cy="120" r="40" stroke="#d43533" stroke-width="0.5"/>
      <circle cx="48" cy="400" r="80" stroke="#d43533" stroke-width="1"/>
      <circle cx="48" cy="400" r="55" stroke="#d43533" stroke-width="0.5"/>
      <line x1="144" y1="0" x2="144" y2="640" stroke="#d43533" stroke-width="0.5" stroke-dasharray="4 8"/>
    </svg>
  </div>

  <div class="relative z-10 p-6 h-full flex flex-col">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <a href="/" class="font-cairo font-black text-2xl" style="color:var(--c-brand)">هفار ستور</a>
      <button
        id="nav-close"
        class="w-8 h-8 flex items-center justify-center rounded-full transition-colors text-sm"
        style="background-color:var(--c-border);color:var(--c-ink-muted)"
        aria-label="إغلاق القائمة"
      >
        ✕
      </button>
    </div>

    <!-- Nav links (Wilson P13: staggered) -->
    <nav class="flex flex-col gap-1" id="drawer-links">
      {links.map((l, i) => (
        <a
          href={l.href}
          class="drawer-link block px-4 py-3 rounded-xl font-cairo font-semibold text-lg transition-all" style="color:var(--c-ink)"
          style={`transition-delay: ${(i + 1) * 50}ms`}
        >
          {l.label}
        </a>
      ))}
      <a
        href="/login"
        class="drawer-link block px-4 py-3 rounded-xl font-cairo font-semibold text-lg transition-all mt-2 pt-4" style="color:var(--c-ink);border-top:1px solid var(--c-border)"
        style="transition-delay: 200ms"
      >
        تسجيل الدخول
      </a>
    </nav>

    <!-- Footer trust -->
    <div class="mt-auto pt-6 border-t border-stone-100 dark:border-stone-800">
      <p class="text-xs font-cairo text-center" style="color:var(--c-ink-faint)">
        ضمان · شحن مجاني · دفع عند الاستلام
      </p>
    </div>
  </div>
</div>

<script>
  const toggle = document.getElementById('nav-toggle')
  const closeBtn = document.getElementById('nav-close')
  const drawer = document.getElementById('nav-drawer')
  const backdrop = document.getElementById('nav-backdrop')
  const links = document.querySelectorAll('.drawer-link')

  function openDrawer() {
    drawer!.style.transform = 'perspective(1200px) rotateY(0deg) translateX(0)'
    drawer!.setAttribute('aria-hidden', 'false')
    backdrop!.classList.remove('hidden')
    toggle!.setAttribute('aria-expanded', 'true')
    document.body.style.overflow = 'hidden'
    links.forEach((l) => {
      ;(l as HTMLElement).style.opacity = '1'
      ;(l as HTMLElement).style.transform = 'translateX(0)'
    })
  }

  function closeDrawer() {
    drawer!.style.transform = 'perspective(1200px) rotateY(12deg) translateX(100%)'
    drawer!.setAttribute('aria-hidden', 'true')
    backdrop!.classList.add('hidden')
    toggle!.setAttribute('aria-expanded', 'false')
    document.body.style.overflow = ''
    links.forEach((l) => {
      ;(l as HTMLElement).style.opacity = '0'
      ;(l as HTMLElement).style.transform = 'translateX(16px)'
    })
  }

  // Initial hidden state for stagger
  links.forEach((l) => {
    ;(l as HTMLElement).style.opacity = '0'
    ;(l as HTMLElement).style.transform = 'translateX(16px)'
    ;(l as HTMLElement).style.transition = 'opacity 0.3s cubic-bezier(0.22,1,0.36,1), transform 0.3s cubic-bezier(0.22,1,0.36,1), background-color 0.2s'
  })

  toggle?.addEventListener('click', openDrawer)
  closeBtn?.addEventListener('click', closeDrawer)
  backdrop?.addEventListener('click', closeDrawer)

  document.querySelectorAll('#nav-drawer a').forEach((a) =>
    a.addEventListener('click', closeDrawer),
  )
</script>

---
import Base from '../layouts/Base.astro'
import CheckoutForm from '../components/checkout/CheckoutForm'
import InnerHero from '../components/InnerHero.astro'
---

<Base title="إتمام الطلب | هفار">

  <InnerHero
    label="خطوة أخيرة"
    title="إتمام الشراء"
    subtitle="أدخل بياناتك — هنوصلك المنتج لباب البيت مجاناً"
    variant="service"
    cta={{ label: "السلة", href: "/cart" }}
  />

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <CheckoutForm client:load />
  </div>

</Base>

---
import Base from '../layouts/Base.astro'
import AuthForm from '../components/auth/AuthForm'
---

<Base title="دخول وتسجيل | هفار">

  <div class="login-page">
    {/* Ambient brand canvas — quiet warmth + dot grid so the space reads
        intentional on big screens instead of a lone card in a white void. */}
    <div class="login-ambient" aria-hidden="true"></div>

    <div class="login-col">

      <AuthForm client:load />

      <p class="login-terms">
        بالدخول أو التسجيل أنت توافق على
        <a href="/terms" class="login-terms-link">الشروط والأحكام</a>
        وسياسة الخصوصية الخاصة بهفار.
      </p>

    </div>
  </div>

</Base>

<style is:global>
  /* In-place beat transition for the AuthForm island (phone → name) */
  @keyframes authBeat {
    from { opacity: 0; transform: translateY(7px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .auth-beat { animation: authBeat 0.34s cubic-bezier(0.22, 1, 0.36, 1) both; }
</style>

<style>
  .login-page {
    position: relative;
    min-height: calc(100svh - 3.5rem);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.75rem 1.5rem 2.5rem;
    overflow: hidden;
    background-color: var(--c-bg);
  }
  @media (min-width: 768px) {
    .login-page {
      min-height: calc(100svh - 4rem);
      padding: 3rem 2.5rem;
    }
  }

  .login-ambient {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image:
      radial-gradient(ellipse 75% 48% at 50% 0%, rgba(var(--c-brand-rgb), 0.07), transparent 62%),
      radial-gradient(circle, var(--c-border) 1px, transparent 1px);
    background-size: auto, 30px 30px;
    background-position: center, center;
    -webkit-mask-image: radial-gradient(ellipse 90% 80% at 50% 40%, #000 55%, transparent 100%);
            mask-image: radial-gradient(ellipse 90% 80% at 50% 40%, #000 55%, transparent 100%);
  }

  .login-col {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 23rem;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 1.75rem;
  }

  .login-terms {
    text-align: center;
    font-family: "Cairo", system-ui, sans-serif;
    font-size: 0.75rem;
    line-height: 1.7;
    color: var(--c-ink-faint);
    margin: 0;
  }
  .login-terms-link {
    color: var(--c-ink-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }
  .login-terms-link:hover { color: var(--c-brand); }
</style>

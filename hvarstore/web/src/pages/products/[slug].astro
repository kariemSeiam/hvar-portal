---
import Base from '../../layouts/Base.astro'
import CtaActionBar from '../../components/pdp/CtaActionBar'
import ProductCard from '../../components/ProductCard.astro'
import { api } from '../../lib/api'

const { slug } = Astro.params

if (!slug) return Astro.redirect('/products')

let product
try {
  product = await api.products.get(slug)
} catch {
  return Astro.redirect('/products')
}

// Related: same category, excluding current
let related: Awaited<ReturnType<typeof api.products.list>>['items'] = []
try {
  const r = await api.products.list({
    category: product.categoryId ?? undefined,
    in_stock: undefined,
    limit: 5,
    offset: 0,
  })
  related = r.items.filter((p) => p.id !== product.id).slice(0, 4)
} catch {
  /* related is optional */
}

const hasDiscount = product.comparePrice !== null && product.comparePrice > product.price
const discountPct = hasDiscount
  ? Math.round(((product.comparePrice! - product.price) / product.comparePrice!) * 100)
  : 0
---

<Base
  title={`${product.name} — هفارستور`}
  description={product.description ?? `${product.name} — اشتر الآن من هفارستور`}
  image={product.image ?? undefined}
>

  <!-- Breadcrumb -->
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-5 pb-2" aria-label="مسار التنقل">
    <ol class="flex items-center gap-2 text-xs font-cairo text-[#57534e] dark:text-[#a8a29e]">
      <li><a href="/" class="hover:text-[#d43533] transition-colors">البيت</a></li>
      <li class="opacity-40">›</li>
      <li><a href="/products" class="hover:text-[#d43533] transition-colors">المنتجات</a></li>
      {product.categoryName && (
        <>
          <li class="opacity-40">›</li>
          <li>
            <a href={`/products?category=${product.categoryId}`} class="hover:text-[#d43533] transition-colors">
              {product.categoryName}
            </a>
          </li>
        </>
      )}
      <li class="opacity-40">›</li>
      <li class="text-[#1c1917] dark:text-[#f5f5f4] font-semibold truncate max-w-[180px]">{product.name}</li>
    </ol>
  </nav>

  <!-- PDP body -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">

      <!-- Gallery (Wilson P8: breath animation on single image) -->
      <div class="relative">
        <div class="sticky top-20">
          <div class="relative aspect-square rounded-2xl overflow-hidden bg-[#fbf7f1] dark:bg-[#1c1917] border border-[#e7e0d6] dark:border-[#2c2825]">
            {product.image ? (
              <img
                src={product.image}
                alt={product.name}
                class="w-full h-full object-cover pdp-breath"
                loading="eager"
                decoding="async"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-red-50 to-stone-100 dark:from-red-950/20 dark:to-stone-900">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#d43533" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round" opacity="0.25">
                  <path d="M13 2L4.5 13H11l-1 9L21 11H14l1-9Z"/>
                </svg>
              </div>
            )}

            <!-- Discount badge -->
            {hasDiscount && (
              <span class="absolute top-4 right-4 px-3 py-1 rounded-xl bg-[#d43533] text-white text-sm font-bold font-inter shadow-lg">
                -{discountPct}%
              </span>
            )}
          </div>

          <!-- SKU (for reference) -->
          <p class="mt-3 text-center font-mono text-xs text-stone-400 dark:text-stone-600">
            {product.sku}
          </p>
        </div>
      </div>

      <!-- Product info -->
      <div class="space-y-6">

        <!-- Category + name -->
        {product.categoryName && (
          <a
            href={`/products?category=${product.categoryId}`}
            class="inline-block text-xs font-cairo font-semibold text-[#d43533] bg-red-50 dark:bg-red-950/20 px-3 py-1 rounded-full hover:bg-red-100 dark:hover:bg-red-950/40 transition-colors"
          >
            {product.categoryName}
          </a>
        )}

        <h1 class="font-cairo font-black text-2xl sm:text-3xl text-[#1c1917] dark:text-[#f5f5f4] leading-snug">
          {product.name}
        </h1>

        <!-- CTA action bar (React island: qty + variation + add + WhatsApp) -->
        <CtaActionBar product={product} client:load />

        <!-- Description accordion -->
        {product.description && (
          <details class="group border border-[#e7e0d6] dark:border-[#2c2825] rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer font-cairo font-bold text-sm text-[#1c1917] dark:text-[#f5f5f4] select-none hover:bg-stone-50 dark:hover:bg-stone-900/30 transition-colors list-none">
              <span>وصف المنتج</span>
              <svg class="w-4 h-4 text-stone-400 transition-transform group-open:rotate-180" viewBox="0 0 16 16" fill="none">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <div class="px-5 pb-5 pt-2 font-cairo text-sm text-[#57534e] dark:text-[#a8a29e] leading-relaxed">
              {product.description}
            </div>
          </details>
        )}

        <!-- Weight/specs if available -->
        {product.weight && (
          <details class="group border border-[#e7e0d6] dark:border-[#2c2825] rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer font-cairo font-bold text-sm text-[#1c1917] dark:text-[#f5f5f4] select-none hover:bg-stone-50 dark:hover:bg-stone-900/30 transition-colors list-none">
              <span>المواصفات</span>
              <svg class="w-4 h-4 text-stone-400 transition-transform group-open:rotate-180" viewBox="0 0 16 16" fill="none">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <div class="px-5 pb-5 pt-2">
              <table class="w-full text-sm font-cairo">
                <tr class="border-b border-[#e7e0d6] dark:border-[#2c2825]">
                  <td class="py-2 text-[#57534e] dark:text-[#a8a29e]">الوزن</td>
                  <td class="py-2 text-[#1c1917] dark:text-[#f5f5f4] font-semibold text-end">{product.weight} كجم</td>
                </tr>
                <tr>
                  <td class="py-2 text-[#57534e] dark:text-[#a8a29e]">كود المنتج</td>
                  <td class="py-2 text-[#1c1917] dark:text-[#f5f5f4] font-mono text-xs text-end">{product.sku}</td>
                </tr>
              </table>
            </div>
          </details>
        )}

      </div>
    </div>

    <!-- Related products -->
    {related.length > 0 && (
      <section class="mt-16 reveal-section">
        <h2 class="font-cairo font-bold text-lg text-[#1c1917] dark:text-[#f5f5f4] mb-6">
          منتجات مشابهة
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {related.map((p) => (
            <div class="reveal-child">
              <ProductCard product={p} />
            </div>
          ))}
        </div>
      </section>
    )}

  </div>

</Base>

<style>
  /* Wilson P8: breath animation on product image */
  @keyframes pdp-breath {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.018); }
  }
  .pdp-breath {
    animation: pdp-breath 20s ease-in-out infinite;
    transform-origin: center center;
  }
  @media (prefers-reduced-motion: reduce) {
    .pdp-breath { animation: none; }
  }
</style>

---
import Base from '../../layouts/Base.astro'
import CtaActionBar from '../../components/pdp/CtaActionBar'
import ProductCard from '../../components/ProductCard.astro'
import WarrantyCallout from '../../components/pdp/WarrantyCallout.astro'
import ChefSection from '../../components/pdp/ChefSection.astro'
import FaqSection from '../../components/pdp/FaqSection.astro'
import SpecsSection from '../../components/pdp/SpecsSection.astro'
import AccessoriesGrid from '../../components/pdp/AccessoriesGrid.astro'
import ComparisonNudge from '../../components/pdp/ComparisonNudge.astro'
import ApplianceIcon from '../../components/icons/ApplianceIcon.astro'
import ColorFamilySwatches from '../../components/pdp/ColorFamilySwatches.astro'
import { api } from '../../lib/api'
import { getEnrichment, getWarrantyText } from '../../lib/enrichment'

const { slug } = Astro.params

if (!slug) return Astro.redirect('/products')

let product
try {
  product = await api.products.get(slug)
} catch {
  return Astro.redirect('/products')
}

/* Related: same category, fetch 8 → filter self → take 4 */
let related: Awaited<ReturnType<typeof api.products.list>>['items'] = []
try {
  const r = await api.products.list({
    category: product.categoryId ?? undefined,
    in_stock: undefined,
    limit: 8,
    offset: 0,
  })
  related = r.items.filter((p) => p.id !== product.id).slice(0, 4)
} catch {
  /* related is optional */
}

const hasDiscount = product.comparePrice !== null && product.comparePrice > product.price
const discountPct = hasDiscount
  ? Math.round(((product.comparePrice! - product.price) / product.comparePrice!) * 100)
  : 0

const descriptionFallback = `منتج هفار. شحن مجاني لجميع المحافظات.`
const displayDescription = product.description || descriptionFallback

const enrichment = getEnrichment(product.sku)
const comparisonGroupKey = enrichment?.comparisonGroup ?? null
const warrantyText = getWarrantyText(product.sku)

/* ── Color family (e.g. 5070 shell variants) — map variant SKUs to live PDPs ── */
let familySwatches: Array<{ sku: string; nameAr: string; hex: string; slug: string | null; current: boolean }> = []
const variants = enrichment?.colorVariants ?? []
if (variants.length > 0 && variants.some((v) => v.sku === product.sku)) {
  try {
    // Shortest variant SKU is the family base (e.g. "5070") — one LIKE query finds all siblings
    const baseSku = variants.reduce((a, b) => (a.sku.length <= b.sku.length ? a : b)).sku
    const fam = await api.products.list({ q: baseSku, limit: 20 })
    const bySku = new Map(fam.items.map((p) => [p.sku, p.slug]))
    familySwatches = variants.map((v) => ({
      ...v,
      slug: bySku.get(v.sku) ?? null,
      current: v.sku === product.sku,
    }))
  } catch {
    /* swatches are progressive enhancement — PDP renders without them */
  }
}

/* ── JSON-LD ── */
const productJsonld = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.name,
  description: product.description ?? descriptionFallback,
  sku: product.sku,
  image: product.image ?? undefined,
  category: product.categoryName ?? undefined,
  offers: {
    "@type": "Offer",
    price: product.price,
    priceCurrency: "EGP",
    availability: product.stock > 0
      ? "https://schema.org/InStock"
      : "https://schema.org/OutOfStock",
    url: `https://hvarstore.com/products/${product.slug}`,
    itemCondition: "https://schema.org/NewCondition",
    ...(hasDiscount && {
      priceSpecification: {
        "@type": "UnitPriceSpecification",
        price: product.comparePrice,
        priceCurrency: "EGP",
      },
    }),
  },
})

const breadcrumbJsonld = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "البيت", item: "https://hvarstore.com/" },
    { "@type": "ListItem", position: 2, name: "المنتجات", item: "https://hvarstore.com/products" },
    ...(product.categoryName && product.categoryId != null
      ? [{ "@type": "ListItem", position: 3, name: product.categoryName, item: `https://hvarstore.com/products?category=${product.categoryId}` }]
      : []),
    { "@type": "ListItem", position: 4, name: product.name, item: `https://hvarstore.com/products/${product.slug}` },
  ],
})
---

<Base
  title={`${product.name} — سعر ومواصفات | هفار`}
  description={product.description ?? `${product.name} من هفار. شحن مجاني لجميع المحافظات، وافحص قبل الدفع.`}
  image={product.image ?? undefined}
  noBottomNav
  jsonld={[productJsonld, breadcrumbJsonld]}
>

  <!-- Breadcrumb (RTL-correct separator ‹) -->
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-5 pb-2" aria-label="مسار التنقل">
    <ol class="flex items-center flex-wrap gap-1.5 text-xs font-cairo" style="color:var(--c-ink-muted)">
      <li><a href="/" class="transition-colors hover:text-[var(--c-brand)]">البيت</a></li>
      <li aria-hidden="true" class="opacity-40 select-none">‹</li>
      <li><a href="/products" class="transition-colors hover:text-[var(--c-brand)]">المنتجات</a></li>
      {product.categoryName && product.categoryId != null && (
        <>
          <li aria-hidden="true" class="opacity-40 select-none">‹</li>
          <li>
            <a href={`/products?category=${product.categoryId}`} class="transition-colors hover:text-[var(--c-brand)]">
              {product.categoryName}
            </a>
          </li>
        </>
      )}
      <li aria-hidden="true" class="opacity-40 select-none">‹</li>
      <li class="font-semibold truncate max-w-[180px]" style="color:var(--c-ink)">{product.name}</li>
    </ol>
  </nav>

  <!-- PDP body -->
  <main class="pdp-root max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">

      <!-- Gallery -->
      <div class="relative">
        <div class="sticky top-[68px]">

          <!-- Image frame -->
          <div class="pdp-frame grain-overlay">
            <!-- P4 red mesh glow -->
            <div class="pdp-mesh" aria-hidden="true"></div>

            {product.image ? (
              <img
                src={product.image}
                alt={product.name}
                class="pdp-img"
                loading="eager"
                decoding="async"
                width="800"
                height="800"
              />
            ) : (
              <div
                class="w-full h-full flex items-center justify-center relative"
                style="background:linear-gradient(135deg,var(--c-brand-tint),var(--c-bg))"
              >
                <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none" aria-hidden="true">
                  <svg width="80%" height="80%" viewBox="0 0 200 200" fill="none" opacity="0.08">
                    <circle cx="100" cy="100" r="80" stroke="var(--c-brand)" stroke-width="1" stroke-dasharray="6 8"/>
                    <circle cx="100" cy="100" r="58" stroke="var(--c-brand)" stroke-width="0.8"/>
                  </svg>
                </div>
                <ApplianceIcon name={product.name} class="pdp-ph-icon" />
                <span class="absolute z-10 font-cairo font-black select-none" style="inset-block-end:1.25rem;inset-inline-start:1.5rem;font-size:1.75rem;line-height:1;color:var(--c-brand);opacity:0.14">هـ</span>
              </div>
            )}

            <!-- Discount badge -->
            {hasDiscount && (
              <span class="pdp-discount">-{discountPct}%</span>
            )}

            <!-- Bottom trust strip overlaid on image -->
            <div class="pdp-trust-strip">
              <span class="pdp-trust-chip">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  <polyline points="9 12 11 14 15 10"/>
                </svg>
                {warrantyText}
              </span>
              <span class="pdp-trust-div" aria-hidden="true"></span>
              <span class="pdp-trust-chip">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="1" y="3" width="15" height="13" rx="1"/>
                  <path d="M16 8h4l3 5v3h-7V8z"/>
                  <circle cx="5.5" cy="18.5" r="2.5"/>
                  <circle cx="18.5" cy="18.5" r="2.5"/>
                </svg>
                شحن مجاني
              </span>
              <span class="pdp-trust-div" aria-hidden="true"></span>
              <span class="pdp-trust-chip">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="5" width="20" height="14" rx="2"/>
                  <line x1="2" y1="10" x2="22" y2="10"/>
                  <path d="M7 15h2m6 0h2"/>
                </svg>
                ادفع لما يوصل
              </span>
            </div>
          </div>

          <!-- Share + SKU row -->
          <div class="mt-3 flex items-center justify-between px-1">
            <p class="font-mono text-xs" style="color:var(--c-ink-faint)">{product.sku}</p>
            <button
              id="share-btn"
              class="flex items-center gap-1.5 text-xs font-cairo transition-colors"
              style="color:var(--c-ink-muted)"
              aria-label="مشاركة المنتج"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
              </svg>
              مشاركة
            </button>
          </div>
        </div>
      </div>

      <!-- Product info -->
      <div class="pdp-info-col">

        <!-- a. Category pill -->
        {product.categoryName && product.categoryId != null && (
          <a
            href={`/products?category=${product.categoryId}`}
            class="pdp-cat-pill"
          >
            {product.categoryName}
          </a>
        )}

        <!-- b. H1 -->
        <h1 class="pdp-h1">{product.name}</h1>

        <!-- c. Wattage statement -->
        {enrichment?.wattage && (
          <div>
            <p class="pdp-wattage">
              {enrichment.wattageDisplay ?? enrichment.wattage + " وات"}
            </p>
            {enrichment.keyClaim && (
              <p class="pdp-key-claim">{enrichment.keyClaim}</p>
            )}
          </div>
        )}

        <!-- d. Color family swatches (5070-style shell colors) -->
        {familySwatches.length > 0 && <ColorFamilySwatches swatches={familySwatches} />}

        <!-- e. CTA action bar (React island) -->
        <CtaActionBar product={product} client:load />

        <!-- e. Warranty callout -->
        <WarrantyCallout warrantyMonths={enrichment?.warrantyMonths ?? 12} bowlWarrantyYears={enrichment?.bowlWarrantyYears} />

        <!-- f. Key features list -->
        {enrichment?.keyFeatures && enrichment.keyFeatures.length > 0 && (
          <ul class="pdp-features">
            {enrichment.keyFeatures.map(f => (
              <li class="pdp-feature-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                     stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5" style="color:var(--c-brand)" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>
        )}

        <!-- g. Accessories grid -->
        <AccessoriesGrid accessories={enrichment?.accessories ?? []} />

        <!-- h. Specs section -->
        <SpecsSection sku={product.sku} weight={product.weight} enrichment={enrichment} />

        <!-- i. Description — plain visible text, not accordion -->
        {displayDescription && (
          <div>
            <h2 class="pdp-desc-label">وصف المنتج</h2>
            <p class="pdp-desc-text">{displayDescription}</p>
          </div>
        )}

        <!-- j. Chef section -->
        <ChefSection chefs={enrichment?.chefs ?? []} />

        <!-- k. FAQ section -->
        <FaqSection faq={enrichment?.faq ?? []} />

      </div>
    </div>

    <!-- ComparisonNudge — below 2-col grid, before related products -->
    {comparisonGroupKey && (
      <div class="mt-10">
        <ComparisonNudge currentSku={product.sku} groupKey={comparisonGroupKey} />
      </div>
    )}

    <!-- Related products -->
    {related.length > 0 && (
      <section class="mt-16 reveal-section">
        <h2 class="font-cairo font-bold text-lg mb-6" style="color:var(--c-ink)">
          من نفس التشكيلة
        </h2>
        <div class="pdp-related-scroll">
          {related.map((p) => (
            <div class="pdp-related-card reveal-child">
              <ProductCard product={p} />
            </div>
          ))}
        </div>
      </section>
    )}

  </main>

</Base>

<style>
  /* gallery */
  .pdp-frame { position: relative; aspect-ratio: 1/1; border-radius: var(--radius-lg); overflow: hidden; background: var(--c-bg); border: 1px solid var(--c-border); }
  .pdp-frame :global(.pdp-ph-icon) { position: relative; z-index: 2; width: clamp(7rem, 30vw, 12rem); height: clamp(7rem, 30vw, 12rem); color: var(--c-brand); opacity: 0.30; }
  .pdp-mesh { position: absolute; inset: 0; z-index: 1; pointer-events: none; background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(var(--c-brand-rgb),0.10) 0%, transparent 65%); }
  .dark .pdp-mesh { background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(var(--c-brand-rgb),0.16) 0%, transparent 65%); }
  .pdp-img { width:100%; height:100%; object-fit:contain; padding:1.5rem; display:block; position:relative; z-index:0; background: linear-gradient(160deg,#ffffff 0%,#faf6f0 100%); }
  @media (prefers-reduced-motion: no-preference) { .pdp-img { animation: pdp-breath 20s ease-in-out infinite; transform-origin: center; } }
  @keyframes pdp-breath { 0%,100%{transform:scale(1)} 50%{transform:scale(1.018)} }

  /* discount badge */
  .pdp-discount { position:absolute; top:0.875rem; inset-inline-end:0.875rem; z-index:4; padding:0.25rem 0.625rem; border-radius:var(--radius-sm); background:var(--c-brand); color:#fff; font-family:'Inter',sans-serif; font-weight:700; font-size:0.8125rem; line-height:1; box-shadow:0 2px 8px rgba(var(--c-brand-rgb),0.35); }

  /* trust strip at bottom of image */
  .pdp-trust-strip { position:absolute; bottom:0; inset-inline:0; z-index:4; display:flex; align-items:center; justify-content:center; padding:1.25rem 1rem 0.875rem; background:linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.58) 100%); }
  .pdp-trust-chip { display:flex; align-items:center; gap:0.3rem; font-family:'Cairo',sans-serif; font-weight:600; font-size:0.6875rem; color:rgba(255,255,255,0.93); white-space:nowrap; flex:1; justify-content:center; }
  .pdp-trust-div { width:1px; height:1rem; background:rgba(255,255,255,0.22); flex-shrink:0; }

  /* info col layout */
  .pdp-info-col { display:flex; flex-direction:column; gap:1.25rem; }
  .pdp-h1 { font-family:'Cairo',sans-serif; font-weight:900; font-size:clamp(1.375rem,4vw,1.875rem); line-height:1.25; color:var(--c-ink); margin:0; }
  .pdp-wattage { font-family:'Cairo',sans-serif; font-weight:900; font-size:clamp(2rem,5.5vw,3.5rem); line-height:1; color:var(--c-brand); letter-spacing:-0.02em; }
  .pdp-key-claim { font-family:'Cairo',sans-serif; font-size:0.8125rem; color:var(--c-ink-muted); margin:0.125rem 0 0; }
  .pdp-cat-pill { align-self:flex-start; display:inline-block; font-family:'Cairo',sans-serif; font-weight:600; font-size:0.75rem; padding:0.25rem 0.75rem; border-radius:9999px; color:var(--c-brand); background:var(--c-brand-tint); text-decoration:none; transition:background 0.2s; }
  .pdp-cat-pill:hover { background:rgba(var(--c-brand-rgb),0.14); }

  /* features grid */
  .pdp-features { list-style:none; padding:0; margin:0; display:grid; grid-template-columns:1fr 1fr; gap:0.625rem; }
  .pdp-feature-item { display:flex; align-items:flex-start; gap:0.5rem; font-family:'Cairo',sans-serif; font-size:0.8125rem; font-weight:600; color:var(--c-ink); line-height:1.4; }

  /* description */
  .pdp-desc-label { font-family:'Cairo',sans-serif; font-weight:700; font-size:0.875rem; color:var(--c-ink-secondary); margin:0 0 0.5rem; }
  .pdp-desc-text { font-family:'Cairo',sans-serif; font-size:0.875rem; line-height:1.85; color:var(--c-ink-muted); margin:0; }

  /* related scroll */
  @media (max-width:639px) {
    .pdp-related-scroll { display:flex; overflow-x:auto; -webkit-overflow-scrolling:touch; scrollbar-width:none; gap:0.875rem; padding-bottom:0.5rem; }
    .pdp-related-scroll::-webkit-scrollbar { display:none; }
    .pdp-related-card { min-width:min(200px,48vw); flex-shrink:0; }
  }
  @media (min-width:640px) { .pdp-related-scroll { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; } }
  @media (min-width:1024px) { .pdp-related-scroll { grid-template-columns:repeat(4,1fr); } }

  #share-btn:hover { color:var(--c-brand); }
  @media (prefers-reduced-motion:reduce) { .pdp-img { animation:none; } }
</style>

<script>
  /* Share button — Web Share API with clipboard fallback */
  const shareBtn = document.getElementById('share-btn')
  if (shareBtn) {
    shareBtn.addEventListener('click', async () => {
      try {
        if (navigator.share) {
          await navigator.share({ title: document.title, url: location.href })
        } else {
          await navigator.clipboard.writeText(location.href)
          shareBtn.textContent = 'تم النسخ ✓'
          setTimeout(() => (shareBtn.textContent = ''), 1800)
        }
      } catch {
        /* user cancelled share — ignore */
      }
    })
  }
</script>

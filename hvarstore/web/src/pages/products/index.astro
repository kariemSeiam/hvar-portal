---
import Base from '../../layouts/Base.astro'
import ProductCard from '../../components/ProductCard.astro'
import CategoryHero from '../../components/category/CategoryHero.astro'
import CategoryFilters from '../../components/category/CategoryFilters.astro'
import { api } from '../../lib/api'

const url = Astro.url
const categoryId = url.searchParams.get('category')
  ? Number(url.searchParams.get('category'))
  : undefined
const q = url.searchParams.get('q') ?? undefined
const minPrice = url.searchParams.get('min_price')
  ? Number(url.searchParams.get('min_price'))
  : undefined
const maxPrice = url.searchParams.get('max_price')
  ? Number(url.searchParams.get('max_price'))
  : undefined
const inStock = url.searchParams.get('in_stock') === '1'
const page = Math.max(1, Number(url.searchParams.get('page') ?? 1))
const limit = 24
const offset = (page - 1) * limit

const sortBy = url.searchParams.get('sort') ?? undefined
const priceRange = url.searchParams.get('price_range') ?? undefined

// Parse price_range into min/max for existing API call
let derivedMinPrice = minPrice
let derivedMaxPrice = maxPrice
if (priceRange) {
  if (priceRange === '2500+') { derivedMinPrice = 2500; derivedMaxPrice = undefined }
  else {
    const [lo, hi] = priceRange.split('-').map(Number)
    if (!isNaN(lo)) derivedMinPrice = lo
    if (!isNaN(hi)) derivedMaxPrice = hi
  }
}

const [productsResult, categoriesResult] = await Promise.allSettled([
  api.products.list({ category: categoryId, q, min_price: derivedMinPrice, max_price: derivedMaxPrice, in_stock: inStock || undefined, limit, offset }),
  api.categories(),
])

const products = productsResult.status === 'fulfilled' ? productsResult.value.items : []
const categories = categoriesResult.status === 'fulfilled'
  ? categoriesResult.value.items.filter((c) => c.productCount > 0)
  : []

const activeCategory = categories.find((c) => c.id === categoryId)
const pageTitle = activeCategory
  ? `${activeCategory.name} | هفار`
  : q
    ? `نتائج البحث: ${q} | هفار`
    : 'تسوق أجهزة المطبخ — خلاطات، قلايات، مكاوي | هفار'

function buildUrl(params: Record<string, string | number | undefined | null>) {
  const u = new URL(url)
  for (const [k, v] of Object.entries(params)) {
    if (v == null || v === '') u.searchParams.delete(k)
    else u.searchParams.set(k, String(v))
  }
  u.searchParams.delete('page')
  return u.pathname + u.search
}
---

<Base title={pageTitle}>

  {/* ── When a category is active: show hero + separate search bar ── */}
  {activeCategory && (
    <>
      <CategoryHero categoryName={activeCategory.name} productCount={products.length} />
      <div style="background-color:var(--c-surface);border-bottom:1px solid var(--c-border)">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
          <form method="GET" action="/products" class="flex flex-wrap items-center gap-3">
            <input type="hidden" name="category" value={String(categoryId)} />
            <div class="relative flex-1 min-w-[200px] max-w-sm">
              <input type="search" name="q" value={q ?? ''} placeholder={`ابحث في ${activeCategory.name}...`}
                class="hvar-input w-full pr-10 pl-4 py-2.5 rounded-xl text-sm font-cairo transition-colors"
                style="border-color:var(--c-border);background-color:var(--c-bg);color:var(--c-ink)" />
              <svg class="absolute top-1/2 right-3 -translate-y-1/2" width="15" height="15" viewBox="0 0 20 20" fill="none" style="color:var(--c-ink-muted)">
                <circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.5"/>
                <line x1="14" y1="14" x2="18" y2="18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            {q && (
              <a href={"/products?category=" + categoryId}
                 class="px-3 py-2.5 rounded-xl border text-sm font-cairo transition-colors"
                 style="border-color:var(--c-border);color:var(--c-ink-muted)">
                مسح البحث
              </a>
            )}
          </form>
        </div>
      </div>
    </>
  )}

  {/* ── No active category, no search query: dark brand banner ── */}
  {!activeCategory && !q && (
    <section class="relative overflow-hidden grain-overlay"
             style="background-color:#130F0C;border-bottom:1px solid rgba(245,239,230,0.08)">

      {/* Red ember glow — left side */}
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
           style="background:radial-gradient(ellipse 60% 80% at 0% 50%, rgba(var(--c-brand-rgb),0.10) 0%, transparent 65%)">
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-10">
        <div class="reveal-section flex items-end justify-between gap-4">

          {/* Left: heading block */}
          <div>
            <p class="reveal-child font-cairo font-semibold text-[10px] uppercase tracking-[0.14em] mb-2"
               style="color:#C8893B">
              أجهزة هفار
            </p>
            <h1 class="reveal-child font-cairo font-black leading-none"
                style="font-size:clamp(2rem,6vw,3.5rem);color:#F5EFE6;letter-spacing:-0.02em">
              كل المنتجات
            </h1>
            <p class="reveal-child font-cairo text-sm mt-2"
               style="color:rgba(245,239,230,0.40)">
              من ٥٠٠ لـ ٨٠٠٠ وات — بيتك دايما جاهز
            </p>
          </div>

          {/* Right: ghosted wattage number (desktop only) */}
          <p class="hidden sm:block font-cairo font-black select-none pointer-events-none leading-none flex-shrink-0"
             style="font-size:clamp(2.5rem,7vw,5rem);color:var(--c-brand);opacity:0.08;letter-spacing:-0.04em"
             aria-hidden="true">
            ٨٠٠٠
          </p>

        </div>
      </div>
    </section>
  )}

  {/* ── No active category: search / browsing header ── */}
  {!activeCategory && (
    <div style="background-color:var(--c-surface);border-bottom:1px solid var(--c-border)">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 sm:py-5">
        {q && (
          <h1 class="font-cairo font-black text-2xl mb-4" style="color:var(--c-ink)">
            {`نتائج: "${q}"`}
          </h1>
        )}

        <!-- Search + filters bar -->
        <form method="GET" action="/products" class="flex flex-wrap items-center gap-3">

          <!-- Search -->
          <div class="relative flex-1 min-w-[200px] max-w-sm">
            <input
              type="search"
              name="q"
              value={q ?? ''}
              placeholder="ابحث عن منتج..."
              class="hvar-input w-full pr-10 pl-4 py-2.5 rounded-xl font-cairo text-sm transition-colors"
            />
            <svg class="absolute top-1/2 right-3 -translate-y-1/2 text-stone-400" width="15" height="15" viewBox="0 0 20 20" fill="none">
              <circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.5"/>
              <line x1="14" y1="14" x2="18" y2="18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>

          <!-- In-stock toggle -->
          <label class="flex items-center gap-2 cursor-pointer select-none">
            <input
              type="checkbox"
              name="in_stock"
              value="1"
              checked={inStock}
              class="w-4 h-4 rounded accent-[var(--c-brand)]"
            />
            <span class="font-cairo text-sm text-muted">متاح فقط</span>
          </label>

          <button
            type="submit"
            class="px-4 py-2.5 rounded-xl bg-brand hover:bg-[var(--c-brand-hover)] text-white font-cairo font-semibold text-sm transition-colors"
          >
            بحث
          </button>

          {(q || inStock || categoryId || minPrice || maxPrice) && (
            <a
              href="/products"
              class="px-3 py-2.5 rounded-xl border border-hvar text-muted font-cairo text-sm hover:border-[var(--c-brand)] hover:text-[var(--c-brand)] transition-colors"
            >
              مسح الفلاتر
            </a>
          )}

        </form>
      </div>
    </div>
  )}

  <!-- Categories filter chips -->
  {categories.length > 0 && (
    <div class="bg-bg border-b border-hvar py-3 relative">
      <!-- edge fade to hint scroll -->
      <div class="chip-fade-end pointer-events-none" aria-hidden="true"></div>
      <div class="max-w-7xl mx-auto">
        <div class="chip-row flex items-center gap-2 overflow-x-auto px-4 sm:px-6 lg:px-8 pb-1 scrollbar-none">
          <a
            href="/products"
            class={`chip-item flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-cairo font-semibold transition-colors ${
              !categoryId
                ? 'bg-brand text-white'
                : 'bg-surface border border-hvar text-muted hover:border-[var(--c-brand)] hover:text-[var(--c-brand)]'
            }`}
          >
            الكل
          </a>
          {categories.map((cat) => (
            <a
              href={buildUrl({ category: cat.id })}
              class={`chip-item flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-cairo font-semibold transition-colors ${
                categoryId === cat.id
                  ? 'bg-brand text-white'
                  : 'bg-surface border border-hvar text-muted hover:border-[var(--c-brand)] hover:text-[var(--c-brand)]'
              }`}
            >
              {cat.name}
              <span class="text-xs opacity-60 ms-1">({cat.productCount})</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  )}

  {activeCategory && (
    <CategoryFilters
      currentUrl={url}
      categoryName={activeCategory.name}
      inStock={inStock}
      sortBy={sortBy}
      priceRange={priceRange}
    />
  )}

  <!-- Products grid -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 relative">

    <!-- Wilson P3: dot-grid background beneath the product cards -->
    <div class="absolute inset-0 -z-10 grid-dot-sm rounded-3xl pointer-events-none" aria-hidden="true" style="mask-image:linear-gradient(to bottom,transparent 0%,rgba(0,0,0,0.06) 30%,rgba(0,0,0,0.04) 70%,transparent 100%)"></div>

    {products.length === 0 ? (
      <div class="relative flex flex-col items-center justify-center text-center py-24 overflow-hidden">
        <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
             style="background:radial-gradient(ellipse 55% 50% at 50% 40%, rgba(var(--c-brand-rgb),0.06) 0%, transparent 70%)"></div>
        <svg class="relative" aria-hidden="true"
             style="width:clamp(80px,16vw,130px);height:auto;color:var(--c-brand);opacity:0.15"
             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          <path d="M8 11h6M11 8v6" />
        </svg>
        <p class="relative font-cairo font-black text-xl sm:text-2xl mt-5" style="color:var(--c-ink)">
          {q ? `مفيش نتائج لـ "${q}"` : 'مفيش منتجات دلوقتي'}
        </p>
        <p class="relative font-cairo text-sm mt-2 mb-8" style="color:var(--c-ink-muted)">
          {q ? 'جربي كلمة تانية أو تصفّحي الكل' : 'جربي تصفّحي كل المنتجات'}
        </p>
        <a href="/products"
           class="relative inline-flex items-center gap-2 px-7 py-3.5 rounded-xl font-cairo font-bold text-base text-white"
           style="background:var(--c-brand);transition:all 0.3s cubic-bezier(0.22,1,0.36,1)">
          كل المنتجات
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M4 8h8M8 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    ) : (
      <>
        <p class="font-cairo text-sm text-muted mb-5">
          {activeCategory
            ? `${products.length} منتج في ${activeCategory.name}`
            : q
              ? `${products.length} نتيجة لـ "${q}"`
              : `${products.length} منتج`
          }
        </p>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {products.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>

        <!-- Pagination -->
        {(products.length === limit || page > 1) && (
          <div class="flex items-center justify-center gap-3 mt-10">
            {page > 1 && (
              <a
                href={buildUrl({ page: page - 1, category: categoryId, q, in_stock: inStock ? '1' : null })}
                class="px-5 py-2.5 rounded-xl border border-hvar font-cairo font-semibold text-sm text-ink hover:border-[var(--c-brand)] hover:text-[var(--c-brand)] transition-colors"
              >
                السابق
              </a>
            )}
            <span class="font-cairo text-sm text-muted">
              صفحة {page}
            </span>
            {products.length === limit && (
              <a
                href={buildUrl({ page: page + 1, category: categoryId, q, in_stock: inStock ? '1' : null })}
                class="px-5 py-2.5 rounded-xl border border-hvar font-cairo font-semibold text-sm text-ink hover:border-[var(--c-brand)] hover:text-[var(--c-brand)] transition-colors"
              >
                التالي
              </a>
            )}
          </div>
        )}
      </>
    )}

  </div>

</Base>

<style>
  .scrollbar-none { -ms-overflow-style: none; scrollbar-width: none; }
  .scrollbar-none::-webkit-scrollbar { display: none; }

  /* Chip row — scroll-snap */
  .chip-row {
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .chip-row::-webkit-scrollbar { display: none; }
  .chip-item { scroll-snap-align: start; }

  /* Trailing fade mask to hint more content */
  .chip-fade-end {
    position: absolute;
    inset-block: 0;
    inset-inline-end: 0;
    width: 3.5rem;
    /* RTL: inline-end is physical left — fade from solid left to transparent right */
    background: linear-gradient(to right, var(--c-bg) 0%, transparent 100%);
    z-index: 1;
    pointer-events: none;
  }
  @media (min-width: 1024px) { .chip-fade-end { display: none; } }
</style>

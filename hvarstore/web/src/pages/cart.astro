---
import Base from '../layouts/Base.astro'
import CartView from '../components/cart/CartView'
---

<Base title="السلة — هفارستور">

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- Breadcrumb -->
    <nav class="mb-6" aria-label="مسار التنقل">
      <ol class="flex items-center gap-2 text-xs font-cairo text-[#57534e] dark:text-[#a8a29e]">
        <li><a href="/" class="hover:text-[#d43533] transition-colors">البيت</a></li>
        <li class="opacity-40">›</li>
        <li class="text-[#1c1917] dark:text-[#f5f5f4] font-semibold">السلة</li>
      </ol>
    </nav>

    <h1 class="font-cairo font-black text-2xl text-[#1c1917] dark:text-[#f5f5f4] mb-6">
      سلة التسوق
    </h1>

    <CartView client:load />

  </div>

</Base>

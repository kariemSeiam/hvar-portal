---
import Base from '../layouts/Base.astro'
import Hero from '../components/Hero.astro'
import CategoriesStrip from '../components/CategoriesStrip.astro'
import ProductCard from '../components/ProductCard.astro'
import { api } from '../lib/api'

const [featuredResult, categoriesResult] = await Promise.allSettled([
  api.products.featured(8),
  api.categories(),
])

const featured = featuredResult.status === 'fulfilled' ? featuredResult.value.items : []
const categories = categoriesResult.status === 'fulfilled' ? categoriesResult.value.items : []

---

<Base
  title="هفار | أجهزة منزلية مصرية بجودة تستاهل بيتك وشحن مجاني لكل مصر"
  description="تسوّقي أجهزة هفار: خلاطات، قلايات هوائية، مكاوي بخار، عجانات وكبّة. صناعة مصرية، شحن مجاني لكل مصر، وافحصي قبل ما تدفعي."
>

  <Hero />

  <CategoriesStrip categories={categories} />

  <!-- Featured products -->
  <section class="py-16 sm:py-20 reveal-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="flex items-end justify-between mb-8">
        <div>
          <p class="font-cairo text-xs font-semibold tracking-[0.14em] mb-1.5" style="color:var(--c-flame)">الأكثر مبيعاً</p>
          <h2 class="font-cairo font-bold text-xl" style="color:var(--c-ink)">
            من هفار
          </h2>
        </div>
        {featured.length > 0 && (
          <a
            href="/products"
            class="font-cairo text-sm font-semibold transition-colors flex items-center gap-1 pb-0.5"
            style="color:var(--c-brand)"
          >
            عرض الكل
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M4 8h8M8 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        )}
      </div>

      <div class="feat-row">
        {featured.length === 0 ? (
          Array.from({ length: 4 }).map((_, i) => (
            <div class="reveal-child feat-card" style={`--stagger:${i * 55}ms`}>
              <div class="rounded-2xl overflow-hidden shimmer-skel" style="background-color:var(--c-surface);border:1px solid var(--c-border)">
                <div class="aspect-square" style="background-color:var(--c-border)"></div>
                <div class="p-4 space-y-3">
                  <div class="h-2.5 w-1/3 rounded-full" style="background-color:var(--c-border)"></div>
                  <div class="h-3 w-3/4 rounded-full" style="background-color:var(--c-border)"></div>
                  <div class="h-3 w-1/2 rounded-full" style="background-color:var(--c-border)"></div>
                </div>
              </div>
            </div>
          ))
        ) : (
          featured.map((product, i) => (
            <div class="reveal-child feat-card" style={`--stagger:${Math.min(i, 3) * 55}ms`}>
              <ProductCard product={product} eager={i < 2} />
            </div>
          ))
        )}
      </div>

    </div>
  </section>

  <style>
    /* Featured: clean vertical grid at every breakpoint — no horizontal scroll */
    .feat-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }
    @media (min-width: 640px) {
      .feat-row {
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
      }
    }
    @media (min-width: 1024px) {
      .feat-row { grid-template-columns: repeat(4, 1fr); }
    }

    /* Staggered wave reveal — each card inherits its own delay */
    .feat-card.reveal-child {
      transform: translateY(24px) scale(0.97);
      transition-delay: var(--stagger, 0ms);
    }
    .feat-card.reveal-child.visible {
      transform: translateY(0) scale(1);
      transition-delay: var(--stagger, 0ms);
    }
  </style>

  <!-- ── Social Proof ───────────────────────────────────────── -->
  <section class="py-16 sm:py-20 reveal-section" style="background-color:var(--c-surface);border-top:1px solid var(--c-border);border-bottom:1px solid var(--c-border)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-10">
        <div class="reveal-child">
          <p class="font-cairo font-semibold text-xs uppercase tracking-[0.16em] mb-1" style="color:var(--c-flame)">هيقولوا إيه عنا؟</p>
          <h2 class="font-cairo font-black text-2xl sm:text-3xl" style="color:var(--c-ink)">١٤٧٫٠٠٠+ بيثقوا فينا</h2>
        </div>
        <a href="https://www.facebook.com/hvar22" target="_blank" rel="noopener noreferrer"
           class="reveal-child flex items-center gap-2 font-cairo text-sm font-semibold transition-colors flex-shrink-0"
           style="color:var(--c-brand)">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          ١٤٧ ألف متابع
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M4 8h8M8 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <div class="proof-row">

        {([
          {
            name: "سارة محمود",
            city: "القاهرة",
            stars: 5,
            text: "كبة هفار ٢٠٠٠ وات دي أكتر من هيلة! شغالة من ٣ سنين ومافيهاش أي مشكلة. جودة هفار مش كلام — تستاهل كل قرش.",
            product: "كبة هفار ٢٠٠٠ وات",
          },
          {
            name: "منى علي",
            city: "الجيزة",
            stars: 5,
            text: "القلاية الهوائية الجمبو ٩ لتر تجنن! بتعمل لعيلتي كلها وبسرعة. التوصيل كان في اليوم التاني.",
            product: "قلاية هوائية ٩ لتر",
          },
          {
            name: "هند رضا",
            city: "الإسكندرية",
            stars: 5,
            text: "فحصت المنتج قبل ما أدفع وعجبني جداً. الخدمة محترمة والناس تستاهل تتعامل مع هفار.",
            product: "هاند بلندر ٤ في ١",
          },
          {
            name: "نورا حسن",
            city: "المنصورة",
            stars: 5,
            text: "اشتريت مكواة البخار وجاتني في نص اليوم! المنتج أحلى من الصورة والسعر منافس جداً.",
            product: "مكواة بخار ٢٨٠٠ وات",
          },
        ]).map(({ name, city, stars, text, product }) => (
          <div class="proof-card reveal-child" style="background:var(--c-bg);border:1px solid var(--c-border);border-radius:1.25rem;display:flex;flex-direction:column;gap:0.625rem;">
            <!-- Stars -->
            <div class="flex gap-0.5" aria-label={`${stars} نجوم`}>
              {Array.from({ length: stars }).map(() => (
                <svg width="13" height="13" viewBox="0 0 24 24" fill="var(--c-flame-bright)" aria-hidden="true">
                  <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
                </svg>
              ))}
            </div>
            <!-- Quote -->
            <p class="font-cairo text-sm leading-relaxed flex-1" style="color:var(--c-ink)">{text}</p>
            <!-- Footer -->
            <div>
              <p class="font-cairo text-xs font-bold" style="color:var(--c-ink)">{name}</p>
              <p class="font-cairo text-xs" style="color:var(--c-ink-muted)">{city} · {product}</p>
            </div>
          </div>
        ))}

      </div>
    </div>
  </section>

  <!-- ── How It Works ────────────────────────────────────────── -->
  <section class="py-16 sm:py-20 reveal-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-10 reveal-child">
        <p class="font-cairo font-semibold text-xs uppercase tracking-[0.16em] mb-2" style="color:var(--c-flame)">هفار بتوصلك</p>
        <h2 class="font-cairo font-black text-2xl sm:text-3xl" style="color:var(--c-ink)">٣ خطوات وبس</h2>
      </div>

      <div class="hiw-row">

        <div class="hiw-step reveal-child">
          <div class="hiw-num">١</div>
          <div class="hiw-icon-wrap">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
          </div>
          <h3 class="hiw-title font-cairo">اختاري منتجك</h3>
          <p class="hiw-desc font-cairo">تصفّحي الكتالوج، قارني، واختاري بثقة</p>
          <div class="hiw-arrow" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 12h16M13 5l7 7-7 7"/>
            </svg>
          </div>
        </div>

        <div class="hiw-step reveal-child">
          <div class="hiw-num">٢</div>
          <div class="hiw-icon-wrap">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="1" y="3" width="15" height="13" rx="1"/>
              <path d="M16 8h4a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-4"/>
              <circle cx="7.5" cy="20" r="1.5"/><circle cx="18.5" cy="20" r="1.5"/>
            </svg>
          </div>
          <h3 class="hiw-title font-cairo">اطلبي واستني</h3>
          <p class="hiw-desc font-cairo">نوصل لبابك خلال ١–٣ أيام بشحن مجاني</p>
          <div class="hiw-arrow" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 12h16M13 5l7 7-7 7"/>
            </svg>
          </div>
        </div>

        <div class="hiw-step reveal-child">
          <div class="hiw-num">٣</div>
          <div class="hiw-icon-wrap hiw-icon-wrap--red">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 2L4 6v6c0 5 3.5 9.5 8 11 4.5-1.5 8-6 8-11V6L12 2Z"/>
              <polyline points="9 12 11 14 15 10"/>
            </svg>
          </div>
          <h3 class="hiw-title font-cairo">افحصي قبل الدفع</h3>
          <p class="hiw-desc font-cairo">ادفعي لما تتأكدي — وخدمة هفار معاكِ بعد البيع</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Service section -->
  <section class="pb-16 sm:pb-20 reveal-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-7">
        <h2 class="font-cairo font-bold text-xl" style="color:var(--c-ink)">
          خدمة ما بعد البيع
        </h2>
        <a href="/service" class="font-cairo text-sm font-semibold flex items-center gap-1" style="color:var(--c-brand)">
          كل الخدمات
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M4 8h8M8 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <div class="svc-row">
        {([
          {
            label: 'صيانة',
            desc: 'طلب صيانة منزلية',
            href: '/service/new?type=HVM',
            svg: `<path d="M14.5 4.5A4.5 4.5 0 0 0 6 8c0 .9.3 1.8.7 2.5L3 14.1A2 2 0 1 0 5.9 17l3.6-3.7A4.5 4.5 0 1 0 14.5 4.5Z"/>`,
          },
          {
            label: 'استبدال',
            desc: 'استبدال منتج معطوب',
            href: '/service/new?type=HVR',
            svg: `<path d="M21 12a9 9 0 0 0-9-9 9 9 0 0 0-6.36 2.64L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9 9 0 0 0 6.36-2.64L21 16"/><path d="M16 16h5v5"/>`,
          },
          {
            label: 'مرتجع',
            desc: 'إرجاع منتج',
            href: '/service/new?type=HVT',
            svg: `<path d="M9 14H4v5"/><path d="M20 9a9 9 0 0 0-15-3.8L4 8"/><path d="M4 14a9 9 0 0 0 15 3.8l1-3.8"/>`,
          },
          {
            label: 'تواصل',
            desc: 'كلمنا مباشرة',
            href: '/contact',
            svg: `<path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2 4.2 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1 1 .4 2 .7 2.9a2 2 0 0 1-.4 2L8 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2-.5c.9.3 1.9.6 2.9.7A2 2 0 0 1 22 16.9Z"/>`,
          },
        ] as const).map(({ svg, label, desc, href }) => (
          <a
            href={href}
            class="reveal-child svc-card group flex flex-col items-center text-center gap-3 p-5 rounded-2xl bg-surface border border-hvar hover:border-[var(--c-brand)] hover:shadow-[0_4px_20px_rgba(var(--c-brand-rgb),0.08)] transition-all duration-300"
          >
            <div class="w-11 h-11 flex items-center justify-center rounded-xl bg-red-50 dark:bg-red-950/20 text-brand group-hover:bg-brand group-hover:text-white transition-all duration-300">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={svg} />
            </div>
            <div>
              <p class="font-cairo font-bold text-sm text-ink">{label}</p>
              <p class="font-cairo text-xs text-muted mt-0.5">{desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <style>
    /* ── Social proof testimonials ── */
    .proof-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }
    @media (min-width: 1024px) {
      .proof-row {
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
      }
    }
    .proof-card {
      padding: 0.875rem;
    }
    @media (min-width: 640px) {
      .proof-card { padding: 1.25rem; }
    }

    /* ── How It Works ── */
    .hiw-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      position: relative;
    }
    @media (max-width: 639px) {
      .hiw-row {
        grid-template-columns: 1fr;
        gap: 0;
      }
    }

    .hiw-step {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 1.75rem 1.25rem;
      border-radius: 1.25rem;
      border: 1px solid var(--c-border);
      background: var(--c-surface);
      transition: border-color 0.28s var(--ease-spring), box-shadow 0.28s var(--ease-spring);
    }
    .hiw-step:hover {
      border-color: rgba(var(--c-brand-rgb), 0.35);
      box-shadow: 0 6px 28px rgba(var(--c-brand-rgb), 0.08);
    }
    @media (max-width: 639px) {
      .hiw-step {
        flex-direction: row;
        text-align: start;
        gap: 1rem;
        border-radius: 0;
        border-inline: none;
        border-top: none;
        padding: 1.25rem 1rem;
      }
      .hiw-step:first-child {
        border-top: 1px solid var(--c-border);
        border-radius: 1.25rem 1.25rem 0 0;
      }
      .hiw-step:last-child {
        border-radius: 0 0 1.25rem 1.25rem;
      }
      .hiw-icon-wrap {
        flex-shrink: 0;
        margin-block-end: 0;
      }
    }

    .hiw-num {
      position: absolute;
      inset-block-start: 0.75rem;
      inset-inline-start: 0.75rem;
      font-family: "Cairo", system-ui, sans-serif;
      font-weight: 900;
      font-size: 0.7rem;
      color: var(--c-brand);
      opacity: 0.55;
      line-height: 1;
    }
    @media (max-width: 639px) {
      .hiw-num { inset-inline-start: auto; inset-inline-end: 0.75rem; }
    }

    .hiw-icon-wrap {
      width: 3rem;
      height: 3rem;
      border-radius: 0.875rem;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-block-end: 0.875rem;
      background: rgba(var(--c-brand-rgb), 0.07);
      color: var(--c-brand);
      flex-shrink: 0;
    }
    .hiw-icon-wrap--red {
      background: rgba(var(--c-brand-rgb), 0.11);
    }

    .hiw-title {
      font-weight: 700;
      font-size: 0.9375rem;
      color: var(--c-ink);
      margin-block-end: 0.25rem;
    }
    .hiw-desc {
      font-size: 0.8125rem;
      color: var(--c-ink-muted);
      line-height: 1.6;
    }
    @media (max-width: 639px) {
      .hiw-title { margin-block-end: 0.125rem; }
    }

    .hiw-arrow {
      display: none;
    }
    @media (min-width: 640px) {
      .hiw-arrow {
        display: block;
        position: absolute;
        inset-inline-end: -1rem;
        inset-block-start: 50%;
        transform: translateY(-50%) scaleX(-1);
        color: var(--c-ink-faint);
        opacity: 0.4;
        z-index: 2;
        pointer-events: none;
      }
      .hiw-step:last-child .hiw-arrow { display: none; }
    }

    /* ── Service cards — 2×2 on mobile, 4-col on desktop ── */
    .svc-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }
    @media (min-width: 640px) {
      .svc-row {
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
      }
    }
  </style>

</Base>

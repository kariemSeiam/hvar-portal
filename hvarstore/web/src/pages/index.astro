---
import Base from '../layouts/Base.astro'
import Hero from '../components/Hero.astro'
import CategoriesStrip from '../components/CategoriesStrip.astro'
import TrustBlock from '../components/TrustBlock.astro'
import ChefStrip from '../components/ChefStrip.astro'
import ProductCard from '../components/ProductCard.astro'
import { api } from '../lib/api'

const [featuredResult, categoriesResult] = await Promise.allSettled([
  api.products.featured(8),
  api.categories(),
])

const featured = featuredResult.status === 'fulfilled' ? featuredResult.value.items : []
const categories = categoriesResult.status === 'fulfilled' ? categoriesResult.value.items : []

---

<Base
  title="هفار | أجهزة منزلية بضمان سنتين وشحن مجاني لجميع أنحاء مصر"
  description="تسوق أجهزة هفار: خلاطات، قلايات هوائية، مكاوي بخار، عجانات. ضمان من سنتين لثلاث سنوات، شحن مجاني، افحص قبل الدفع."
>

  <Hero />

  <TrustBlock />

  <CategoriesStrip categories={categories} />

  <!-- Featured products -->
  <section class="py-16 sm:py-20 reveal-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="flex items-center justify-between mb-7">
        <h2 class="font-cairo font-bold text-xl" style="color:var(--c-ink)">
          الأكثر مبيعاً من هفار
        </h2>
        {featured.length > 0 && (
          <a
            href="/products"
            class="font-cairo text-sm text-brand hover:text-[var(--c-brand-hover)] font-semibold transition-colors flex items-center gap-1"
          >
            عرض الكل
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M4 8h8M8 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        )}
      </div>

      <div class="feat-row">
        {featured.length === 0 ? (
          /* Skeleton shimmer while loading */
          Array.from({ length: 4 }).map(() => (
            <div class="rounded-2xl bg-surface border border-hvar overflow-hidden shimmer-skel">
              <div class="aspect-square" style="background-color:var(--c-border)"></div>
              <div class="p-4 space-y-3">
                <div class="h-2.5 w-1/3 rounded-full" style="background-color:var(--c-border)"></div>
                <div class="h-3 w-3/4 rounded-full" style="background-color:var(--c-border)"></div>
                <div class="h-3 w-1/2 rounded-full" style="background-color:var(--c-border)"></div>
              </div>
            </div>
          ))
        ) : (
          featured.map((product) => (
            <div class="reveal-child">
              <ProductCard product={product} />
            </div>
          ))
        )}
      </div>

    </div>
  </section>

  <style>
    /* Featured: thumb-driven horizontal snap carousel on mobile (with edge
       peek), grid on larger screens */
    @media (max-width: 639px) {
      .feat-row {
        display: flex;
        gap: 0.875rem;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        margin-inline: -1rem;
        padding-inline: 1rem;
        padding-bottom: 0.5rem;
      }
      .feat-row::-webkit-scrollbar { display: none; }
      .feat-row > * {
        min-width: min(62vw, 240px);
        flex-shrink: 0;
        scroll-snap-align: start;
      }
    }
    @media (min-width: 640px) {
      .feat-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
      }
    }
    @media (min-width: 1024px) {
      .feat-row { grid-template-columns: repeat(4, 1fr); }
    }
  </style>

  <ChefStrip />

  <!-- ── WhatsApp CTA band ─────────────────────────────────── -->
  <section class="relative overflow-hidden py-10 sm:py-12 reveal-section" style="background:#1a1208;border-top:1px solid rgba(var(--c-brass-rgb),0.12);border-bottom:1px solid rgba(var(--c-brass-rgb),0.12)">
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 60% 80% at 80% 50%, rgba(37,211,102,0.06) 0%, transparent 65%)" aria-hidden="true"></div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center gap-5 sm:gap-8 reveal-child">
        <div class="flex-1 text-center sm:text-start">
          <p class="font-cairo font-semibold text-xs uppercase tracking-[0.16em] mb-1" style="color:#25d366;opacity:0.75">+١٤٧ ألف عيلة هفار</p>
          <h2 class="font-cairo font-black text-xl sm:text-2xl leading-tight" style="color:#F5EFE6">
            وصفات، نصايح، وأسعار حصرية — يوميًا على واتساب
          </h2>
          <p class="font-cairo text-sm mt-1.5 leading-relaxed" style="color:rgba(245,239,230,0.45)">
            انضمي لمجتمع هفار على واتساب — كوبونات، قبل الإطلاق، واستشارات مجانية
          </p>
        </div>
        <a
          href="https://wa.me/201204444196?text=عايزة أنضم لمجموعة هفار"
          target="_blank"
          rel="noopener noreferrer"
          class="flex-shrink-0 inline-flex items-center gap-2.5 px-6 py-3.5 rounded-xl font-cairo font-bold text-base text-white transition-all"
          style="background:#25D366;box-shadow:0 4px 20px rgba(37,211,102,0.25);transition:all 0.3s cubic-bezier(0.22,1,0.36,1)"
          onmouseover="this.style.background='#1db954';this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 28px rgba(37,211,102,0.35)'"
          onmouseout="this.style.background='#25D366';this.style.transform='';this.style.boxShadow='0 4px 20px rgba(37,211,102,0.25)'"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          انضمي دلوقتي
        </a>
      </div>
    </div>
  </section>

  <!-- ── Social Proof ───────────────────────────────────────── -->
  <section class="py-16 sm:py-20 reveal-section" style="background-color:var(--c-surface);border-top:1px solid var(--c-border);border-bottom:1px solid var(--c-border)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-10">
        <div class="reveal-child">
          <p class="font-cairo font-semibold text-xs uppercase tracking-[0.16em] mb-1" style="color:var(--c-brass)">هيقولوا إيه عنا؟</p>
          <h2 class="font-cairo font-black text-2xl sm:text-3xl" style="color:var(--c-ink)">١٤٧٫٠٠٠+ بيثقوا فينا</h2>
        </div>
        <a href="https://www.facebook.com/hvar22" target="_blank" rel="noopener noreferrer"
           class="reveal-child flex items-center gap-2 font-cairo text-sm font-semibold transition-colors flex-shrink-0"
           style="color:var(--c-brand)">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          ١٤٧ ألف متابع
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M4 8h8M8 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <div class="proof-row">

        {([
          {
            name: "سارة محمود",
            city: "القاهرة",
            stars: 5,
            text: "الكبة البلدوزر ٢٠٠٠ وات دي أكتر من هيلة! شغالة من ٣ سنين ومافيهاش أي مشكلة. والضمان حقيقي مش كلام.",
            product: "كبة البلدوزر ٢٠٠٠ وات",
          },
          {
            name: "منى علي",
            city: "الجيزة",
            stars: 5,
            text: "القلاية الهوائية الجمبو ٩ لتر تجنن! بتعمل لعيلتي كلها وبسرعة. التوصيل كان في اليوم التاني.",
            product: "قلاية هوائية ٩ لتر",
          },
          {
            name: "هند رضا",
            city: "الإسكندرية",
            stars: 5,
            text: "فحصت المنتج قبل ما أدفع وعجبني جداً. الخدمة محترمة والناس تستاهل تتعامل مع هفار.",
            product: "هاند بلندر ٤ في ١",
          },
          {
            name: "نورا حسن",
            city: "المنصورة",
            stars: 5,
            text: "اشتريت مكواة البخار وجاتني في نص اليوم! المنتج أحلى من الصورة والسعر منافس جداً.",
            product: "مكواة بخار ٢٨٠٠ وات",
          },
        ]).map(({ name, city, stars, text, product }) => (
          <div class="proof-card reveal-child" style="background:var(--c-bg);border:1px solid var(--c-border);border-radius:1.25rem;padding:1.25rem;display:flex;flex-direction:column;gap:0.75rem;flex-shrink:0;scroll-snap-align:start">
            <!-- Stars -->
            <div class="flex gap-0.5" aria-label={`${stars} نجوم`}>
              {Array.from({ length: stars }).map(() => (
                <svg width="13" height="13" viewBox="0 0 24 24" fill="var(--c-brass)" aria-hidden="true">
                  <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
                </svg>
              ))}
            </div>
            <!-- Quote -->
            <p class="font-cairo text-sm leading-relaxed flex-1" style="color:var(--c-ink)">{text}</p>
            <!-- Footer -->
            <div>
              <p class="font-cairo text-xs font-bold" style="color:var(--c-ink)">{name}</p>
              <p class="font-cairo text-xs" style="color:var(--c-ink-muted)">{city} · {product}</p>
            </div>
          </div>
        ))}

      </div>
    </div>
  </section>

  <!-- ── How It Works ────────────────────────────────────────── -->
  <section class="py-16 sm:py-20 reveal-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-10 reveal-child">
        <p class="font-cairo font-semibold text-xs uppercase tracking-[0.16em] mb-2" style="color:var(--c-brass)">هفار بتوصلك</p>
        <h2 class="font-cairo font-black text-2xl sm:text-3xl" style="color:var(--c-ink)">٣ خطوات وبس</h2>
      </div>

      <div class="hiw-row">

        <div class="hiw-step reveal-child">
          <div class="hiw-num">١</div>
          <div class="hiw-icon-wrap">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
          </div>
          <h3 class="hiw-title font-cairo">اختاري منتجك</h3>
          <p class="hiw-desc font-cairo">تصفّحي الكتالوج، قارني، واختاري بثقة</p>
          <div class="hiw-arrow" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 12h16M13 5l7 7-7 7"/>
            </svg>
          </div>
        </div>

        <div class="hiw-step reveal-child">
          <div class="hiw-num">٢</div>
          <div class="hiw-icon-wrap">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="1" y="3" width="15" height="13" rx="1"/>
              <path d="M16 8h4a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-4"/>
              <circle cx="7.5" cy="20" r="1.5"/><circle cx="18.5" cy="20" r="1.5"/>
            </svg>
          </div>
          <h3 class="hiw-title font-cairo">اطلبي واستني</h3>
          <p class="hiw-desc font-cairo">نوصل لبابك خلال ١–٣ أيام بشحن مجاني</p>
          <div class="hiw-arrow" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 12h16M13 5l7 7-7 7"/>
            </svg>
          </div>
        </div>

        <div class="hiw-step reveal-child">
          <div class="hiw-num">٣</div>
          <div class="hiw-icon-wrap hiw-icon-wrap--red">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 2L4 6v6c0 5 3.5 9.5 8 11 4.5-1.5 8-6 8-11V6L12 2Z"/>
              <polyline points="9 12 11 14 15 10"/>
            </svg>
          </div>
          <h3 class="hiw-title font-cairo">افحصي قبل الدفع</h3>
          <p class="hiw-desc font-cairo">ادفعي لما تتأكدي — والضمان معاكِ سنتين</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Service section -->
  <section class="pb-16 sm:pb-20 reveal-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-7">
        <h2 class="font-cairo font-bold text-xl" style="color:var(--c-ink)">
          خدمة ما بعد البيع
        </h2>
        <a href="/service" class="font-cairo text-sm font-semibold flex items-center gap-1" style="color:var(--c-brand)">
          كل الخدمات
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M4 8h8M8 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <div class="svc-row">
        {([
          {
            label: 'صيانة',
            desc: 'طلب صيانة منزلية',
            href: '/service/new?type=HVM',
            svg: `<path d="M14.5 4.5A4.5 4.5 0 0 0 6 8c0 .9.3 1.8.7 2.5L3 14.1A2 2 0 1 0 5.9 17l3.6-3.7A4.5 4.5 0 1 0 14.5 4.5Z"/>`,
          },
          {
            label: 'استبدال',
            desc: 'استبدال منتج معطوب',
            href: '/service/new?type=HVR',
            svg: `<path d="M21 12a9 9 0 0 0-9-9 9 9 0 0 0-6.36 2.64L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9 9 0 0 0 6.36-2.64L21 16"/><path d="M16 16h5v5"/>`,
          },
          {
            label: 'مرتجع',
            desc: 'إرجاع منتج',
            href: '/service/new?type=HVT',
            svg: `<path d="M9 14H4v5"/><path d="M20 9a9 9 0 0 0-15-3.8L4 8"/><path d="M4 14a9 9 0 0 0 15 3.8l1-3.8"/>`,
          },
          {
            label: 'تواصل',
            desc: 'كلمنا مباشرة',
            href: '/contact',
            svg: `<path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2 4.2 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1 1 .4 2 .7 2.9a2 2 0 0 1-.4 2L8 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2-.5c.9.3 1.9.6 2.9.7A2 2 0 0 1 22 16.9Z"/>`,
          },
        ] as const).map(({ svg, label, desc, href }) => (
          <a
            href={href}
            class="reveal-child svc-card group flex flex-col items-center text-center gap-3 p-5 rounded-2xl bg-surface border border-hvar hover:border-[var(--c-brand)] hover:shadow-[0_4px_20px_rgba(var(--c-brand-rgb),0.08)] transition-all duration-300"
          >
            <div class="w-11 h-11 flex items-center justify-center rounded-xl bg-red-50 dark:bg-red-950/20 text-brand group-hover:bg-brand group-hover:text-white transition-all duration-300">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={svg} />
            </div>
            <div>
              <p class="font-cairo font-bold text-sm text-ink">{label}</p>
              <p class="font-cairo text-xs text-muted mt-0.5">{desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <style>
    /* ── Social proof testimonials ── */
    .proof-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }
    @media (max-width: 1023px) {
      .proof-row {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (max-width: 639px) {
      .proof-row {
        display: flex;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        margin-inline: -1rem;
        padding-inline: 1rem;
        padding-block-end: 0.5rem;
        gap: 0.875rem;
      }
      .proof-row::-webkit-scrollbar { display: none; }
      .proof-card {
        min-width: min(76vw, 280px) !important;
        scroll-snap-align: start;
      }
    }

    /* ── How It Works ── */
    .hiw-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      position: relative;
    }
    @media (max-width: 639px) {
      .hiw-row {
        grid-template-columns: 1fr;
        gap: 0;
      }
    }

    .hiw-step {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 1.75rem 1.25rem;
      border-radius: 1.25rem;
      border: 1px solid var(--c-border);
      background: var(--c-surface);
      transition: border-color 0.28s var(--ease-spring), box-shadow 0.28s var(--ease-spring);
    }
    .hiw-step:hover {
      border-color: rgba(var(--c-brand-rgb), 0.35);
      box-shadow: 0 6px 28px rgba(var(--c-brand-rgb), 0.08);
    }
    @media (max-width: 639px) {
      .hiw-step {
        flex-direction: row;
        text-align: start;
        gap: 1rem;
        border-radius: 0;
        border-inline: none;
        border-top: none;
        padding: 1.25rem 1rem;
      }
      .hiw-step:first-child {
        border-top: 1px solid var(--c-border);
        border-radius: 1.25rem 1.25rem 0 0;
      }
      .hiw-step:last-child {
        border-radius: 0 0 1.25rem 1.25rem;
      }
      .hiw-icon-wrap {
        flex-shrink: 0;
        margin-block-end: 0;
      }
    }

    .hiw-num {
      position: absolute;
      inset-block-start: 0.75rem;
      inset-inline-start: 0.75rem;
      font-family: "Cairo", system-ui, sans-serif;
      font-weight: 900;
      font-size: 0.7rem;
      color: var(--c-brand);
      opacity: 0.55;
      line-height: 1;
    }
    @media (max-width: 639px) {
      .hiw-num { inset-inline-start: auto; inset-inline-end: 0.75rem; }
    }

    .hiw-icon-wrap {
      width: 3rem;
      height: 3rem;
      border-radius: 0.875rem;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-block-end: 0.875rem;
      background: rgba(var(--c-brand-rgb), 0.07);
      color: var(--c-brand);
      flex-shrink: 0;
    }
    .hiw-icon-wrap--red {
      background: rgba(var(--c-brand-rgb), 0.11);
    }

    .hiw-title {

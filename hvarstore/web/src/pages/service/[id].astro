        <li><a href="/" class="hover:text-[#d43533] transition-colors">البيت</a></li>
        <li class="opacity-40">›</li>
        <li><a href="/account" class="hover:text-[#d43533] transition-colors">حسابي</a></li>
        <li class="opacity-40">›</li>
        <li><a href="/service" class="hover:text-[#d43533] transition-colors">الدعم والصيانة</a></li>
        <li class="opacity-40">›</li>
        <li class="text-[#1c1917] dark:text-[#f5f5f4] font-semibold">تفاصيل التذكرة</li>

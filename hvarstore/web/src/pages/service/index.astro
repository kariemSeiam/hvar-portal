---
import Base from '../../layouts/Base.astro'
import TicketsList from '../../components/service/TicketsList'
import InnerHero from '../../components/InnerHero.astro'
---

<Base title="الصيانة والاستبدال | هفار">

  <InnerHero
    label="هفار للدعم"
    title="الدعم والصيانة"
    subtitle="بعد البيع يبدأ الاهتمام الحقيقي"
    variant="service"
    cta={{ label: "طلب جديد", href: "/service/new" }}
  />

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <TicketsList client:load />
  </div>

</Base>

    </p>
  </div>

  <div class="space-y-3 reveal-section">
    {faqItems.map(({ q, a }) => (
      <details
        class="group rounded-2xl overflow-hidden
               bg-surface
               border border-hvar
               hover:border-[var(--c-brand)]/30 dark:hover:border-[var(--c-brand)]/30 reveal-child"
        style="transition:border-color 250ms cubic-bezier(0.22,1,0.36,1)"
      >
        <summary
          class="flex items-center justify-between gap-4 px-5 py-4
                 cursor-pointer select-none list-none
                 font-cairo font-bold text-sm text-ink
                 hover:bg-stone-50 dark:hover:bg-white/5"
          style="transition:background 150ms cubic-bezier(0.22,1,0.36,1)"
        >
          <span>{q}</span>
          <svg class="faq-chevron w-4 h-4 flex-shrink-0 text-muted"
               viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M4 6l4 4 4-4" stroke="currentColor"
                  stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </summary>
        <div class="px-5 pb-4 pt-1 font-cairo text-sm text-muted leading-relaxed">
          {a}
        </div>
      </details>
    ))}
  </div>

</section>



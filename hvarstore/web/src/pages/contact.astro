---
import Base from '../layouts/Base.astro'
import Doodles from '../components/Doodles.astro'

const waProductUrl  = `https://wa.me/201204444196?text=${encodeURIComponent('مرحباً، عايزة أستفسر عن منتج')}`
const waOrderUrl    = `https://wa.me/201204444196?text=${encodeURIComponent('مرحباً، عايزة أستفسر عن طلبي')}`
const waGeneralUrl  = `https://wa.me/201204444196?text=${encodeURIComponent('مرحباً، عايزة أستفسر')}`
const waWholesale   = 'https://wa.me/message/RURCTAQLT5ASO1'

const faqItems = [
  {
    q: 'ما مدة ضمان منتجات هفار؟',
    a: 'من سنتين لثلاث سنوات حسب المنتج — يبدأ من تاريخ الاستلام. الضمان يشمل قطع الغيار والإصلاح من غير شروط مخبّية.',
  },
  {
    q: 'هل الدفع عند الاستلام متاح؟',
    a: 'أيوه. افحصي المنتج قبل ما تدفعي — ده حقك. كمان متاح الدفع بالبطاقة أو بالتقسيط عن طريق فاليو وسهولة وأمان.',
  },
  {
    q: 'كم يستغرق التوصيل وهل له رسوم؟',
    a: 'من ١ لـ٣ أيام عمل لأغلب المحافظات. التوصيل مجاني على كل الطلبات — مفيش رسوم إضافية.',
  },
  {
    q: 'عندي منتج وقف أو بيعمل مشكلة — إزاي أطلب صيانة؟',
    a: 'ادخلي على صفحة الخدمة واختاري "صيانة". ادخلي اسم المنتج والمشكلة بالتفصيل وفريقنا هيتواصل معاكِ خلال ٢٤ ساعة لتحديد موعد الاستلام.',
  },
  {
    q: 'إزاي أرجع منتج مش عاجبني؟',
    a: 'خلال ١٤ يوم من الاستلام طالما المنتج بحالته الأصلية مع العبوة. افتحي طلب مرتجع من صفحة الخدمة وهنتواصل معاكِ.',
  },
  {
    q: 'هل هفار عندها فروع أو معارض؟',
    a: 'أيوه، هفار لها فروع في عدة محافظات. تواصلي على الخط الساخن ١٧٥٦٦ أو واتساب عشان تعرفي أقرب فرع ليكِ.',
  },
  {
    q: 'عايزة أشتري كميات كبيرة أو بالجملة؟',
    a: 'تواصلي على واتساب الجملة مباشرة وفريق المبيعات هيرد عليكِ. نوفر خصومات خاصة للكميات والموزعين والمطاعم.',
  },
]

const faqJsonld = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
})

const contactJsonld = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'تواصل مع هفار',
  url: 'https://hvarstore.com/contact',
  mainEntity: {
    '@type': 'Organization',
    name: 'هفار',
    telephone: '+201204444196',
    email: 'info@hvarstore.com',
    contactPoint: {
      '@type': 'ContactPoint',
      telephone: '+201204444196',
      contactType: 'customer service',
      areaServed: 'EG',
      availableLanguage: 'Arabic',
      hoursAvailable: 'Mo-Su 09:00-21:00',
    },
  },
})
---

<Base
  title="تواصل مع هفار — خط ساخن ١٧٥٦٦، واتساب، خدمة عملاء"
  description="تواصلي مع هفار عبر الخط الساخن ١٧٥٦٦، واتساب ٠١٢٠٤٤٤٤١٩٦، أو راسلينا مباشرة. نرد خلال ٢٤ ساعة. ضمان حقيقي وشحن مجاني."
  jsonld={[faqJsonld, contactJsonld]}
>

<style>
  /* Wilson motion signature */
  :root { --curve: cubic-bezier(0.22, 1, 0.36, 1); }

  /* ── P2: Grain Texture ────────────────────────────────────────────────── */
  .grain-overlay { position: relative; isolation: isolate; }
  .grain-overlay::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-size: 256px 256px;
    opacity: 0.04;
    mix-blend-mode: overlay;
  }
  .dark .grain-overlay::before { opacity: 0.06; }

  /* ── P4: Red Mesh ─────────────────────────────────────────────────────── */
  .mesh-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, hsl(1 64% 51% / 0.08) 0%, transparent 70%),
      radial-gradient(ellipse 40% 30% at 90% 80%, hsl(32 55% 51% / 0.06) 0%, transparent 60%);
  }
  .dark .mesh-hero::after {
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, hsl(2 75% 58% / 0.14) 0%, transparent 70%),
      radial-gradient(ellipse 40% 30% at 90% 80%, hsl(32 55% 51% / 0.10) 0%, transparent 60%);
  }

  /* ── P6: Card Shine ───────────────────────────────────────────────────── */
  .card-shine { position: relative; overflow: hidden; }
  .card-shine::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 0%, transparent 40%,
      hsl(1 64% 51% / 0.06) 45%,
      hsl(1 64% 51% / 0.12) 50%,
      hsl(1 64% 51% / 0.06) 55%,
      transparent 60%, transparent 100%
    );
    opacity: 0;
    transform: translateX(-100%);
    transition: opacity 0.4s var(--curve), transform 0.5s var(--curve);
    pointer-events: none;
  }
  .card-shine:hover::after { opacity: 1; transform: translateX(100%); }
  @media (prefers-reduced-motion: reduce) { .card-shine::after { display: none; } }

  /* ── P7: Scroll Reveals (Base already adds .visible via IO) ───────────── */
  .reveal-section {
    opacity: 0;
    transform: translateY(2rem);
    transition: opacity 700ms var(--curve), transform 700ms var(--curve);
  }
  .reveal-section.visible { opacity: 1; transform: translateY(0); }
  .reveal-child {
    opacity: 0;
    transform: translateY(1.125rem);
    transition: opacity 500ms var(--curve), transform 500ms var(--curve);
  }
  .visible .reveal-child { opacity: 1; transform: translateY(0); }
  .visible .reveal-child:nth-child(1) { transition-delay:   0ms; }
  .visible .reveal-child:nth-child(2) { transition-delay:  80ms; }
  .visible .reveal-child:nth-child(3) { transition-delay: 160ms; }
  .visible .reveal-child:nth-child(4) { transition-delay: 240ms; }
  .visible .reveal-child:nth-child(5) { transition-delay: 320ms; }
  .visible .reveal-child:nth-child(6) { transition-delay: 400ms; }
  .visible .reveal-child:nth-child(7) { transition-delay: 480ms; }
  @media (prefers-reduced-motion: reduce) {
    .reveal-section,
    .reveal-child { opacity: 1; transform: none; transition: none; }
  }

  /* ── P9: Trust Line ───────────────────────────────────────────────────── */
  .trust-line {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.375rem 1rem;
    font-size: 0.8125rem;
    color: var(--c-muted);
    margin-block-start: 0.75rem;
    font-family: 'Cairo', sans-serif;
  }
  .trust-line__item { display: inline-flex; align-items: center; gap: 0.3rem; }

  /* ── Intent cards lift ────────────────────────────────────────────────── */
  .intent-card {
    transition:
      border-color 250ms var(--curve),
      transform    250ms var(--curve),
      box-shadow   250ms var(--curve);
  }
  .intent-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 40px hsl(1 64% 51% / 0.10);
  }
  .intent-card:active { transform: translateY(0); }

  /* ── Hotline number display ───────────────────────────────────────────── */
  .hotline-num {
    font-family: 'Cairo', sans-serif;
    font-variant-numeric: tabular-nums;
    font-size: clamp(3.5rem, 14vw, 8rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--c-brass);
    line-height: 1;
  }

  /* ── WhatsApp live pulse ──────────────────────────────────────────────── */
  @media (prefers-reduced-motion: no-preference) {
    .wa-live {
      animation: wa-pulse 2.8s ease-in-out infinite;
    }
    @keyframes wa-pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.35); }
      50%       { box-shadow: 0 0 0 10px rgba(37, 211, 102, 0); }
    }
  }

  /* ── FAQ chevron ──────────────────────────────────────────────────────── */
  details summary::-webkit-details-marker { display: none; }
  .faq-chevron { transition: transform 250ms var(--curve); }
  details[open] .faq-chevron { transform: rotate(180deg); }

  /* ── Community stat ───────────────────────────────────────────────────── */
  .stat-num {
    font-family: 'Cairo', sans-serif;
    font-size: clamp(3rem, 10vw, 5rem);
    font-weight: 900;
    line-height: 1;
    color: #fff;
  }

  /* ── Divider dot ──────────────────────────────────────────────────────── */
  .dot-sep { opacity: 0.3; }
</style>


<!-- ═══════════════════════════════════════════════════════════════════════
     HERO — P1 doodles + P2 grain + P4 mesh
     ═══════════════════════════════════════════════════════════════════════ -->
<section
  class="relative overflow-hidden grain-overlay mesh-hero
         bg-[#FBF7F1] dark:bg-[#130F0C]
         min-h-[400px] sm:min-h-[460px]
         flex items-center"
>

  <!-- P1: Doodle field — shared, theme-aware, animated -->
  <Doodles variant="hero" />

  <!-- Content ─────────────────────────────────────────── -->

  <!-- Breadcrumb — visually hidden, kept for accessibility -->
  <nav class="sr-only" aria-label="مسار التنقل">
    <ol>
      <li><a href="/">البيت</a></li>
      <li>تواصل معنا</li>
    </ol>
  </nav>

  <div class="relative z-10 w-full max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-14 sm:py-20">
    <div class="reveal-section flex flex-col sm:flex-row items-start sm:items-end justify-between gap-6 sm:gap-12">

      <!-- Left: hotline as the hero -->
      <div>
        <!-- Brass pre-heading -->
        <p class="reveal-child font-cairo font-semibold text-xs uppercase tracking-[0.16em] mb-3"
           style="color:var(--c-brass)">
          الخط الساخن الرسمي
        </p>

        <!-- THE NUMBER — this IS the header -->
        <div class="reveal-child flex items-baseline gap-3">
          <span class="hotline-num"
                style="color:var(--c-brand)">
            ١٧٥٦٦
          </span>
        </div>

        <!-- Subline -->
        <p class="reveal-child font-cairo text-base sm:text-lg mt-3 leading-relaxed"
           style="color:var(--c-ink-muted)">
          في ثواني — كل يوم، كل وقت
        </p>
      </div>

      <!-- Right: ghosted phone icon (desktop only) -->
      <div class="hidden sm:block flex-shrink-0 select-none pointer-events-none" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round"
             style="color:var(--c-brand);opacity:0.12;width:clamp(80px,12vw,120px);height:clamp(80px,12vw,120px)">
          <path d="M22 16.9v3a2 2 0 01-2.2 2 19.8 19.8 0 01-8.6-3.1 19.5 19.5 0 01-6-6A19.8 19.8 0 012 4.2 2 2 0 014 2h3a2 2 0 012 1.7c.1 1 .4 2 .7 2.9a2 2 0 01-.4 2L8 9.9a16 16 0 006 6l1.3-1.3a2 2 0 012-.5c.9.3 1.9.6 2.9.7A2 2 0 0122 16.9z"/>
        </svg>
      </div>

    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════════════
     INTENT CARDS — catch every visitor type
     ═══════════════════════════════════════════════════════════════════════ -->
<section
  class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-14 reveal-section"
  aria-label="اختاري سبب تواصلك"
>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">

    <!-- Intent A: Pre-purchase inquiry -->
    <a
      href={waProductUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="group reveal-child intent-card card-shine
             flex flex-col gap-4 p-7 rounded-2xl
             bg-surface
             border-2 border-hvar
             hover:border-[var(--c-brand)] dark:hover:border-[var(--c-brand)]
             focus-visible:outline-2 focus-visible:outline-[var(--c-brand)]"
    >
      <div class="w-14 h-14 rounded-2xl bg-[#fef2f2] dark:bg-[var(--c-brand)]/10
                  flex items-center justify-center text-brand
                  group-hover:bg-brand group-hover:text-white"
           style="transition:background 250ms cubic-bezier(0.22,1,0.36,1),color 250ms cubic-bezier(0.22,1,0.36,1)">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
      </div>
      <div class="flex-1">
        <p class="font-cairo font-bold text-base text-ink mb-1.5">
          عايزة تشتري أو تستفسري
        </p>
        <p class="font-cairo text-sm text-muted leading-relaxed">
          سؤال عن منتج، مقارنة بين موديلين، أو تأكيد قبل ما تطلبي — كلمينا على واتساب
        </p>
      </div>
      <span class="font-cairo text-sm font-bold text-brand flex items-center gap-1.5 mt-auto">
        واتساب الآن
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"
             class="rtl:rotate-180" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor"
                stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </a>

    <!-- Intent B: After-sale service -->
    <a
      href="/service/new"
      class="group reveal-child intent-card card-shine
             flex flex-col gap-4 p-7 rounded-2xl
             bg-surface
             border-2 border-hvar
             hover:border-[#C8893B] dark:hover:border-[#C8893B]
             focus-visible:outline-2 focus-visible:outline-[#C8893B]"
    >
      <div class="w-14 h-14 rounded-2xl bg-[#C8893B]/10
                  flex items-center justify-center text-brass"
           style="transition:background 250ms cubic-bezier(0.22,1,0.36,1),color 250ms cubic-bezier(0.22,1,0.36,1)">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
        </svg>
      </div>
      <div class="flex-1">
        <p class="font-cairo font-bold text-base text-ink mb-1.5">
          منتج محتاج خدمة
        </p>
        <p class="font-cairo text-sm text-muted leading-relaxed">
          صيانة، استبدال تحت الضمان، أو إرجاع — افتحي طلب وفريقنا هيرد خلال ٢٤ ساعة
        </p>
      </div>
      <span class="font-cairo text-sm font-bold text-brass flex items-center gap-1.5 mt-auto">
        افتحي طلب خدمة
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"
             class="rtl:rotate-180" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor"
                stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </a>

    <!-- Intent C: Order / complaint -->
    <a
      href={waOrderUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="group reveal-child intent-card card-shine
             flex flex-col gap-4 p-7 rounded-2xl
             bg-surface
             border-2 border-hvar
             hover:border-[#1d9a4a] dark:hover:border-[#1d9a4a]
             focus-visible:outline-2 focus-visible:outline-[#1d9a4a]"
    >
      <div class="w-14 h-14 rounded-2xl bg-[#1d9a4a]/10
                  flex items-center justify-center text-[#1d9a4a]"
           style="transition:background 250ms cubic-bezier(0.22,1,0.36,1),color 250ms cubic-bezier(0.22,1,0.36,1)">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
      </div>
      <div class="flex-1">
        <p class="font-cairo font-bold text-base text-ink mb-1.5">
          طلبي وصل؟ عندي استفسار؟
        </p>
        <p class="font-cairo text-sm text-muted leading-relaxed">
          تتبع طلب، تأخير في التوصيل، أو أي سؤال بعد الشراء — كلمينا مباشرة
        </p>
      </div>
      <span class="font-cairo text-sm font-bold text-[#1d9a4a] flex items-center gap-1.5 mt-auto">
        راسلينا الآن
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"
             class="rtl:rotate-180" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor"
                stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </a>

  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════════════
     PRIMARY CONTACT CHANNELS
     ═══════════════════════════════════════════════════════════════════════ -->
<section
  id="contact"
  class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pb-16"
  aria-label="قنوات التواصل"
>

  <!-- ── Hotline 17566 hero card ──────────────────────────────────────── -->
  <div class="reveal-section mb-6">
    <div class="relative overflow-hidden rounded-3xl grain-overlay
                bg-gradient-to-br from-[#1e1814] to-[#2d1f10]
                dark:from-[#0e0b07] dark:to-[#1a1007]
                p-8 sm:p-10 sm:p-12">

      <!-- Brass ambient glow -->
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
           style="background:radial-gradient(ellipse 70% 60% at 85% 20%,hsl(32 55% 51% / 0.22) 0%,transparent 65%)">
      </div>
      <!-- Red ember top-left -->
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
           style="background:radial-gradient(ellipse 50% 40% at 5% 5%,hsl(1 64% 51% / 0.15) 0%,transparent 60%)">
      </div>

      <div class="relative flex flex-col sm:flex-row sm:items-center gap-8">

        <!-- Number block -->
        <div class="flex flex-col gap-3">
          <span class="font-cairo text-xs font-semibold text-brass tracking-widest uppercase">
            الخط الساخن — مسجّل لدى NTRA
          </span>
          <p class="hotline-num" dir="ltr" aria-label="رقم الخط الساخن ١٧٥٦٦">17566</p>
          <p class="font-cairo text-sm text-[#a8a29e] max-w-xs leading-relaxed">
            اتصلي من أي شبكة في مصر. الخط متاح من ٩ صباحاً لـ٩ مساءً طوال أيام الأسبوع.
          </p>
        </div>

        <!-- CTA block -->
        <div class="sm:ms-auto flex flex-col items-start sm:items-end gap-4 flex-shrink-0">
          <a
            href="tel:17566"
            class="inline-flex items-center gap-3
                   px-8 py-4 rounded-xl min-h-[52px]
                   bg-[#C8893B] hover:bg-[#b07830]
                   text-white font-cairo font-bold text-base
                   focus-visible:outline-2 focus-visible:outline-[#C8893B]"
            style="transition:background 250ms cubic-bezier(0.22,1,0.36,1),box-shadow 250ms cubic-bezier(0.22,1,0.36,1);
                   box-shadow:0 4px 20px hsl(32 55% 51% / 0.40)"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2 4.2 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1 1 .4 2 .7 2.9a2 2 0 0 1-.4 2L8 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2-.5c.9.3 1.9.6 2.9.7A2 2 0 0 1 22 16.9Z"/>
            </svg>
            اتصلي على ١٧٥٦٦
          </a>

          <!-- P9 mini trust -->
          <p class="font-cairo text-xs text-[#a8a29e]">
            من ٩ صباحاً لـ٩ مساءً · ٧ أيام في الأسبوع
          </p>
